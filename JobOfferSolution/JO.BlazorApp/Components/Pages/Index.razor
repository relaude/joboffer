@attribute [Route(JORoutes.Public.Landing)]
@layout LandingLayout
@attribute [AllowAnonymous]
@inject NavigationManager NavigationManager

<HeadContent>
    <link rel="stylesheet" href="/sbadmin2/css/sb-admin-2.css" />
</HeadContent>

<div class="bg-gradient-primary min-vh-100 d-flex align-items-center justify-content-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-6 col-lg-7 col-md-9">
                <div class="text-center text-white">
                    <h1 class="display-4 font-weight-bold mb-4">Job Offer</h1>
                    <button type="button" class="btn btn-light btn-lg shadow-sm px-5" @onclick="Login">
                        Login
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private bool _checkedAuth;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _checkedAuth || AuthenticationStateTask is null)
        {
            return;
        }

        _checkedAuth = true;

        var authState = await AuthenticationStateTask;

        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo("/home", replace: true);
        }
    }

    private void Login()
    {
        NavigationManager.NavigateTo("/MicrosoftIdentity/Account/SignIn?redirectUri=/home", true);
        //NavigationManager.NavigateTo("/home", true);
    }
}
