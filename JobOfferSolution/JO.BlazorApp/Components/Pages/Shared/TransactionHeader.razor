@inject ITransactionService TransactionService

<div class="card shadow mb-4 border-left-primary">

    <!-- Card Header -->
    <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-receipt"></i> Transaction Information
        </h6>

        <span class="badge
                @(jobOfferTransactions.StatusName == "Approved" ? "badge-success" :
                    jobOfferTransactions.StatusName == "Rejected" ? "badge-danger" :
                    "badge-warning")
                px-3 py-2">
            @jobOfferTransactions.StatusName
        </span>
    </div>

    <!-- Card Body -->
    <div class="card-body">

        <div class="row">

            <!-- Left Column -->
            <div class="col-md-6">

                <div class="form-group">
                    <label class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                        Transaction Number
                    </label>
                    <div class="h5 mb-3 font-weight-bold text-gray-800">
                        @jobOfferTransactions.TransactionNumber
                    </div>
                </div>

                <div class="form-group">
                    <label class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                        Candidate Name
                    </label>
                    <div class="h6 mb-3 text-gray-800">
                        <i class="fas fa-user mr-2 text-gray-500"></i>
                        @jobOfferTransactions.CandidateName
                    </div>
                </div>

            </div>

            <!-- Right Column -->
            <div class="col-md-6">

                <div class="form-group">
                    <label class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                        Email Address
                    </label>
                    <div class="h6 mb-3 text-gray-800">
                        <i class="fas fa-envelope mr-2 text-gray-500"></i>
                        @jobOfferTransactions.CandidateEmail
                    </div>
                </div>

                <div class="form-group">
                    <label class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                        Status
                    </label>
                    <div class="h6 mb-3 text-gray-800">
                        @jobOfferTransactions.StatusName
                    </div>
                </div>

            </div>

        </div>

    </div>

</div>

@code {
    [Parameter] public int TransactionId { get; set; }
    private VwJobOfferTransactions jobOfferTransactions = new();

    protected override async Task OnInitializedAsync()
    {
        jobOfferTransactions = await TransactionService.GetTransactionDetails(TransactionId);
    }
}
