@inject IJobOfferService JobOfferService
@inject IUtilitiesService UtilitiesService

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-file-contract mr-2"></i> @jobOffer.JobOfferNumber
        </h6>

        <h6 class="m-0 font-weight-bold text-primary">
            @jobOffer.StatusName
        </h6>
    </div>

    <div class="card-body">

        <div class="row">
            <div class="col-md-4 border-right pr-4">
                <div class="mb-4">
                    <h6 class="font-weight-bold text-primary border-bottom pb-2 mb-3">Position Details</h6>

                    <div class="mb-3">
                        <label class="text-xs text-uppercase text-muted mb-1">Position Title</label>
                        <div class="form-control form-control-sm bg-light">
                            @jobOffer.PositionName
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="text-xs text-uppercase text-muted mb-1">Department</label>
                        <div class="form-control form-control-sm bg-light">
                            @jobOffer.DepartmentName
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="font-weight-bold text-warning border-bottom pb-2 mb-3">Offer Timeline</h6>

                    <div class="mb-3">
                        <label class="text-xs text-uppercase text-muted mb-1">Offer Date</label>
                        <div class="form-control form-control-sm bg-light">
                            @jobOffer.OfferDate?.ToString(CommonConstant.DefaultDateFormat)
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="text-xs text-uppercase text-muted mb-1">Proposed Start Date</label>
                        <div class="form-control form-control-sm bg-light">
                            @jobOffer.ProposedStartDate?.ToString(CommonConstant.DefaultDateFormat)
                        </div>
                    </div>
                </div>

            </div>

            <div class="col-md-8 pl-4">
                <div class="mb-4">
                    <h6 class="font-weight-bold text-success border-bottom pb-2 mb-3">Compensation</h6>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="text-xs text-uppercase text-muted mb-1">Basic Salary</label>
                            <div class="form-control form-control-sm bg-light">
                                @UtilitiesService.ToPeso(jobOffer.BasicSalary)
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="text-xs text-uppercase text-muted mb-1">Allowance</label>
                            <div class="form-control form-control-sm bg-light">
                                @UtilitiesService.ToPeso(jobOffer.Allowance)
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="text-xs text-uppercase text-muted mb-1">Signing Bonus</label>
                            <div class="form-control form-control-sm bg-light">
                                @UtilitiesService.ToPeso(jobOffer.SigningBonus)
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="font-weight-bold text-info border-bottom pb-2 mb-3">Additional Information</h6>

                    <div class="form-control form-control-sm bg-light" style="min-height:80px;">
                        @jobOffer.Remarks
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    [Parameter] public int JobOfferId { get; set; }

    private VwJobOffers jobOffer = new();

    protected override async Task OnParametersSetAsync()
    {
        jobOffer = await JobOfferService.GetJobOffer(JobOfferId);
    }
}
