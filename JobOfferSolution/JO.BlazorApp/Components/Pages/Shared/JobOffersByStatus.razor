@inject IDashboardService DashboardService
@inject IUtilitiesService UtilitiesService
@inject NavigationManager Navigation

<div class="card small shadow mb-4 border-left-primary">
    <div class="card-header">
        <h6 class="m-0 font-weight-bold text-primary">
            @HeaderTitle
        </h6>
    </div>
    <div class="card-body">
        <div class="d-flex flex-column flex-md-row align-items-start flex-wrap mb-3">
            <!-- Filter/Search Section -->
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover table-sm text-nowrap">
                <thead class="thead-light">
                    <tr>
                        <th>JO No.</th>
                        <th>Status</th>
                        <th>Candidate</th>
                        <th>Position</th>
                        <th>Department</th>
                        <th>Offer</th>
                    </tr>
                </thead>
                <tbody>
                    @if (jobOffers.Any())
                    {
                        @foreach (var item in jobOffers)
                        {
                            <tr>
                                <td>
                                    <button type="button"
                                            class="btn btn-sm btn-link text-primary p-0 align-baseline"
                                            style="text-decoration: none;"
                                            @onclick="() => ViewDetails(item)">
                                        @item.JobOfferNumber
                                    </button>
                                </td>
                                <td>@item.StatusName</td>
                                <td>@item.CandidateName</td>
                                <td>@item.PositionName</td>
                                <td>@item.DepartmentName</td>
                                <td>@UtilitiesService.ToPeso(item.BasicSalary)</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">
                                <i class="fas fa-info-circle mr-1"></i> No records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    [Parameter] public int StatusId { get; set; }
    [Parameter] public string RedirectTo { get; set; }
    [Parameter] public string HeaderTitle { get; set; } = "Job Offers";

    private IEnumerable<VwJobOffers> jobOffers = new List<VwJobOffers>();

    protected override async Task OnParametersSetAsync()
    {
        jobOffers = await DashboardService.GetAllJobOffers(StatusId);
    }

    private void ViewDetails(VwJobOffers item)
    {
        Navigation.NavigateTo($"{RedirectTo}/{item.Id}/{item.Candidate_Id}", true);
    }
}
