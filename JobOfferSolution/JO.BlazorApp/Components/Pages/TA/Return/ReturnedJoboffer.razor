@inject IJobOfferService JobOfferService
@inject IDropDownListService DropDownListService
@inject IAlertService AlertService
@inject NavigationManager Navigation

@attribute [Authorize(Roles = JOUserRole.TA)]
@attribute [Route(JORoutes.TA.Return + "/{jobOfferId:int}/{candidateId:int}")]

<ReturnLogs JobOfferId="@jobOfferId" />

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">
            @jobOffer.JobOfferNumber
        </h6>
    </div>
    
    <div class="card-body">
        <div class="mb-4">
            <h6 class="text-xs font-weight-bold text-uppercase text-gray-500 mb-3 border-bottom pb-2">
                Position Details
            </h6>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold text-gray-600">Position Title</label>
                    <InputSelect class="form-control form-control-sm"
                                 @bind-Value="@jobOffer.JobPosition_Id">
                        <option value="0">- Please Select -</option>
                        @foreach (var item in ddPosition)
                        {
                            <option value="@item.Id">@item.Value</option>
                        }
                    </InputSelect>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold text-gray-600">Department</label>
                    <InputSelect class="form-control form-control-sm"
                                 @bind-Value="@jobOffer.Department_Id">
                        <option value="0">- Please Select -</option>
                        @foreach (var item in ddDepartment)
                        {
                            <option value="@item.Id">@item.Value</option>
                        }
                    </InputSelect>
                </div>
            </div>
        </div>
    
        <div class="mb-4">
            <h6 class="text-xs font-weight-bold text-uppercase text-gray-500 mb-3 border-bottom pb-2">
                Compensation Details
            </h6>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold text-gray-600">
                        Basic Salary
                    </label>
                    <InputNumber class="form-control form-control-sm"
                                 @bind-Value="jobOffer.BasicSalary"
                                 min="10000"
                                 step="10000" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold text-gray-600">
                        Allowance
                    </label>
                    <InputNumber class="form-control form-control-sm"
                                 @bind-Value="jobOffer.Allowance"
                                 min="1000"
                                 step="1000" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold text-gray-600">
                        Signing Bonus
                    </label>
                    <InputNumber class="form-control form-control-sm"
                                 @bind-Value="jobOffer.SigningBonus"
                                 min="1000"
                                 step="1000" />
                </div>

                <!-- Empty column for balance -->
                <div class="col-md-6"></div>
            </div>
        </div>
    
        <div class="mb-4">
            <h6 class="text-xs font-weight-bold text-uppercase text-gray-500 mb-3 border-bottom pb-2">
                Offer Timeline
            </h6>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold text-gray-600">
                        Offer Date
                    </label>
                    <div class="form-control form-control-sm bg-light">
                        @(jobOffer.OfferDate.HasValue ? jobOffer.OfferDate.Value.ToString(CommonConstant.DefaultDateFormat) : "")
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="font-weight-bold text-gray-600">
                        Proposed Start Date
                    </label>
                    <InputDate class="form-control form-control-sm"
                               @bind-Value="jobOffer.ProposedStartDate" />
                </div>
            </div>
        </div>
    </div>
    
    <div class="card-footer d-flex justify-content-end">
        <button type="button" class="btn btn-outline-secondary btn-sm mr-2"
                @onclick="GoBack">
            Go Back
        </button>

        <button type="submit" class="btn btn-primary btn-sm shadow-sm"
                @onclick="() => Submit()">
            <i class="fas fa-save fa-sm text-white-50 mr-1"></i>
            Submit
        </button>
    </div>
</div>

@code {
    [Parameter] public int jobOfferId { get; set; }
    [Parameter] public int candidateId { get; set; }

    private IEnumerable<DropdownDto> ddPosition = new List<DropdownDto>();
    private IEnumerable<DropdownDto> ddDepartment = new List<DropdownDto>();
    VwJobOffers jobOffer = new();

    protected override async Task OnParametersSetAsync()
    {
        ddPosition = await DropDownListService.GetJobPositions();
        ddDepartment = await DropDownListService.GetDepartments();
        jobOffer = await JobOfferService.GetJobOffer(jobOfferId);
    }

    private void GoBack()
    {
        Navigation.NavigateTo(JORoutes.TA.Return);
    }

    private async Task Submit()
    {
        List<string> errors = CollectErrors(new List<string>());

        if (errors.Any())
        {
            await AlertService.Errors(errors);
            return;
        }

        if (!await AlertService.Confirm()) return;
    }

    private List<string> CollectErrors(List<string> errors)
    {
        if (jobOffer.JobPosition_Id == 0)
            errors.Add("Position title is required.");

        if (jobOffer.Department_Id == 0)
            errors.Add("Department is required.");

        return errors;
    }
}
