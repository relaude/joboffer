@inject IJobOfferService JobOfferService

<div class="card border-left-primary mb-4 shadow">
    <div class="card-header py-3 d-flex align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Return Logs</h6>
    </div>

    <div class="card-body" style="max-height: 500px; overflow-y: auto;">
        @if (returnLogs != null && returnLogs.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle return-logs-table">
                    <thead class="thead-light">
                        <tr>
                            <th class="text-nowrap">Return By</th>
                            <th class="text-nowrap">Date</th>
                            <th class="text-nowrap">Reason</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in returnLogs)
                        {
                            <tr>
                                <td class="text-nowrap">@item.ReturnBy</td>
                                <td class="text-nowrap">@item.CreatedAt.Value.ToString(CommonConstant.DefaultDateTimeFormat)</td>
                                <td class="text-nowrap">@item.ReasonName</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Remarks))
                                    {
                                        <textarea class="form-control" rows="3" readonly>@item.Remarks</textarea>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-3 text-center text-muted">
                <i class="fa-solid fa-file-lines fa-2x mb-2"></i>
                <div>No records available</div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int JobOfferId { get; set; }

    IEnumerable<VwReturnLogs> returnLogs = new List<VwReturnLogs>();

    protected override async Task OnParametersSetAsync()
    {
        returnLogs = await JobOfferService.GetReturnLogs(JobOfferId);
    }
}
