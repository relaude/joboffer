@attribute [Authorize(Roles = JOUSerRole.TA)]
@attribute [Route(JORoutes.TA.JobOffer)]

@inject ICandidateService CandidateService
@inject IUtilitiesService UtilitiesService
@inject IAlertService AlertService
@inject IDropDownListService DropDownListService
@inject NavigationManager Navigation

<div class="card small shadow mb-4 border-left-primary">
    <div class="card-header">
        <h6 class="m-0 font-weight-bold text-primary">
            JO Creation
        </h6>
    </div>

    <div class="card-body">

        <div class="form-row align-items-center mb-4">
            <div class="col-md-4">
                <div class="input-group input-group-sm">
                    <input type="text"
                           class="form-control"
                           placeholder="Candidate name"
                           @bind="@candidateName">
                </div>
            </div>

            <div class="col-md-2">
                <button class="btn btn-primary btn-sm btn-block"
                        @onclick="() => ChangePage(1)">
                    <i class="fas fa-search mr-2"></i> Apply Filters
                </button>
            </div>

            <div class="col-md-2">
                <button class="btn btn-outline-secondary btn-sm btn-block"
                        @onclick="() => Reset()">
                    <i class="fas fa-eraser mr-2"></i>Reset
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover table-sm text-nowrap">
                <thead class="thead-light">
                    <tr>
                        <th>Name</th>
                        <th>JO Status</th>
                        <th>Email</th>
                        <th>Position Applied For</th>
                        <th>Expected Salary</th>
                    </tr>
                </thead>
                <tbody>
                    @if (candidates.Any())
                    {
                        @foreach (var item in candidates)
                        {
                            <tr>
                                <td>
                                    <button type="button"
                                            class="btn btn-sm btn-link text-primary p-0 align-baseline"
                                            style="text-decoration: none;"
                                            @onclick="() => CreateJO(item.Id)">
                                        @($"{item.FirstName} {item.LastName}")
                                    </button>
                                </td>
                                <td>@item.CandidateJOStatus</td>
                                <td>@item.Email</td>
                                <td>@item.PositionAppliedFor</td>
                                <td>@UtilitiesService.ToPeso(item.ExpectedSalary)</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">
                                <i class="fas fa-info-circle mr-1"></i> No records found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <Pagination TotalRows="@totalCount"
                    RowsPerPage="@pageSize"
                    CurrentPage="@currentPage"
                    MaxPageButtons="5"
                    OnPageChanged="ChangePage">
        </Pagination>

    </div>
</div>

@code {
    private IEnumerable<VwCandidates> candidates = new List<VwCandidates>();

    //filters
    private string? candidateName = "";

    //pagination
    private int currentPage = 1;
    private int pageSize = CommonConstant.DefaultPageSize;
    private int totalCount = 0;
    private EventCallback<int> OnPageChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await ChangePage(1);
    }

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        var pagedCandidates = await CandidateService.CandidatesForJOCretionAsync(
            candidateName,
            currentPage,
            pageSize);

        candidates = pagedCandidates.Data;
        totalCount = pagedCandidates.TotalCount;
    }

    private async Task Reset()
    {
        candidateName = "";
        await ChangePage(1);
    }

    private void CreateJO(int id)
    {
        Navigation.NavigateTo($"{JORoutes.TA.JobOffer}/{id}");
    }
}
