@inject ITransactionService TransactionService
@inject ITalentAcquisitionService TalentAcquisitionService
@inject IAlertService AlertService

<div class="card shadow mb-4 border-left-primary">

    <div class="card-header py-3 d-flex justify-content-between align-items-center bg-white">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-receipt"></i> @jobOfferTransactions.TransactionNumber
        </h6>

        <span class="badge badge-info px-3 py-2">
            @jobOfferTransactions.StatusName
        </span>
    </div>

    <div class="card-body">
        <!-- Candidate Name -->
        <div class="row align-items-center py-2">
            <div class="col-md-4 text-xs font-weight-bold text-primary text-uppercase">
                <i class="fas fa-user mr-2 text-gray-400"></i>
                Candidate Name
            </div>
            <div class="col-md-8 text-gray-800 font-weight-600">
                @jobOfferTransactions.CandidateName
            </div>
        </div>

        <!-- Email Address -->
        <div class="row align-items-center py-2">
            <div class="col-md-4 text-xs font-weight-bold text-primary text-uppercase">
                <i class="fas fa-envelope mr-2 text-gray-400"></i>
                Email Address
            </div>
            <div class="col-md-8 text-gray-800">
                @jobOfferTransactions.CandidateEmail
            </div>
        </div>

        <!-- HROD Candidate -->
        <div class="row align-items-center py-2">
            <div class="col-md-4 text-xs font-weight-bold text-primary text-uppercase">
                <i class="fas fa-user-check mr-2 text-gray-400"></i>
                HROD Candidate
            </div>
            <div class="col-md-8">
                <select class="form-control form-control-sm d-inline-block"
                        style="width: 120px;"
                        @bind="isHrod">
                    <option value="1">Yes</option>
                    <option value="0">No</option>
                </select>
            </div>
        </div>
    </div>

    <div class="card-footer d-flex justify-content-end">
        <button class="btn btn-sm btn-primary" 
            @onclick="() => TagHrodCandidate()">
            <i class="fas fa-floppy-disk mr-1"></i> Save
        </button>
    </div>
</div>

@code {
    [Parameter] public int TransactionId { get; set; }

    private VwJobOfferTransactions jobOfferTransactions = new();
    private string isHrod = "0";

    protected override async Task OnParametersSetAsync()
    {
        await GetDetails();
    }

    private async Task GetDetails()
    {
        jobOfferTransactions = await TransactionService.GetTransactionDetails(TransactionId);
        isHrod = jobOfferTransactions.IsHROD == true ? "1" : "0";
    }

    private async Task TagHrodCandidate()
    {
        if (!await AlertService.Confirm())
            return;

        await TalentAcquisitionService
            .TagAsHrodCandidate(jobOfferTransactions.Candidate_Id, isHrod == "1");

        await GetDetails();
        //StateHasChanged();
    }
}
