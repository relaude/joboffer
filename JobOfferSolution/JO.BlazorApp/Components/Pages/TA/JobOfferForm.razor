<div class="card shadow mb-4 border-left-primary">

    <!-- Card Header -->
    <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">
            Create New Job Offer
        </h6>
    </div>

    <!-- Card Body -->
    <div class="card-body small">

        <EditForm Model="@jobOfferModel" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger mb-3" />

            <!-- ================= Position Details ================= -->
            <div class="mb-4">
                <h6 class="text-xs font-weight-bold text-uppercase text-gray-500 mb-3 border-bottom pb-2">
                    Position Details
                </h6>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold text-gray-600">
                            Position Title
                        </label>
                        <InputText class="form-control form-control-sm"
                                   @bind-Value="jobOfferModel.PositionTitle" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold text-gray-600">
                            Department
                        </label>
                        <InputText class="form-control form-control-sm"
                                   @bind-Value="jobOfferModel.Department" />
                    </div>
                </div>
            </div>

            <!-- ================= Compensation ================= -->
            <div class="mb-4">
                <h6 class="text-xs font-weight-bold text-uppercase text-gray-500 mb-3 border-bottom pb-2">
                    Compensation Details
                </h6>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold text-gray-600">
                            Basic Salary
                        </label>
                        <InputNumber class="form-control form-control-sm"
                                     @bind-Value="jobOfferModel.BasicSalary" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold text-gray-600">
                            Allowance
                        </label>
                        <InputNumber class="form-control form-control-sm"
                                     @bind-Value="jobOfferModel.Allowance" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold text-gray-600">
                            Signing Bonus
                        </label>
                        <InputNumber class="form-control form-control-sm"
                                     @bind-Value="jobOfferModel.SigningBonus" />
                    </div>

                    <!-- Empty column for balance -->
                    <div class="col-md-6"></div>
                </div>
            </div>

            <!-- ================= Offer Timeline ================= -->
            <div class="mb-4">
                <h6 class="text-xs font-weight-bold text-uppercase text-gray-500 mb-3 border-bottom pb-2">
                    Offer Timeline
                </h6>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold text-gray-600">
                            Offer Date
                        </label>
                        <InputDate class="form-control form-control-sm"
                                   @bind-Value="jobOfferModel.OfferDate" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold text-gray-600">
                            Proposed Start Date
                        </label>
                        <InputDate class="form-control form-control-sm"
                                   @bind-Value="jobOfferModel.StartDate" />
                    </div>
                </div>
            </div>

            <!-- ================= Remarks ================= -->
            <div class="mb-4">
                <h6 class="text-xs font-weight-bold text-uppercase text-gray-500 mb-3 border-bottom pb-2">
                    Additional Information
                </h6>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="font-weight-bold text-gray-600">
                            Remarks
                        </label>
                        <InputTextArea class="form-control form-control-sm"
                                       rows="4"
                                       @bind-Value="jobOfferModel.Remarks" />
                    </div>

                    <!-- Empty column for visual symmetry -->
                    <div class="col-md-6"></div>
                </div>
            </div>

            <!-- ================= Actions ================= -->
            <div class="d-flex justify-content-end border-top pt-3">
                <button type="button" class="btn btn-outline-secondary btn-sm mr-2">
                    Cancel
                </button>

                <button type="submit" class="btn btn-primary btn-sm shadow-sm">
                    <i class="fas fa-save fa-sm text-white-50 mr-1"></i>
                    Save Job Offer
                </button>
            </div>

        </EditForm>

    </div>
</div>

@code {
    private JobOfferModel jobOfferModel = new();

    private async Task HandleSubmit()
    {
        // Save logic here
    }

    public class JobOfferModel
    {
        public string PositionTitle { get; set; }
        public string Department { get; set; }
        public decimal? BasicSalary { get; set; }
        public decimal? Allowance { get; set; }
        public decimal? SigningBonus { get; set; }
        public DateTime? OfferDate { get; set; }
        public DateTime? StartDate { get; set; }
        public string Remarks { get; set; }
    }
}
