@attribute [Authorize(Roles = JOUserRole.TA)]
@attribute [Route(JORoutes.TA.MSFormFileUpload + "/{requestId:int}")]

@inject ICandidateService CandidateService
@inject IUtilitiesService UtilitiesService
@inject IMSFormRequestService MSFormRequestService
@inject IAlertService AlertService
@inject NavigationManager Navigation

<div class="card shadow mb-4 border-left-primary small ms-form-page">
    <div class="card-header py-3 bg-white d-flex flex-column flex-md-row justify-content-between align-items-md-center">
        <div class="mb-2 mb-md-0">
            <div class="d-flex align-items-center mb-1">
                <div class="icon-circle bg-primary text-white mr-2">
                    <i class="fas fa-file-alt"></i>
                </div>
                <div>
                    <h6 class="m-0 font-weight-bold text-primary">
                        Compensation & Benefits Form Request Details
                    </h6>
                    <div class="text-xs text-gray-500">
                        Talent Acquisition request overview
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex flex-wrap align-items-center">
            <span class="badge badge-primary mr-1">
                <i class="fas fa-hashtag fa-fw mr-1"></i>
                @DisplayText(requestInfo.ReferenceNumber)
            </span>
            <span class="badge badge-light border mr-1">
                <i class="fas fa-user-shield fa-fw text-primary mr-1"></i>
                Talent Acquisition View
            </span>
        </div>
    </div>

    <div class="card-body">
        <div class="row">
            <!-- Candidate Info -->
            <div class="col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-header py-2 bg-white d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            Candidate Information
                        </h6>
                    </div>
                    <div class="card-body py-3">
                        <div class="row small mb-2">
                            <div class="col-5 text-muted">Candidate Name</div>
                            <div class="col-7 font-weight-bold text-gray-800">@CandidateName</div>
                        </div>
                        <div class="row small mb-2">
                            <div class="col-5 text-muted">Email Address</div>
                            <div class="col-7">@DisplayText(candidate.Email)</div>
                        </div>
                        <div class="row small mb-2">
                            <div class="col-5 text-muted">Contact Number</div>
                            <div class="col-7">@DisplayText(candidate.ContactNumber)</div>
                        </div>
                        <div class="row small mb-2">
                            <div class="col-5 text-muted">Position Applied</div>
                            <div class="col-7">@DisplayText(candidate.PositionAppliedFor)</div>
                        </div>
                        <div class="row small mb-2">
                            <div class="col-5 text-muted">Current Employer</div>
                            <div class="col-7">@DisplayText(candidate.CurrentEmployer)</div>
                        </div>
                        <div class="row small">
                            <div class="col-5 text-muted">Expected Salary</div>
                            <div class="col-7 font-weight-bold text-success">
                                @UtilitiesService.ToPeso(candidate.ExpectedSalary)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Candidate Info -->
            <!-- Work Info -->
            <div class="col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-header py-2 bg-white d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            Work Information
                        </h6>
                    </div>
                    <div class="card-body py-3">
                        <div class="row small mb-2">
                            <div class="col-5 text-muted">Current Employer</div>
                            <div class="col-7 font-weight-bold">@DisplayText(candidate.CurrentEmployer)</div>
                        </div>
                        <div class="row small mb-2">
                            <div class="col-5 text-muted">Last Position</div>
                            <div class="col-7">@DisplayText(candidate.LastPositionHeld)</div>
                        </div>
                        <div class="row small mb-2">
                            <div class="col-5 text-muted">Employment Status</div>
                            <div class="col-7">@DisplayText(candidate.EmploymentStatusName)</div>
                        </div>
                        <div class="row small mb-2">
                            <div class="col-5 text-muted">Experience</div>
                            <div class="col-7">@DisplayText(candidate.WorkExperienceName)</div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Work Info -->
            <!-- Quick View -->
            <div class="col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-header py-2 bg-white d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            Quick Overview
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="d-flex align-items-start mb-3">
                            <div class="icon-circle-sm bg-success text-white mr-3">
                                <i class="fas fa-clipboard-check"></i>
                            </div>
                            <div>
                                <div class="font-weight-bold text-gray-800">Request Status</div>
                                <div class="small text-gray-500">@DisplayText(requestInfo.StatusName)</div>
                            </div>
                        </div>

                        <div class="d-flex align-items-start mb-3">
                            <div class="icon-circle-sm bg-info text-white mr-3">
                                <i class="fas fa-calendar-alt"></i>
                            </div>
                            <div>
                                <div class="font-weight-bold text-gray-800">Sent Date</div>
                                <div class="small text-gray-500">@FormatDateTime(requestInfo.RequestSentDate)</div>
                            </div>
                        </div>

                        <div class="d-flex align-items-start mb-3">
                            <div class="icon-circle-sm bg-warning text-white mr-3">
                                <i class="fas fa-bell"></i>
                            </div>
                            <div>
                                <div class="font-weight-bold text-gray-800">First Reminder</div>
                                <div class="small text-gray-500">@FormatDateTime(requestInfo.Reminder1SentDate)</div>
                            </div>
                        </div>

                        <div class="d-flex align-items-start">
                            <div class="icon-circle-sm bg-secondary text-white mr-3">
                                <i class="fas fa-bell"></i>
                            </div>
                            <div>
                                <div class="font-weight-bold text-gray-800">Second Reminder</div>
                                <div class="small text-gray-500">@FormatDateTime(requestInfo.Reminder2SentDate)</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Quick View -->
        </div>

        <div class="row">
            <div class="col-lg-5 mb-4">
                <div class="card h-100">
                    <div class="card-header py-2 bg-white d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            Upload File
                        </h6>
                        <span class="badge badge-light border text-gray-600">
                            Mock Layout
                        </span>
                    </div>
                    <div class="card-body">
                        <div class="border rounded bg-light text-center p-4 mb-3">
                            <div class="icon-circle bg-primary text-white mx-auto mb-3">
                                <i class="fas fa-cloud-upload-alt"></i>
                            </div>
                            <div class="font-weight-bold text-gray-800 mb-1">
                                Drop candidate documents here
                            </div>
                            <div class="small text-gray-500 mb-3">
                                Supported files: PDF, DOCX, PNG, JPG
                            </div>
                            <button type="button" class="btn btn-primary btn-sm" disabled>
                                <i class="fas fa-folder-open fa-fw mr-1"></i>
                                Browse Files
                            </button>
                        </div>

                        <div class="form-row">
                            <div class="form-group col-md-6 mb-2">
                                <label class="text-xs font-weight-bold text-gray-600 text-uppercase mb-1">
                                    Candidate ID
                                </label>
                                <input class="form-control form-control-sm" value="@DisplayText(candidate.Id.ToString())" disabled />
                            </div>
                            <div class="form-group col-md-6 mb-2">
                                <label class="text-xs font-weight-bold text-gray-600 text-uppercase mb-1">
                                    MS Form Request ID
                                </label>
                                <input class="form-control form-control-sm" value="@requestId" disabled />
                            </div>
                        </div>

                        <div class="form-group mb-0">
                            <label class="text-xs font-weight-bold text-gray-600 text-uppercase mb-1">
                                File Type
                            </label>
                            <select class="form-control form-control-sm" disabled>
                                <option>Pre-employment Requirement</option>
                                <option>Valid ID</option>
                                <option>Signed Offer</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7 mb-4">
                <div class="card h-100">
                    <div class="card-header py-2 bg-white d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            Submitted Documents
                        </h6>
                        <span class="small text-gray-500 mt-1 mt-md-0">
                            Mock data based on submitted document records
                        </span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th class="border-0 pl-3">File Name</th>
                                        <th class="border-0">Type ID</th>
                                        <th class="border-0">Size</th>
                                        <th class="border-0">Uploaded By</th>
                                        <th class="border-0 pr-3">Uploaded Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="pl-3">
                                            <div class="font-weight-bold text-gray-800">signed-offer-letter.pdf</div>
                                            <div class="text-xs text-gray-500">/mock/uploads/signed-offer-letter.pdf</div>
                                        </td>
                                        <td>
                                            <span class="badge badge-primary">3</span>
                                        </td>
                                        <td>248 KB</td>
                                        <td>TA Admin</td>
                                        <td class="pr-3">Jun 24, 2026 09:15 AM</td>
                                    </tr>
                                    <tr>
                                        <td class="pl-3">
                                            <div class="font-weight-bold text-gray-800">government-id-front.jpg</div>
                                            <div class="text-xs text-gray-500">/mock/uploads/government-id-front.jpg</div>
                                        </td>
                                        <td>
                                            <span class="badge badge-info">2</span>
                                        </td>
                                        <td>512 KB</td>
                                        <td>Candidate</td>
                                        <td class="pr-3">Jun 25, 2026 02:40 PM</td>
                                    </tr>
                                    <tr>
                                        <td class="pl-3">
                                            <div class="font-weight-bold text-gray-800">pre-employment-form.docx</div>
                                            <div class="text-xs text-gray-500">/mock/uploads/pre-employment-form.docx</div>
                                        </td>
                                        <td>
                                            <span class="badge badge-success">1</span>
                                        </td>
                                        <td>184 KB</td>
                                        <td>Candidate</td>
                                        <td class="pr-3">Jun 26, 2026 11:05 AM</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="card-footer text-right">
        <a href="@JORoutes.TA.RequestTracker" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left fa-fw mr-1"></i>Back to Tracker
        </a>

        <button type="button" class="btn btn-primary btn-sm mr-1" @onclick="SubmitRequest">
            <i class="fas fa-check fa-fw mr-1"></i>Submitted
        </button>
    </div>
</div>

@code {
    [Parameter] public int requestId { get; set; }

    private VwCandidateMSFormRequests requestInfo = new();
    private VwCandidates candidate = new();

    protected override async Task OnInitializedAsync()
    {
        requestInfo = await MSFormRequestService.GetMSFormRequest(requestId) ?? new();

        if (requestInfo?.CandidateId is int candidateId)
            candidate = await CandidateService.GetCandidate(candidateId) ?? new();
    }

    private async Task SubmitRequest()
    {
        if (!await AlertService.Confirm("Tag this MS Form request as submitted?", "Submit"))
            return;

        await MSFormRequestService.TagMSFormRequestAsSubmitted(requestId);
        Navigation.NavigateTo(JORoutes.TA.RequestTracker);
    }

    private string CandidateName
    {
        get
        {
            var firstName = string.IsNullOrWhiteSpace(candidate.FirstName)
                ? requestInfo.FirstName
                : candidate.FirstName;

            var lastName = string.IsNullOrWhiteSpace(candidate.LastName)
                ? requestInfo.LastName
                : candidate.LastName;

            return DisplayText($"{firstName} {lastName}".Trim());
        }
    }

    private static string DisplayText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "N/A" : value;
    }

    private static string FormatDateTime(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("MMM dd, yyyy hh:mm tt") : "N/A";
    }
}
