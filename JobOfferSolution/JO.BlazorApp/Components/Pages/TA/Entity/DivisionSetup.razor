@attribute [Authorize(Roles = JOUserRole.TA)]
@attribute [Route(JORoutes.TA.DivisionSetup + "/{requestId:int}")]

@inject IMSFormRequestService MSFormRequestService
@inject IDropDownListService DropDownListService
@inject ISalaryMatrixService SalaryMatrixService
@inject IJOAnalysisService JOAnalysisService
@inject IAlertService AlertService

<div class="card shadow mb-4 border-left-primary small jo-form-page">
    <div class="card-header py-3 bg-white">
        <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between">
            <div>
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-building fa-fw mr-2"></i>
                    Company and Legal Entity Setup
                </h6>
                <small class="text-muted">Fields marked <span class="text-danger">*</span> are required.</small>
            </div>

            <div class="mt-2 mt-lg-0">
                <span class="badge badge-light border mr-1">
                    <i class="fas fa-user-tie fa-fw text-primary mr-1"></i>
                    TA Partner View
                </span>
                <span class="badge badge-success">
                    <i class="fas fa-check-circle fa-fw mr-1"></i>
                    Matrix Matched
                </span>
            </div>
        </div>


    </div>

    <div class="card-body">

        <div class="alert alert-light border-left-info py-2 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="fas fa-info-circle fa-fw text-info mr-2"></i>
                <span>Select the hiring company and legal entity for this offer so compensation rules, payroll setup, and compliance checks use the correct entity.</span>
            </div>
        </div>

        <!-- Summary -->
        <div class="row mb-4">
            <div class="col-xl-4 col-md-6 mb-3 mb-xl-0">
                <div class="border-left-primary bg-light px-3 py-2 h-100">
                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Candidate</div>
                    <div class="font-weight-bold text-gray-900">@($"{requestInfo.FirstName} {requestInfo.LastName}")</div>
                    <div class="text-muted">@requestInfo.Email</div>
                </div>
            </div>

            <div class="col-xl-4 col-md-6 mb-3 mb-xl-0">
                <div class="border-left-info bg-light px-3 py-2 h-100">
                    <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Requisition</div>
                    <div class="font-weight-bold text-gray-900">@requestInfo.ReferenceNumber</div>
                    <div class="text-muted">@requestInfo.StatusName</div>
                </div>
            </div>

            <div class="col-xl-4 col-md-6">
                <div class="border-left-warning bg-light px-3 py-2 h-100">
                    <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">TA Owner</div>
                    <div class="font-weight-bold text-gray-900">@requestInfo.TAOwner</div>
                </div>
            </div>
        </div>
        <!-- Summary -->

        <div class="row">
            <!-- Division -->
            <div class="col-lg-4 mb-4">
                <div class="card">
                    <div class="card-header bg-white">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-sitemap fa-fw text-primary mr-2"></i>
                            Division Assignment
                        </h6>
                        <small class="text-muted">Company and Division options</small>
                    </div>

                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label class="font-weight-bold text-gray-800">
                                Company <span class="text-danger">*</span>
                            </label>
                            <select class="form-control form-control-sm"
                                    @bind="selectedCompanyId"
                                    @bind:after="OnCompanyChanged">
                                @foreach (var option in ddCompanies)
                                {
                                    <option value="@option.Id">@option.Value</option>
                                }
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label class="font-weight-bold text-gray-800">
                                Division <span class="text-danger">*</span>
                            </label>
                            <select class="form-control form-control-sm"
                                    @bind="selectedDivisionId"
                                    @bind:after="OnDivisionChanged"
                                    disabled="@(ddDivisions.Count == 0)">
                                @foreach (var option in ddDivisions)
                                {
                                    <option value="@option.Id">@option.Value</option>
                                }
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label class="font-weight-bold text-gray-800">
                                Salary Matrix <span class="text-danger">*</span>
                            </label>
                            <select class="form-control form-control-sm"
                                    @bind="selectedMatrixId"
                                    @bind:after="OnMatrixChanged"
                                    disabled="@(ddMatrix.Count == 0)">
                                @foreach (var option in ddMatrix)
                                {
                                    <option value="@option.Id">@option.Value</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Matrix -->
            <div class="col-lg-8 mb-4">
                <div class="card">
                    <div class="card-header bg-white">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-table fa-fw text-primary mr-2"></i>
                            Salary Matrix Preview
                        </h6>
                        <small class="text-muted">Salary ranges based on SalaryMatrix and SalaryMatrixBand references.</small>
                    </div>

                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm text-nowrap mb-0">
                                <thead class="thead-light text-center">
                                    <tr>
                                        <th>Job Level</th>
                                        <th>Job Family</th>
                                        <th>Position Grade</th>
                                        <th>Minimum</th>
                                        <th>Midpoint</th>
                                        <th>Maximum</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var band in salaryBands)
                                    {
                                        <tr>
                                            <td>@band.JobLevelName</td>
                                            <td>@band.JobFamilyName</td>
                                            <td>@band.PositionGrade</td>
                                            <td class="text-right">@band.BandMinimum</td>
                                            <td class="text-right font-weight-bold text-gray-900">@band.BandMidpoint</td>
                                            <td class="text-right">@band.BandMaximum</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-footer text-right">
        <a href="@JORoutes.TA.RequestTracker" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left fa-fw mr-1"></i>Back to Tracker
        </a>

        <button type="button" class="btn btn-primary btn-sm mr-1">
            <i class="fas fa-save fa-fw mr-1"></i>Submit
        </button>
    </div>
</div>

@code {
    [Parameter] public int requestId { get; set; }

    private VwCandidateMSFormRequests requestInfo = new();
    private List<DropdownDto> ddCompanies = new();
    private List<DropdownDto> ddDivisions = new();
    private List<DropdownDto> ddMatrix = new();
    private List<VwSalaryMatrixBand> salaryBands = new();

    private int selectedCompanyId = 0;
    private int selectedDivisionId = 0;
    private int selectedMatrixId = 0;

    protected override async Task OnInitializedAsync()
    {
        requestInfo = await MSFormRequestService.GetMSFormRequest(requestId) ?? new();

        ddCompanies = await DropDownListService.GetCompanies();
        selectedCompanyId = ddCompanies.FirstOrDefault()?.Id ?? 0;

        await OnCompanyChanged();
    }

    private async Task OnCompanyChanged()
    {
        ddDivisions.Clear();
        ddMatrix.Clear();
        salaryBands.Clear();
        selectedDivisionId = 0;
        selectedMatrixId = 0;
        
        if (selectedCompanyId > 0)
            ddDivisions = await DropDownListService.GetDivisionsByCompnayId(selectedCompanyId);

        selectedDivisionId = ddDivisions.FirstOrDefault()?.Id ?? 0;

        await OnDivisionChanged();
    }

    private async Task OnDivisionChanged()
    {
        ddMatrix.Clear();
        salaryBands.Clear();
        selectedMatrixId = 0;
        
        if (selectedDivisionId > 0)
            ddMatrix = await DropDownListService.GetSalaryMatrixByDivisionId(selectedDivisionId);

        selectedMatrixId = ddMatrix.FirstOrDefault()?.Id ?? 0;

        await OnMatrixChanged();
    }

    private async Task OnMatrixChanged()
    {
        salaryBands.Clear();
        
        if (selectedMatrixId > 0)
            salaryBands = await SalaryMatrixService.GetSalaryBands(selectedMatrixId);
    }
}
