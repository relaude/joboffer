@attribute [Authorize(Roles = JOUserRole.TA)]
@attribute [Route(JORoutes.TA.ApplicationDetails + "/{applicationId:int}")]

@inject IJOAnalysisService JOAnalysisService
@inject ISalaryMatrixService SalaryMatrixService
@inject ICandidateService CandidateService

<div class="card shadow mb-4 border-left-primary small jo-form-page">
    <div class="card-header py-3 bg-white">
        <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between">
            <div>
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-building fa-fw mr-2"></i>
                    Company and Legal Entity Details
                </h6>
                <small class="text-muted">@application.ReferenceNumber</small>
            </div>

            <div class="mt-2 mt-lg-0">
                <span class="badge badge-light border mr-1">
                    <i class="fas fa-user-tie fa-fw text-primary mr-1"></i>
                    TA Partner View
                </span>
            </div>
        </div>
    </div>

    <div class="card-body">

        <div class="row text-center mb-4">
            @foreach (var step in workFlow.Take(6))
            {
                <div class="col-xl col-md-4 col-6 mb-2">
                    <div class="border rounded bg-light px-2 py-2 h-100">
                        <div class="text-@step.ActionClass mb-1"><i class="@step.Icon"></i></div>
                        <div class="text-xs font-weight-bold text-gray-800">@step.ShortName</div>
                        <span class="badge badge-@step.ActionClass mt-1">@step.ActionName</span>
                    </div>
                </div>
            }
        </div>

        <div class="row">

            <!-- Candidate -->
            <div class="col-lg-4 mb-4">
                <div class="card">
                    <div class="card-header bg-white">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            <i class="fas fa-id-card fa-fw text-primary mr-2"></i>
                            Candidate Information
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Candidate Name</div>
                            <div class="col-sm-8 font-weight-bold text-gray-900">@application.CandidateName</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Position Applied</div>
                            <div class="col-sm-8">@candidate.ApplyFor</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Expected Salary</div>
                            <div class="col-sm-8 font-weight-bold text-gray-900">@candidate.Salary</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Application -->
            <div class="col-lg-4 mb-4">
                <div class="card">
                    <div class="card-header bg-white">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            <i class="fas fa-building fa-fw text-primary mr-2"></i>
                            Application Details
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Reference No.</div>
                            <div class="col-sm-8 font-weight-bold text-gray-900">
                                @application.ReferenceNumber
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Position Title</div>
                            <div class="col-sm-8">@application.PositionAppliedFor</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Company</div>
                            <div class="col-sm-8">
                                @application.CompanyName
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Division</div>
                            <div class="col-sm-8 font-weight-bold text-gray-900">
                                @application.DivisionName
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Salary Matrix</div>
                            <div class="col-sm-8 font-weight-bold text-gray-900">
                                @application.MatrixName
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="card">
                    <div class="card-header bg-white">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            <i class="fas fa-table fa-fw text-primary mr-2"></i>
                            Salary Bands
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm text-nowrap mb-0">
                                <thead class="thead-light text-center">
                                    <tr>
                                        <th>Job Level</th>
                                        <th>Minimum</th>
                                        <th>Midpoint</th>
                                        <th>Maximum</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var band in salaryBands)
                                    {
                                        <tr>
                                            <td>@band.JobLevelName</td>
                                            <td class="text-right">@band.BandMinimum</td>
                                            <td class="text-right font-weight-bold text-gray-900">@band.BandMidpoint</td>
                                            <td class="text-right">@band.BandMaximum</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="card-footer text-right">
        <a href="@JORoutes.TA.JobOfferTracker" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left fa-fw mr-1"></i>Back to Tracker
        </a>
    </div>
</div>

@code {
    [Parameter] public int applicationId { get; set; }

    private VwCandidateApplications application = new();
    private List<VwSalaryMatrixBand> salaryBands = new();
    private Candidates candidate = new();
    private List<VwJobOfferWorkFlow> workFlow = new();

    protected override async Task OnInitializedAsync()
    {
        application = await JOAnalysisService.GetCandidateApplication(applicationId) ?? new();
        workFlow = await JOAnalysisService.GetJobOfferWorkFlow(applicationId);
        salaryBands = await SalaryMatrixService.GetSalaryBands(application.SalaryMatrixId.Value) ?? new();
        candidate = await CandidateService.GetCandidate(application.CandidateId.Value) ?? new();
    }
}
