@attribute [Authorize(Roles = JOUserRole.TA)]
@attribute [Route(JORoutes.TA.Analysis + "/{applicationId:int}")]

@inject IJOAnalysisService JOAnalysisService
@inject ISalaryMatrixService SalaryMatrixService
@inject ICandidateService CandidateService
@inject IAccountService AccountService
@inject IUtilitiesService UtilitiesService
@inject IAlertService AlertService
@inject IDropDownListService DropDownListService
@inject NavigationManager Navigation

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header bg-white py-3">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between">
            <div>
                <div class="d-flex align-items-center mb-1">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-chart-line fa-fw mr-2"></i>Job Offer Analysis
                    </h6>
                    <span class="badge badge-warning ml-2">3 options awaiting creation</span>
                </div>
                <div class="text-muted">ReferenceNumber</div>
            </div>
            <div class="d-flex align-items-center mt-3 mt-lg-0">
                <span class="badge badge-light border mr-2">
                    <i class="fas fa-user-tie fa-fw text-primary mr-1"></i>
                    TA Partner View
                </span>
            </div>
        </div>
    </div>
    
    <div class="card-body p-3 p-lg-4">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-2">
            <div>
                <h6 class="font-weight-bold text-gray-900 mb-0">Proposal options</h6>
                <span class="text-muted">Review the key differences per card.</span>
            </div>
        </div>

        <!-- Proposals -->
        <div class="row">
            @foreach (var option in joProposals)
            {
                <div class="col-xl-4 mb-3">
                    <div class="card shadow-sm h-100 @(IsRecommended(option.OptionNumber) ? "border-primary" : "border")">
                        <div class="card-header px-3 py-3 @(IsRecommended(option.OptionNumber) ? "bg-primary text-white" : "bg-light")">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="d-flex align-items-center font-weight-bold">
                                        <input class="mr-2"
                                               type="checkbox"
                                               name="recommend"
                                               value="@option.OptionNumber"
                                               checked="@(selectedOptionNumber == option.OptionNumber)"
                                               @onchange="@(() => OnRecommendChange(option.OptionNumber))" />

                                        @if (IsRecommended(option.OptionNumber))
                                        {
                                            <i class="fas fa-star mr-1"></i>
                                        }

                                        <span>@($"Option {option.OptionNumber}")</span>
                                    </div>

                                    @if (IsRecommended(option.OptionNumber))
                                    {
                                        <small class="text-white-50">TA Recommended</small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">Other Offer</small>
                                    }
                                </div>

                                <span class="badge @(IsRecommended(option.OptionNumber) ? "badge-light" : "badge-success")">
                                    @ValidationStatusName(option.ValidationStatusId)
                                </span>
                            </div>
                        </div>
                    
                        <div class="card-body p-3">

                            <div class="d-flex justify-content-between align-items-end mb-3">
                                <div>
                                    <div class="text-xs text-muted text-uppercase">Monthly base</div>
                                    <div class="h5 font-weight-bold text-gray-900 mb-0">
                                        <input class="form-control form-control-sm form-ctrl-sml" type="number" step="1000" @bind="option.ProposedSalary" />
                                    </div>
                                </div>
                                <div class="text-right">
                                    <div class="text-xs text-muted">Annual + Packages</div>
                                    <strong>@UtilitiesService.ToPeso(option.AnnualSalary)</strong>
                                </div>
                            </div>
                        
                            <div class="row text-center no-gutters border rounded mb-3">
                                <div class="col-6 py-2 border-right"><small class="text-muted d-block">Increase</small><strong class="text-success">@option.IncreasePercentage%</strong></div>
                                <div class="col-6 py-2 border-right"><small class="text-muted d-block">Compa-ratio</small><strong>@option.CompaRatio</strong></div>
                            </div>

                            <label class="font-weight-bold text-gray-700 mb-1">Justification</label>
                            <textarea class="form-control form-control-sm" rows="3" @bind="option.Justification"></textarea>

                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="row">
            <div class="col-xl-6 mb-3">
                <!-- Job Level -->
                <div class="card border shadow-sm w-100 mb-3">
                    <div class="card-header bg-white py-2">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            <i class="fas fa-check-double fa-fw text-primary mr-2"></i>
                            Job Level
                        </h6>
                    </div>
                    <div class="card-body p-3">
                        <div class="list-group list-group-flush">
                            @foreach (var band in salaryBands)
                            {
                                <label class="list-group-item d-flex align-items-center px-0 py-2 mb-0">
                                    <input class="mr-3" type="radio" name="salaryBand"
                                           value="@band.Id"
                                           checked="@(selectedBandId == band.Id)"
                                           @onchange="@(() => OnSalaryBandChange(band.Id))" />
                                    <span class="font-weight-bold text-gray-900">
                                        @band.JobLevelName
                                    </span>
                                </label>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-6 mb-3">
                <!-- Compensation & Benefits -->
                <div class="card border shadow-sm w-100">
                    <div class="card-header bg-white py-2">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            <i class="fas fa-gift fa-fw text-primary mr-2"></i>
                            Compensation & Benefits
                        </h6>
                    </div>
                    <div class="card-body p-3">
                        <div class="form-group row align-items-center mb-3">
                            <div class="col-sm-10 col-md-6 col-lg-4">
                                <select class="form-control form-control-sm"
                                        @bind="selectedPackageId"
                                        @bind:after="OnPackageChange">
                                    @foreach (var package in ddPackages)
                                    {
                                        <option value="@package.Id">@package.Value</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Item</th>
                                        <th>Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in compensationItems)
                                    {
                                        <tr>
                                            <td>@item.ItemName</td>
                                            <td class="font-weight-bold text-gray-900">@SetCompBenItemValue(item)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-footer text-right">
        <a href="@JORoutes.TA.JobOfferTracker"
           class="btn btn-outline-secondary btn-sm mr-2">
            <i class="fas fa-arrow-left fa-fw mr-1"></i>Back to Tracker
        </a>

        <button type="button"
                class="btn btn-outline-info btn-sm mr-2"
                @onclick="ReComputeProposalAnalysis">
            <i class="fas fa-calculator fa-fw mr-1"></i>
            Recompute Analysis
        </button>

        <button type="button"
                class="btn btn-primary btn-sm"
                @onclick="SaveAllProposals">
            <i class="fas fa-paper-plane fa-fw mr-1"></i>
            Submit For Approval
        </button>
    </div>
</div>

@code {
    [Parameter] public int applicationId { get; set; }

    //private VwCandidateApplications application = new();
    private VwSalaryMatrixBand selectedBand = new();
    //private VwCandidates candidate = new();

    private List<VwSalaryMatrixBand> salaryBands = new();
    private List<JobOfferProposal> joProposals = new();
    private List<ValidationStatus> validStatus = new();
    private List<VwCompensationBenefits> compensationItems = new();
    private List<DropdownDto> ddPackages = new();
    private List<VwJobOfferWorkFlow> workFlow = new();

    private int userId = 0;
    private int selectedBandId = 0;
    private int selectedOptionNumber = 0;
    private int selectedPackageId = 0;

    private string analysisNotes = "";

    protected override async Task OnInitializedAsync()
    {
        validStatus = await JOAnalysisService.GetValidationStatus();
        ddPackages = await DropDownListService.GetCompBenPackages();

        //application = await JOAnalysisService.GetCandidateApplication(applicationId);
        workFlow = await JOAnalysisService.GetJobOfferWorkFlow(applicationId);
        //salaryBands = await SalaryMatrixService.GetSalaryBands(application.SalaryMatrixId.Value);
        //candidate = await CandidateService.GetCandidate(application.CandidateId.Value);
        userId = await AccountService.GetJobOfferUserId();

        selectedPackageId = ddPackages.FirstOrDefault()?.Id ?? 0;
        await OnPackageChange();

        var firstBand = salaryBands.FirstOrDefault();
        if (firstBand is not null)
            await OnSalaryBandChange(firstBand.Id);

        if (joProposals.Any())
            OnRecommendChange(joProposals.FirstOrDefault()?.OptionNumber ?? 0);
    }

    private async Task SaveAllProposals()
    {
        List<string> errors = new();
        errors = CollectErrors(errors);

        if (errors.Any())
        { await AlertService.Errors(errors); return; }

        if (!await AlertService.Confirm()) return;

        joProposals = await JOAnalysisService.ReComputeProposalAnalysis(joProposals, compensationItems);

        int analysisId = await JOAnalysisService.SaveProposalsAndAnalysis(joProposals,
            selectedOptionNumber,
            selectedPackageId,
            0,
            analysisNotes);

        Navigation.NavigateTo($"{JORoutes.TA.JOAnalysisDetails}/{analysisId}");
    }

    private List<string> CollectErrors(List<string> errors, bool includeAnalysis = false)
    {
        bool hasError = joProposals
            .Any(jo => !jo.ProposedSalary.HasValue
                || string.IsNullOrWhiteSpace(jo.Justification));

        if (hasError)
            errors.Add("Base salary and justification remarks are required.");

        if (includeAnalysis)
        {
            if (string.IsNullOrWhiteSpace(analysisNotes))
                errors.Add("Analysis notes is required.");
        }

        return errors;
    }

    private async Task OnPackageChange()
    {
        compensationItems = await JOAnalysisService.GetCompensationBenefits(selectedPackageId) ?? new();
    }

    private string SetCompBenItemValue(VwCompensationBenefits item)
    {
        if (item.Amount.HasValue)
            return UtilitiesService.ToCurrency(item.Amount, item.Currency);

        return item.ItemDescription ?? "";
    }

    private async Task OnSalaryBandChange(int bandId)
    {
        selectedBandId = bandId;
        selectedBand = salaryBands.FirstOrDefault(x => x.Id == selectedBandId) ?? new();

        // if (!application.SalaryMatrixId.HasValue || !candidate.CurrentSalary.HasValue)
        // {
        //     joProposals = new();
        //     return;
        // }

        // if (!application.SalaryMatrixId.HasValue)
        // {
        //     joProposals = new();
        //     return;
        // }

        joProposals = await JOAnalysisService.InitializeProposal(
            applicationId,
            0,
            selectedBandId,
            0,
            userId,
            compensationItems);

        if (!joProposals.Any(jo => jo.OptionNumber.GetValueOrDefault() == selectedOptionNumber))
            OnRecommendChange(joProposals.FirstOrDefault()?.OptionNumber ?? 0);
    }

    private void OnRecommendChange(int? optionNumber)
    {
        selectedOptionNumber = optionNumber.GetValueOrDefault();
    }

    private JobOfferProposal? GetSelectedProposal()
    {
        return joProposals.FirstOrDefault(jo => jo.OptionNumber.GetValueOrDefault() == selectedOptionNumber);
    }

    private async Task ReComputeProposalAnalysis()
    {
        List<string> errors = new();
        errors = CollectErrors(errors, false);

        if (errors.Any())
        { await AlertService.Errors(errors); return; }

        joProposals = await JOAnalysisService.ReComputeProposalAnalysis(joProposals, compensationItems);
        await AlertService.Success("Analysis recomputed successfully.");
    }

    private bool HasOptionExceed()
    {
        return joProposals.Where(jo => jo.ValidationStatusId == JOValidationStatus.Exceed).Any();
    }

    private string ValidationStatusName(int? statusId)
    {
        return validStatus.FirstOrDefault(jo => jo.Id == statusId)?.ValidationStatusName ?? "";
    }

    private string RiskLevel()
    {
        int statusId = 0;
        var selectedProposal = GetSelectedProposal();
        if (selectedProposal is not null)
            statusId = selectedProposal.ValidationStatusId.GetValueOrDefault();

        return validStatus.FirstOrDefault(jo => jo.Id == statusId)?.RiskLevelName ?? "";
    }

    private string RiskLevelReason()
    {
        int statusId = 0;
        var selectedProposal = GetSelectedProposal();
        if (selectedProposal is not null)
            statusId = selectedProposal.ValidationStatusId.GetValueOrDefault();

        return validStatus.FirstOrDefault(jo => jo.Id == statusId)?.RiskLevelReason ?? "";
    }

    private bool IsRecommended(int? optionNumber)
    {
        return optionNumber.GetValueOrDefault() == selectedOptionNumber;
    }
}
