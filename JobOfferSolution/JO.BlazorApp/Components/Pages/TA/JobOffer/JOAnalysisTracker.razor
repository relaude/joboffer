@attribute [Authorize(Roles = JOUserRole.TA)]
@attribute [Route(JORoutes.TA.Analysis)]

@inject IJOAnalysisService JOAnalysisService

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header py-3 bg-white">
        <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between">
            <div>
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-table mr-2"></i>
                    Job Offer Analysis Tracker
                </h6>
                <small class="text-muted">JO list grid</small>
            </div>
            <div class="mt-2 mt-lg-0">
                <span class="badge badge-light border mr-1"><i class="fas fa-user-shield fa-fw text-primary mr-1"></i>Talent Aquisition View</span>
            </div>
        </div>
    </div>

    <div class="card-body">

        <!-- Summary Status -->
        <div class="row">
            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-warning shadow-sm h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                    For Analysis
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">0</div>
                                <div class="small text-gray-500">-</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-hourglass-half fa-2x text-warning"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-success shadow-sm h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                    For Approval
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">0</div>
                                <div class="small text-gray-500">-</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-check-circle fa-2x text-success"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-danger shadow-sm h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                                    Negotiations
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">0</div>
                                <div class="small text-gray-500">-</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-exclamation-triangle fa-2x text-danger"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-4">
                <div class="card border-left-info shadow-sm h-100 py-2">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                    Accepted Offer
                                </div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">0</div>
                                <div class="small text-gray-500">-</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-paper-plane fa-2x text-info"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Summary Status -->
        
        <!-- Filters -->
        <div class="border rounded bg-white mb-4">
            <div class="px-3 py-2 border-bottom bg-light d-flex flex-column flex-md-row justify-content-between">
                <div>
                    <h6 class="m-0 font-weight-bold text-gray-800"><i class="fas fa-filter fa-fw text-primary mr-2"></i>Search & Filters</h6>
                </div>
            </div>

            <div class="p-3">
                <div class="row align-items-end">
                    <div class="col-lg-3 col-md-6 mb-3">
                        <label class="font-weight-bold text-gray-700 mb-1">Candidate</label>
                        <input class="form-control form-ctrl-sml" />
                    </div>

                    <div class="col-lg-3 col-md-6 mb-3">
                        <label class="font-weight-bold text-gray-700 mb-1">Request Date</label>
                        <input class="form-control form-ctrl-sml" />
                    </div>

                    <div class="col-lg-3 col-md-6 mb-3">
                        <label class="font-weight-bold text-gray-700 mb-1">Status</label>
                        <select class="form-control form-ctrl-sml">
                            <option>All Statuses</option>
                        </select>
                    </div>

                    <div class="col-lg-3 col-md-12 mb-3">
                        <div class="d-flex flex-column flex-sm-row justify-content-lg-end">
                            <button type="button" class="btn btn-primary btn-sm mb-2 mb-sm-0 mr-sm-2" disabled>
                                <i class="fas fa-search fa-fw mr-1"></i>Search
                            </button>
                            <button type="button" class="btn btn-outline-secondary btn-sm" disabled>
                                <i class="fas fa-eraser fa-fw mr-1"></i>Clear
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Filters -->

        <div class="card">
            <div class="card-header d-flex flex-column flex-md-row justify-content-between">
                <h6 class="m-0 font-weight-bold text-gray-800">
                    <i class="fas fa-table fa-fw text-primary mr-2"></i>Job Offers Analysis
                </h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-sm text-nowrap mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>Reference Number</th>
                                <th>Candidate Name</th>
                                <th>Position</th>
                                <th>Proposed Salary</th>
                                <th>Salary Matrix</th>
                                <th class="text-center">Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var analysis in joAnalysis)
                            {
                                <tr>
                                    <td>@analysis.ReferenceNumber</td>
                                    <td>@analysis.CandidateName</td>
                                    <td>@analysis.PositionAppliedFor</td>
                                    <td>@analysis.BestProposalSalary</td>
                                    <td>@analysis.MatrixName</td>
                                    <td class="text-center">
                                        <span class="badge badge-warning">New</span>
                                    </td>
                                    <td class="text-center">
                                        <a href="@($"{JORoutes.TA.JOAnalysisDetails}/{analysis.Id}")"
                                           class="btn btn-outline-primary btn-sm mr-1"
                                           title="View">
                                            <i class="fas fa-eye fa-fw"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    private List<VwJobOfferAnalysis> joAnalysis = new();

    protected override async Task OnInitializedAsync()
    {
        joAnalysis = await JOAnalysisService.GetJobOfferAnalysis();
    }
}
