@attribute [Authorize(Roles = JOUserRole.TA)]
@attribute [Route(JORoutes.TA.JobOfferTracker)]

@inject ITrackerService TrackerService

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header py-3 bg-white">
        <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between">
            <div>
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-table mr-2"></i>
                    Job Offers
                </h6>
            </div>
        </div>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-sm text-nowrap mb-0">
                <thead class="thead-light">
                    <tr>
                        <th>Reference Number</th>
                        <th>Candidate Name</th>
                        <th>Email</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var jobOffer in jobOffers)
                    {
                        <tr>
                            <td>@jobOffer.RefNum</td>
                            <td>@jobOffer.CandidateName</td>
                            <td>@jobOffer.Email</td>
                            <td class="text-center">
                                <span class="badge badge-@jobOffer.BootstrapClass">@jobOffer.StatusName</span>
                            </td>
                            <td class="text-center">
                                <a href="@($"{JORoutes.Transaction.JobOffer}/{jobOffer.Id}")"
                                   class="btn btn-outline-primary btn-sm mr-1"
                                   title="Details">
                                    <i class="fas fa-eye fa-fw"></i>
                                </a>

                                @if (jobOffer.StatusId == JOStatus.Request.Awaiting)
                                {
                                    <a href="@($"{JORoutes.TA.Upload}/{jobOffer.Id}")"
                                       class="btn btn-outline-info btn-sm mr-1"
                                       title="File upload">
                                        <i class="fas fa-file-upload fa-fw"></i>
                                    </a>
                                }

                                @if (jobOffer.StatusId == JOStatus.Request.Submitted)
                                {
                                    <a href="@($"{JORoutes.TA.Legal}/{jobOffer.Id}")"
                                       class="btn btn-outline-info btn-sm mr-1"
                                       title="Legal Entity">
                                        <i class="fas fa-building fa-fw"></i>
                                    </a>
                                }

                                @if (jobOffer.StatusId == JOStatus.Application.MatrixSelected)
                                {
                                    <a href="@($"{JORoutes.TA.Analysis}/{jobOffer.Id}")"
                                       class="btn btn-outline-info btn-sm mr-1"
                                       title="Analysis">
                                        <i class="fas fa-chart-line fa-fw"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<VwJobOffers> jobOffers = new();

    protected override async Task OnInitializedAsync()
    {
        jobOffers = await TrackerService.GetJobOffers();
    }
}
