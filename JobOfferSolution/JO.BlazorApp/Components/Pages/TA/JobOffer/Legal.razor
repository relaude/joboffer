@attribute [Authorize(Roles = JOUserRole.TA)]
@attribute [Route(JORoutes.TA.Legal + "/{jobOfferId:int}")]

@inject IDropDownListService DropDownListService
@inject ISalaryMatrixService SalaryMatrixService
@inject IJOAnalysisService JOAnalysisService
@inject IAlertService AlertService
@inject IAccountService AccountService
@inject NavigationManager Navigation

<div class="card shadow mb-4 border-left-primary small jo-form-page">
    <div class="card-header py-3 bg-white">
        <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between">
            <div>
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-building fa-fw mr-2"></i>
                    Company and Legal Entity Setup
                </h6>
                <small class="text-muted">@requestInfo.ReferenceNumber</small>
            </div>

            <div class="mt-2 mt-lg-0">
                <span class="badge badge-light border mr-1">
                    <i class="fas fa-user-tie fa-fw text-primary mr-1"></i>
                    TA Partner View
                </span>
            </div>
        </div>
    </div>

    <div class="card-body">

        <div class="alert alert-light border-left-info py-2 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="fas fa-info-circle fa-fw text-info mr-2"></i>
                <span>Select the hiring company and legal entity for this offer so compensation rules, payroll setup, and compliance checks use the correct entity.</span>
            </div>
        </div>

        <div class="row">

            <!-- Division -->
            <div class="col-lg-6 mb-4">
                <div class="card">
                    <div class="card-header bg-white">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-sitemap fa-fw text-primary mr-2"></i>
                            Division Assignment
                        </h6>
                        <small class="text-muted">Company and Division options</small>
                    </div>

                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label class="font-weight-bold text-gray-800">
                                Company <span class="text-danger">*</span>
                            </label>
                            <select class="form-control form-control-sm"
                                    @bind="legal.CompanyId"
                                    @bind:after="OnCompanyChanged">
                                @foreach (var option in ddCompanies)
                                {
                                    <option value="@option.Id">@option.Value</option>
                                }
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label class="font-weight-bold text-gray-800">
                                Division <span class="text-danger">*</span>
                            </label>
                            <select class="form-control form-control-sm"
                                    @bind="legal.DivisionId"
                                    @bind:after="OnDivisionChanged"
                                    disabled="@(ddDivisions.Count == 0)">
                                @foreach (var option in ddDivisions)
                                {
                                    <option value="@option.Id">@option.Value</option>
                                }
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label class="font-weight-bold text-gray-800">
                                Salary Matrix <span class="text-danger">*</span>
                            </label>
                            <select class="form-control form-control-sm"
                                    @bind="legal.MatrixId"
                                    @bind:after="OnMatrixChanged"
                                    disabled="@(ddMatrix.Count == 0)">
                                @foreach (var option in ddMatrix)
                                {
                                    <option value="@option.Id">@option.Value</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Matrix -->
            <div class="col-lg-6 mb-4">
                <div class="card mb-4">
                    <div class="card-header bg-white">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-table fa-fw text-primary mr-2"></i>
                            Salary Matrix Preview
                        </h6>
                        <small class="text-muted">Salary ranges based on SalaryMatrix and SalaryMatrixBand references.</small>
                    </div>

                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm text-nowrap mb-0">
                                <thead class="thead-light text-center">
                                    <tr>
                                        <th>Job Level</th>
                                        <th>Job Family</th>
                                        <th>Position Grade</th>
                                        <th>Minimum</th>
                                        <th>Midpoint</th>
                                        <th>Maximum</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var band in salaryBands)
                                    {
                                        <tr>
                                            <td>@band.JobLevelName</td>
                                            <td>@band.JobFamilyName</td>
                                            <td>@band.PositionGrade</td>
                                            <td class="text-right">@band.BandMinimum</td>
                                            <td class="text-right font-weight-bold text-gray-900">@band.BandMidpoint</td>
                                            <td class="text-right">@band.BandMaximum</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="form-group mb-3">
                            <label class="font-weight-bold text-gray-800">
                                Position Applied For <span class="text-danger">*</span>
                            </label>
                            <select class="form-control form-control-sm"
                                    @bind="legal.JobPositionId"
                                    disabled="@(ddPositions.Count == 0)">
                                @foreach (var option in ddPositions)
                                {
                                    <option value="@option.Id">@option.Value</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div class="card-footer text-right">
        <a href="@JORoutes.TA.JobOfferTracker" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left fa-fw mr-1"></i>Back to Tracker
        </a>

        <button type="button" class="btn btn-primary btn-sm mr-1"
                @onclick="HandleSubmit">
            <i class="fas fa-save fa-fw mr-1"></i>Submit
        </button>
    </div>
</div>

@code {
    [Parameter] public int jobOfferId { get; set; }

    private VwCandidateMSFormRequests requestInfo = new();
    private List<DropdownDto> ddCompanies = new();
    private List<DropdownDto> ddDivisions = new();
    private List<DropdownDto> ddMatrix = new();
    private List<DropdownDto> ddPositions = new();
    private List<VwSalaryMatrixBand> salaryBands = new();
    private LegalEntities legal = new();

    protected override async Task OnInitializedAsync()
    {
        ddCompanies = await DropDownListService.GetCompanies();
        legal.CompanyId = ddCompanies.FirstOrDefault()?.Id ?? 0;

        await OnCompanyChanged();
    }

    private async Task HandleSubmit()
    {
        List<string> errors = new();

        if (legal.MatrixId.GetValueOrDefault() <= 0)
            errors.Add("Salary Matrix is required.");

        if (legal.JobPositionId.GetValueOrDefault() <= 0)
            errors.Add("Job Position is required.");

        if (errors.Any())
        {
            await AlertService.Errors(errors); return;
        }

        if (!await AlertService.Confirm("Are you sure you want to save this Legal Entity Setup?")) return;

        legal.JobOfferId = jobOfferId;
        await JOAnalysisService.LegalEntitySetup(legal);
        Navigation.NavigateTo($"{JORoutes.Transaction.JobOffer}/{jobOfferId}");
    }

    private async Task OnCompanyChanged()
    {
        ddDivisions.Clear();
        ddMatrix.Clear();
        salaryBands.Clear();
        ddPositions.Clear();

        legal.DivisionId = 0;
        legal.MatrixId = 0;
        legal.JobPositionId = 0;

        var companyId = legal.CompanyId.GetValueOrDefault();
        if (companyId > 0)
        {
            ddDivisions = await DropDownListService.GetDivisionsByCompnayId(companyId);
            legal.DivisionId = ddDivisions.FirstOrDefault()?.Id ?? 0;
        }

        await OnDivisionChanged();
    }

    private async Task OnDivisionChanged()
    {
        ddMatrix.Clear();
        salaryBands.Clear();
        ddPositions.Clear();

        legal.MatrixId = 0;
        legal.JobPositionId = 0;

        var divisionId = legal.DivisionId.GetValueOrDefault();
        if (divisionId > 0)
        {
            ddMatrix = await DropDownListService.GetSalaryMatrixByDivisionId(divisionId);
            legal.MatrixId = ddMatrix.FirstOrDefault()?.Id ?? 0;
        }

        await OnMatrixChanged();
    }

    private async Task OnMatrixChanged()
    {
        salaryBands.Clear();
        ddPositions.Clear();
        legal.JobPositionId = 0;

        var matrixId = legal.MatrixId.GetValueOrDefault();
        if (matrixId <= 0)
            return;

        salaryBands = await SalaryMatrixService.GetSalaryBands(matrixId);

        var familyId = salaryBands.FirstOrDefault()?.JobFamilyId.GetValueOrDefault() ?? 0;
        if (familyId <= 0)
            return;

        ddPositions = await DropDownListService.GetJobPositions(familyId);
        legal.JobPositionId = ddPositions.FirstOrDefault()?.Id ?? 0;
    }
}
