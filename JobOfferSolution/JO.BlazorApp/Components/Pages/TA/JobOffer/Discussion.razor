@attribute [Authorize(Roles = JOUserRole.TA)]
@attribute [Route(JORoutes.TA.Discussion + "/{jobOfferId:int}")]

@inject IJODetailsService JODetailsService
@inject IDiscussionService DiscussionService
@inject IJODetailsService JODetailsService
@inject IUtilitiesService UtilitiesService
@inject IAlertService AlertService
@inject IAccountService AccountService

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header py-3 bg-white">
        <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between">
            <div>
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-comments fa-fw mr-2"></i>
                    Job Offer Candidate Discussion
                </h6>
                <small class="text-muted">@jobOffer.RefNum</small>
            </div>

            <div class="mt-2 mt-lg-0">
                <span class="badge badge-light border mr-1">
                    <i class="fas fa-user-tie fa-fw text-primary mr-1"></i>
                    TA Partner View
                </span>
            </div>
        </div>
    </div>

    <div class="card-body">
        <div class="alert alert-light border-left-info py-2 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="fas fa-info-circle fa-fw text-info mr-2"></i>
                <span>Use this discussion view to compare approved offer options, record candidate feedback, and decide the next step.</span>
            </div>
        </div>

        <div class="row">
            <!-- Propoasl -->
            <div class="col-xl-8 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header d-flex flex-column flex-md-row justify-content-between">
                        <div>
                            <h6 class="m-0 font-weight-bold text-gray-800">
                                <i class="fas fa-layer-group fa-fw text-primary mr-2"></i>
                                Approved Offer Options
                            </h6>
                            <small class="text-muted">Only approved options are visible for candidate discussion.</small>
                        </div>
                        <span class="badge badge-success mt-2 mt-md-0 align-self-start align-self-md-center">3 Approved</span>
                    </div>

                    <div class="card-body">
                        <div class="row">
                            @foreach (var option in joProposals)
                            {
                                <div class="col-xl-4 mb-3">
                                    <div class="card shadow-sm h-100 @(option.Recommend.GetValueOrDefault() ? "border-primary" : "border")">
                                        <div class="card-header px-3 py-3 @(option.Recommend.GetValueOrDefault() ? "bg-primary text-white" : "bg-light")">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <div class="d-flex align-items-center font-weight-bold">
                                                        @if (option.Recommend.GetValueOrDefault())
                                                        {
                                                            <i class="fas fa-star mr-1"></i>
                                                        }

                                                        <span>@($"Option {option.OptionNum}")</span>
                                                    </div>

                                                    @if (option.Recommend.GetValueOrDefault())
                                                    {
                                                        <small class="text-white-50">TA Recommended</small>
                                                    }
                                                    else
                                                    {
                                                        <small class="text-muted">Other Offer</small>
                                                    }
                                                </div>

                                                <span class="badge @(option.Recommend.GetValueOrDefault() ? "badge-light" : "badge-success")">
                                                    @BandStatusName(option.StatusId)
                                                </span>
                                            </div>
                                        </div>

                                        <div class="card-body p-3">

                                            <div class="d-flex justify-content-between align-items-end mb-3">
                                                <div>
                                                    <div class="text-xs text-muted text-uppercase">Monthly base</div>
                                                    <div class="h5 font-weight-bold text-gray-900 mb-0">
                                                        @UtilitiesService.ToPeso(option.ProposeSalary)
                                                    </div>
                                                </div>
                                                <div class="text-right">
                                                    <div class="text-xs text-muted">Annual + Packages</div>
                                                    <strong>@UtilitiesService.ToPeso(option.Annual)</strong>
                                                </div>
                                            </div>

                                            <div class="row text-center no-gutters border rounded mb-3">
                                                <div class="col-6 py-2 border-right"><small class="text-muted d-block">Increase</small><strong class="text-success">@option.Increase%</strong></div>
                                                <div class="col-6 py-2 border-right"><small class="text-muted d-block">Compa-ratio</small><strong>@option.CompaRatio</strong></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Candidate -->
            <div class="col-xl-4 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-id-card fa-fw text-info mr-2"></i>
                            Candidate Snapshot
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Candidate</span>
                            <span class="font-weight-bold text-gray-900">@candidate.FName @candidate.LName</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Email</span>
                            <span>@candidate.Email</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Contact</span>
                            <span>@candidate.Contact</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Expected Salary</span>
                            <span class="font-weight-bold text-gray-900">@UtilitiesService.ToPeso(candidate.Expected)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Entry -->
            <div class="col-lg-5 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-clipboard-list fa-fw text-primary mr-2"></i>
                            Discussion Entry
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="form-row">
                            <div class="form-group col-md-6">
                                <label class="font-weight-bold text-gray-700 mb-1">Discussion Date</label>
                                <input type="date" class="form-control form-control-sm" @bind="discussion.DiscussAt" />
                            </div>
                            <div class="form-group col-md-6">
                                <label class="font-weight-bold text-gray-700 mb-1">Channel</label>
                                <select class="form-control form-control-sm"
                                        @bind="discussion.ChannelId">
                                    @foreach (var channel in channels)
                                    {
                                        <option value="@channel.Id">@channel.ChannelName</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="font-weight-bold text-gray-700 mb-1">Step</label>
                            <select class="form-control form-control-sm"
                                    @bind="discussion.StepId">
                                @foreach (var step in steps)
                                {
                                    <option value="@step.Id">@step.StepName</option>
                                }
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="font-weight-bold text-gray-700 mb-1">Candidate Response</label>
                            <select class="form-control form-control-sm"
                                    @bind="discussion.ResponseId">
                                @foreach (var response in responses)
                                {
                                    <option value="@response.Id">@response.ResponseName</option>
                                }
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="font-weight-bold text-gray-700 mb-1">Selected Option</label>
                            <select class="form-control form-control-sm"
                                    @bind="discussion.ProposalId">
                                @foreach (var proposal in joProposals)
                                {
                                    <option value="@proposal.Id">@($"Option {proposal.OptionNum} - {UtilitiesService.ToPeso(proposal.ProposeSalary)}")</option>
                                }
                            </select>
                        </div>
                    
                        <div class="form-group">
                            <label class="font-weight-bold text-gray-700 mb-1">Discussion Notes</label>
                            <textarea class="form-control form-control-sm" rows="4" @bind="discussion.Comments"></textarea>
                        </div>

                        <div class="form-group mb-0">
                            <label class="font-weight-bold text-gray-700 mb-1">Candidate Feedback</label>
                            <textarea class="form-control form-control-sm" rows="3" @bind="discussion.FeedBack"></textarea>
                        </div>
                    </div>
                    <div class="card-footer">
                        <button class="btn btn-sm btn-primary" @onclick="SaveDiscussion">Save</button>
                    </div>
                </div>
            </div>

            <!-- Timeline -->
            <div class="col-lg-7 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-history fa-fw text-info mr-2"></i>
                            Discussion Timeline
                        </h6>
                        <small class="text-muted">Recent contact history and candidate signals.</small>
                    </div>
                    <div class="card-body">
                        @foreach (var item in vwDiscussions)
                        {
                            <div class="d-flex pb-3 mb-3 border-bottom">
                                <div class="btn-circle btn-sm bg-info text-white mr-3">
                                    <i class="@item.Icon"></i>
                                </div>
                                <div class="flex-fill">
                                    <div class="d-flex flex-column flex-md-row justify-content-between">
                                        <div class="font-weight-bold text-gray-900">
                                            <div>@item.StepName</div>
                                            <small class="text-muted">Option @item.OptionNum</small>
                                        </div>
                                        <small class="text-muted">@UtilitiesService.FormatDate(item.DiscussAt, CommonConstant.DefaultShortDateTimeFormat)</small>
                                    </div>
                                    <div class="text-muted">Candidate Response: @item.ResponseName</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-footer text-right">
        <a href="@JORoutes.TA.JobOfferTracker"
           class="btn btn-outline-secondary btn-sm mr-2">
            <i class="fas fa-arrow-left fa-fw mr-1"></i>Back to Tracker
        </a>

        <button type="button" class="btn btn-outline-warning btn-sm mb-2 mb-md-0 mr-md-2" disabled>
            <i class="fas fa-sync-alt fa-fw mr-1"></i>
            Request Re-Proposal
        </button>
        <button type="button" class="btn btn-outline-danger btn-sm mb-2 mb-md-0 mr-md-2" disabled>
            <i class="fas fa-times fa-fw mr-1"></i>
            Mark Declined
        </button>
        <button type="button" class="btn btn-info btn-sm" disabled>
            <i class="fas fa-handshake fa-fw mr-1"></i>
            Proceed to Acceptance
        </button>
    </div>
</div>

@code {
    [Parameter] public int jobOfferId { get; set; }

    private Candidates candidate = new();
    private JobOffers jobOffer = new();
    private Discussions discussion = new()
    {
        DiscussAt = DateTime.Now,
        StepId = 1,
        ChannelId = 1,
        ResponseId = 1
    };

    private List<Proposal> joProposals = new();
    private List<SalaryBandStatus> bandStatus = new();
    private List<ChannelTypes> channels = new();
    private List<DiscussSteps> steps = new();
    private List<CandResponse> responses = new();
    private List<VwDiscussions> vwDiscussions = new();

    protected override async Task OnInitializedAsync()
    {
        jobOffer = await JODetailsService.GetJobOffer(jobOfferId);
        candidate = await JODetailsService.GetCandidate(jobOffer.CandidateId.GetValueOrDefault());
        joProposals = await DiscussionService.GetApprovedProposal(jobOfferId);
        bandStatus = await JODetailsService.GetSalaryBandStatus();
        channels = await DiscussionService.GetChannelTypes();
        steps = await DiscussionService.GetDiscussSteps();
        responses = await DiscussionService.GetCandResponse();

        discussion.JobOfferId = jobOfferId;
        discussion.ProposalId = joProposals.FirstOrDefault().Id;
        discussion.CreatedBy = await AccountService.GetJobOfferUserId();

        await GetDiscussions();
    }

    private async Task SaveDiscussion()
    {
        if (!await AlertService.Confirm()) return;

        await DiscussionService.SaveDiscussion(discussion);
        ResetEntries();
        await GetDiscussions();
    }

    private async Task GetDiscussions()
    {
        vwDiscussions = await DiscussionService.GetDiscussions(jobOfferId);
    }

    private void ResetEntries()
    {
        discussion.ProposalId = joProposals.FirstOrDefault().Id;
        discussion.DiscussAt = DateTime.Now;
        discussion.StepId = 1;
        discussion.ChannelId = 1;
        discussion.ResponseId = 1;
        discussion.Comments = "";
        discussion.FeedBack = "";
    }

    private string BandStatusName(int? statusId)
    {
        return bandStatus.FirstOrDefault(jo => jo.Id == statusId)?.StatusName ?? "";
    }
}
