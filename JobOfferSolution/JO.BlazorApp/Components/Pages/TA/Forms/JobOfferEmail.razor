@inject IJobOfferService JobOfferService
@inject IAlertService AlertService
@inject NavigationManager Navigation

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-file-contract mr-2"></i> @jobOffer.JobOfferNumber
        </h6>

        <span class="badge badge-pill badge-info px-3 py-2 shadow-sm">
            @jobOffer.StatusName
        </span>
    </div>

    <div class="card-body">

        <!-- POSITION DETAILS -->
        <div class="mb-4">
            <h6 class="font-weight-bold text-primary border-bottom pb-2 mb-3">
                Position Details
            </h6>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="text-xs text-uppercase text-muted mb-1">
                        Position Title
                    </label>
                    <div class="form-control form-control-sm bg-light">
                        @jobOffer.PositionName
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="text-xs text-uppercase text-muted mb-1">
                        Department
                    </label>
                    <div class="form-control form-control-sm bg-light">
                        @jobOffer.DepartmentName
                    </div>
                </div>
            </div>
        </div>

        <!-- COMPENSATION -->
        <div class="mb-4">
            <h6 class="font-weight-bold text-success border-bottom pb-2 mb-3">
                Compensation
            </h6>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="text-xs text-uppercase text-muted mb-1">
                        Basic Salary
                    </label>
                    <div class="form-control form-control-sm bg-light">
                        @jobOffer.BasicSalary?.ToString("C")
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="text-xs text-uppercase text-muted mb-1">
                        Allowance
                    </label>
                    <div class="form-control form-control-sm bg-light">
                        @jobOffer.Allowance?.ToString("C")
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="text-xs text-uppercase text-muted mb-1">
                        Signing Bonus
                    </label>
                    <div class="form-control form-control-sm bg-light">
                        @jobOffer.SigningBonus?.ToString("C")
                    </div>
                </div>
            </div>
        </div>

        <!-- OFFER TIMELINE -->
        <div class="mb-4">
            <h6 class="font-weight-bold text-warning border-bottom pb-2 mb-3">
                Offer Timeline
            </h6>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="text-xs text-uppercase text-muted mb-1">
                        Offer Date
                    </label>
                    <div class="form-control form-control-sm bg-light">
                        @jobOffer.OfferDate?.ToString("MMMM dd, yyyy")
                    </div>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="text-xs text-uppercase text-muted mb-1">
                        Proposed Start Date
                    </label>
                    <div class="form-control form-control-sm bg-light">
                        @jobOffer.ProposedStartDate?.ToString("MMMM dd, yyyy")
                    </div>
                </div>
            </div>
        </div>

        <!-- ADDITIONAL INFORMATION -->
        <div class="mb-4">
            <h6 class="font-weight-bold text-info border-bottom pb-2 mb-3">
                Additional Information
            </h6>

            <div class="form-control form-control-sm bg-light" style="min-height:80px;">
                @jobOffer.Remarks
            </div>
        </div>

        <!-- EMAIL MESSAGE -->
        <div class="mb-4">
            <h6 class="font-weight-bold text-dark border-bottom pb-2 mb-3">
                Email Message
            </h6>

            <div class="form-group">
                <label class="text-xs text-uppercase text-muted">
                    Email Body
                </label>
                <InputTextArea @bind-Value="emailMessage" 
                    class="form-control form-control-sm"
                    rows="5"
                    placeholder="Enter your email message here...">
                </InputTextArea>
            </div>
        </div>

        <!-- SUBMIT BUTTON -->
        <div class="text-right">
            <button class="btn btn-outline-secondary btn-sm mr-2"
                    @onclick="HandleCancel">
                Cancel
            </button>
            <button class="btn btn-primary btn-sm px-4"
                    @onclick="() => HandleSubmitEmail()">
                Submit Email
            </button>
        </div>

    </div>
</div>

@code {
    [Parameter] public int JobOfferId { get; set; }

    private string emailMessage = "For your acceptance. Please see attached file.";

    private VwJobOffers jobOffer = new();

    protected override async Task OnParametersSetAsync()
    {
        jobOffer = await JobOfferService.GetJobOffer(JobOfferId);
    }

    private void HandleCancel()
    {
        Navigation.NavigateTo(JORoutes.TA.Email);
    }

    private async Task HandleSubmitEmail()
    {
        if (!await AlertService.Confirm())
            return;

        await JobOfferService.SetJobOfferStatus(JobOfferId, JOMainStatus.Emailed);

        Navigation.NavigateTo($"{JORoutes.Transaction.JobOffer}/{JobOfferId}/{jobOffer.Candidate_Id}");
    }
}
