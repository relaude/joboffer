@inject IJobOfferService JobOfferService
@inject IAlertService AlertService
@inject IUtilitiesService UtilitiesService
@inject IEmailService EmailService
@inject ICandidateService CandidateService
@inject NavigationManager Navigation

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-file-contract mr-2"></i> @jobOffer.JobOfferNumber
        </h6>
    </div>

    <div class="card-body">

        <div class="row">
            <div class="col-md-4 border-right pr-4">
                <div class="mb-4">
                    <h6 class="font-weight-bold text-primary border-bottom pb-2 mb-3">Position Details</h6>

                    <div class="mb-3">
                        <label class="text-xs text-uppercase text-muted mb-1">Position Title</label>
                        <div class="form-control form-control-sm bg-light">
                            @jobOffer.PositionName
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="text-xs text-uppercase text-muted mb-1">Department</label>
                        <div class="form-control form-control-sm bg-light">
                            @jobOffer.DepartmentName
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <h6 class="font-weight-bold text-warning border-bottom pb-2 mb-3">Offer Timeline</h6>

                    <div class="mb-3">
                        <label class="text-xs text-uppercase text-muted mb-1">Offer Date</label>
                        <div class="form-control form-control-sm bg-light">
                            @jobOffer.OfferDate?.ToString("MMMM dd, yyyy")
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="text-xs text-uppercase text-muted mb-1">Proposed Start Date</label>
                        <div class="form-control form-control-sm bg-light">
                            @jobOffer.ProposedStartDate?.ToString("MMMM dd, yyyy")
                        </div>
                    </div>
                </div>

            </div>

            <div class="col-md-8 pl-4">
                <div class="mb-4">
                    <h6 class="font-weight-bold text-success border-bottom pb-2 mb-3">Compensation</h6>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="text-xs text-uppercase text-muted mb-1">Basic Salary</label>
                            <div class="form-control form-control-sm bg-light">
                                @UtilitiesService.ToPeso(jobOffer.BasicSalary)
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="text-xs text-uppercase text-muted mb-1">Allowance</label>
                            <div class="form-control form-control-sm bg-light">
                                @UtilitiesService.ToPeso(jobOffer.Allowance)
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="text-xs text-uppercase text-muted mb-1">Signing Bonus</label>
                            <div class="form-control form-control-sm bg-light">
                                @UtilitiesService.ToPeso(jobOffer.SigningBonus)
                            </div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(jobOffer.Remarks))
                {
                    <div class="mb-4">
                        <h6 class="font-weight-bold text-info border-bottom pb-2 mb-3">Additional Information</h6>

                        <div class="form-control form-control-sm bg-light" style="min-height:80px;">
                            @jobOffer.Remarks
                        </div>
                    </div>
                }

                <div class="mb-4">
                    <h6 class="font-weight-bold text-dark border-bottom pb-2 mb-3">Email</h6>

                    <div class="form-group">
                        <div class="mb-3">
                            <label class="text-xs text-uppercase text-muted">Subject</label>

                            <InputText @bind-Value="emailRequest.Subject"
                                class="form-control form-control-sm"
                                placeholder="Enter email subject..." />
                        </div>

                        <div class="mb-3">
                            <label class="text-xs text-uppercase text-muted">Message</label>

                            <BlazoredTextEditor @ref="@QuillHtml">
                                <ToolbarContent>
                                    <select class="ql-header">
                                        <option selected=""></option>
                                        <option value="1"></option>
                                        <option value="2"></option>
                                        <option value="3"></option>
                                        <option value="4"></option>
                                        <option value="5"></option>
                                    </select>

                                    <span class="ql-formats">
                                        <button class="ql-bold"></button>
                                        <button class="ql-italic"></button>
                                        <button class="ql-underline"></button>
                                        <button class="ql-strike"></button>
                                    </span>

                                    <span class="ql-formats">
                                        <select class="ql-color"></select>
                                        <select class="ql-background"></select>
                                    </span>

                                    <span class="ql-formats">
                                        <button class="ql-list" value="ordered"></button>
                                        <button class="ql-list" value="bullet"></button>
                                    </span>

                                    <span class="ql-formats">
                                        <button class="ql-link"></button>
                                    </span>
                                </ToolbarContent>

                                <EditorContent></EditorContent>
                            </BlazoredTextEditor>
                        </div>
                        
                        <div class="mb-4">
                            <label class="text-xs text-uppercase text-muted">
                                Attachments
                            </label>

                            <div class="list-group">
                                @foreach (var file in listOfFiles)
                                {
                                    <div class="list-group-item py-2">
                                        <div class="d-flex align-items-center justify-content-between">

                                            <div class="d-flex align-items-center">
                                                <i class="fas fa-file-alt text-gray-400 mr-2"></i>
                                                <div>
                                                    <div class="font-weight-medium">@file.Name</div>
                                                    <small class="text-muted">@file.SizeInKb KB</small>
                                                </div>
                                            </div>

                                            <button type="button"
                                                    class="btn btn-danger btn-circle btn-sm"
                                                    title="Remove file"
                                                    @onclick="() => RemoveFile(file)">
                                                <i class="fas fa-trash"></i>
                                            </button>

                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="card-footer text-right">
        <button class="btn btn-outline-secondary btn-sm mr-1"
                @onclick="HandleCancel">
            Cancel
        </button>
        <button class="btn btn-primary btn-sm mr-1"
                @onclick="()=> TestEmail()">
            Test Email
        </button>

        <button class="btn btn-primary btn-sm mr-1"
                @onclick="() => AttachFile()">
            <i class="fas fa-paperclip"></i> Attach
        </button>
        <button class="btn btn-primary btn-sm"
                @onclick="() => HandleSubmitEmail()">
            <i class="fa-solid fa-paper-plane"></i> Submit Email
        </button>
    </div>
</div>

<Modal @ref="modalInputEmail" ModalSize="modal-sm" Title="@jobOffer.JobOfferNumber">
    <ChildContent>
        <input type="email" class="form-control" placeholder="Email" @bind="emailRequest.To" />
    </ChildContent>
    <FooterTemplate>
        <button class="btn btn-primary btn-sm"
            @onclick="()=> Continue()">
            Continue
        </button>
    </FooterTemplate>
</Modal>

<Modal @ref="modalAttach" ModalSize="modal-sm" Title="File">
    <ChildContent>
        <InputFile OnChange="OnFileSelected" class="form-control-file" />
    </ChildContent>
    <FooterTemplate>
        <button class="btn btn-primary btn-sm"@onclick="AddFile">Add</button>
    </FooterTemplate>
</Modal>

@code {
    [Parameter] public int JobOfferId { get; set; }

    private VwJobOffers jobOffer = new();
    BlazoredTextEditor QuillHtml;
    private string QuillHTMLContent;
    private Modal modalInputEmail = default!;
    private Modal modalAttach = default!;
    private string testEmail = "";
    private EmailRequest emailRequest = new();
    private FileStreamDto? selectedFile;
    private List<FileStreamDto> listOfFiles = new();

    protected override async Task OnParametersSetAsync()
    {
        jobOffer = await JobOfferService.GetJobOffer(JobOfferId);
    }

    private void HandleCancel()
    {
        Navigation.NavigateTo(JORoutes.TA.Email);
    }

    private async Task TestEmail()
    {
        modalInputEmail.Show();
    }

    private async Task HandleSubmitEmail()
    {
        emailRequest.To = await CandidateService.GetCandidateEmail(jobOffer.Candidate_Id.Value);
        emailRequest.FileStreams = listOfFiles;

        var errors = await CollectErrors(new List<string>());

        if (errors.Any())
        {
            await AlertService.Errors(errors);
            return;
        }

        if (!await AlertService.Confirm())
            return;

        try
        {
            await EmailService.SendAsync(emailRequest);
            await JobOfferService.SetJobOfferStatus(JobOfferId, JOMainStatus.Emailed);
            Navigation.NavigateTo($"{JORoutes.Transaction.JobOffer}/{JobOfferId}/{jobOffer.Candidate_Id}");
        }
        catch (Exception ex)
        {
            await AlertService.Error(ex.Message);
        }
    }

    private async Task Continue()
    {
        var errors = await CollectErrors(new List<string>());

        if (errors.Any())
        {
            await AlertService.Errors(errors);
            return;
        }

        emailRequest.FileStreams = listOfFiles;
        await EmailService.SendAsync(emailRequest);
        modalInputEmail.Close();
    }

    private async Task AttachFile()
    {
        modalAttach.Show();
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;

        using var stream = file.OpenReadStream(10 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        selectedFile = new FileStreamDto
        {
            Name = file.Name,
            SizeInKb = (file.Size / 1024).ToString("F2"),
            Content = ms.ToArray()
        };
    }

    private void AddFile()
    {
        listOfFiles.Add(selectedFile);
        modalAttach.Close();
    }

    private void RemoveFile(FileStreamDto file)
    {
        if (listOfFiles.Contains(file))
        {
            listOfFiles.Remove(file);
        }
    }

    private async Task<List<string>> CollectErrors(List<string> errors)
    {
        bool isValidEmail = UtilitiesService.IsValidEmail(emailRequest.To);
        emailRequest.Body = await QuillHtml.GetHTML();

        if (!isValidEmail)
            errors.Add("Please enter a valid email address.");

        if (string.IsNullOrEmpty(emailRequest.Subject))
            errors.Add("Email Subject is required.");

        if (string.IsNullOrEmpty(emailRequest.Body) || emailRequest.Body == "<p><br></p>")
            errors.Add("Email Message is required.");

        return errors;
    }
}
