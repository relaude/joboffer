@attribute [Authorize(Roles = JOUserRole.DH)]
@attribute [Route(JORoutes.DH.Approve + "/{analysisId:int}")]

@inject IJOAnalysisService JOAnalysisService

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header bg-white py-3">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between">
            <div>
                <div class="d-flex align-items-center mb-1">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-file-signature fa-fw mr-2"></i>Job Offer Approval
                    </h6>
                    <span class="badge badge-warning ml-2">3 options awaiting review</span>
                </div>
                <div class="text-muted">@joAnalysis.ReferenceNumber &middot; @joAnalysis.CandidateName &middot; @joAnalysis.PositionAppliedFor</div>
            </div>
            <div class="d-flex align-items-center mt-3 mt-lg-0">
                <span class="badge badge-light border mr-2"><i class="fas fa-user-shield text-primary mr-1"></i>Division Head</span>
            </div>
        </div>
    </div>
    
    <div class="card-body p-3 p-lg-4">
        <div class="row mb-4">
            <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
                <div class="card border-left-primary shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="text-xs font-weight-bold text-primary text-uppercase">Candidate</div>
                        <div class="font-weight-bold text-gray-900 mt-1">@joAnalysis.CandidateName</div>
                        <div class="text-muted">@joAnalysis.CandidateEmail</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
                <div class="card border-left-info shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="text-xs font-weight-bold text-info text-uppercase">Salary Context</div>
                        <div class="d-flex justify-content-between mt-1"><span class="text-muted">Current</span><strong>@joAnalysis.CurrentSalary</strong></div>
                        <div class="d-flex justify-content-between"><span class="text-muted">Expected</span><strong>@joAnalysis.ExpectedSalary</strong></div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3 mb-md-0">
                <div class="card border-left-success shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="text-xs font-weight-bold text-success text-uppercase">Salary Band</div>
                        <div class="font-weight-bold text-gray-900 mt-1">PHP 38,000 - 52,000</div>
                        <div class="text-muted">Midpoint: PHP 45,000</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card border-left-warning shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="text-xs font-weight-bold text-warning text-uppercase">Approval Progress</div>
                        <div class="font-weight-bold text-gray-900 mt-1">HROD review</div>
                        <div class="text-muted">Next: Division Head</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int analysisId { get; set; }
    private VwJobOfferAnalysis joAnalysis = new();

    protected override async Task OnInitializedAsync()
    {
        joAnalysis = await JOAnalysisService.GetJobOfferAnalysis(analysisId);
    }
}
