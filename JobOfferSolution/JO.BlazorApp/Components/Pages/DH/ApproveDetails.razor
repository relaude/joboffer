@attribute [Authorize(Roles = JOUserRole.DH)]
@attribute [Route(JORoutes.DH.ApproveDetails + "/{analysisId:int}")]

@inject IJOAnalysisService JOAnalysisService
@inject IUtilitiesService UtilitiesService
@inject IAlertService AlertService
@inject IApprovalService ApprovalService
@inject IAccountService AccountService

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header bg-white py-3">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between">
            <div>
                <div class="d-flex align-items-center mb-1">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-file-signature fa-fw mr-2"></i>Job Offer Approval
                    </h6>
                    <span class="badge badge-warning ml-2">3 options awaiting review</span>
                </div>
                <div class="text-muted">@joAnalysis.ReferenceNumber &middot; @joAnalysis.CandidateName &middot; @joAnalysis.PositionAppliedFor</div>
            </div>
            <div class="d-flex align-items-center mt-3 mt-lg-0">
                <span class="badge badge-light border mr-2">
                    <i class="fas fa-user-shield text-primary mr-1"></i>
                    Division Head
                </span>
            </div>
        </div>
    </div>

    <div class="card-body p-3 p-lg-4">
        <!-- KPI -->
        <div class="row mb-4">
            <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
                <div class="card border-left-primary shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="text-xs font-weight-bold text-primary text-uppercase">Candidate</div>
                        <div class="font-weight-bold text-gray-900 mt-1">@joAnalysis.CandidateName</div>
                        <div class="text-muted">@joAnalysis.CandidateEmail</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
                <div class="card border-left-info shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="text-xs font-weight-bold text-info text-uppercase">Salary Context</div>
                        <div class="d-flex justify-content-between mt-1">
                            <span class="text-muted">Current</span>
                            <strong>@UtilitiesService.ToCurrency(joAnalysis.CurrentSalary, joAnalysis.Currency)</strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Expected</span>
                            <strong>@UtilitiesService.ToCurrency(joAnalysis.ExpectedSalary, joAnalysis.Currency)</strong>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3 mb-md-0">
                <div class="card border-left-success shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="text-xs font-weight-bold text-success text-uppercase">Salary Band</div>
                        <div class="font-weight-bold text-gray-900 mt-1">
                            @($"{UtilitiesService.ToCurrency(joAnalysis.BandMinimum, joAnalysis.Currency)} - {UtilitiesService.ToCurrency(joAnalysis.BandMaximum, joAnalysis.Currency)}")
                        </div>
                        <div class="text-muted">Midpoint: @UtilitiesService.ToCurrency(joAnalysis.BandMidpoint, joAnalysis.Currency)</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card border-left-warning shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="text-xs font-weight-bold text-warning text-uppercase">Salary Matrix</div>
                        <div class="font-weight-bold text-gray-900 mt-1">@joAnalysis.MatrixCode</div>
                        <div class="text-muted">@joAnalysis.JobLevelName</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="alert alert-light border d-flex flex-column flex-md-row align-items-md-center justify-content-between py-2 mb-3">
            <div><i class="fas fa-circle-info text-info mr-2"></i>Decide on each option independently. Comments are required only for <strong>Return</strong> or <strong>Reject</strong>.</div>
            <span class="text-muted text-nowrap mt-2 mt-md-0">
                <i class="fas fa-clock mr-1"></i>
                Submitted @UtilitiesService.FormatDate(joAnalysis.CreatedAt)
            </span>
        </div>

        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-2">
            <div>
                <h6 class="font-weight-bold text-gray-900 mb-0">Proposal options</h6>
                <span class="text-muted">Review the key differences and record one decision per card.</span>
            </div>
        </div>

        <!-- Proposals -->
        <div class="row">
            @foreach (var option in joProposals)
            {
                <div class="col-xl-4 mb-3">
                    <div class="card shadow-sm h-100 @(IsRecommended(option.Id) ? "border-primary" : "border")">
                        <div class="card-header px-3 py-3 @(IsRecommended(option.Id) ? "bg-primary text-white" : "bg-light")">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="font-weight-bold">
                                        @if (IsRecommended(option.Id))
                                        {
                                            <i class="fas fa-star mr-1"></i>
                                        }
                                        @($"Option {option.OptionNumber}")
                                    </div>
                                    @if (IsRecommended(option.Id))
                                    {
                                        <small class="text-white-50">TA Recommended</small>
                                    }
                                    else
                                    {

                                        <small class="text-muted">Other Offer</small>
                                    }
                                </div>
                                <span class="badge @(IsRecommended(option.Id) ? "badge-light" : "badge-success")">@option.ValidationStatusName</span>
                            </div>
                        </div>

                        <div class="card-body p-3">

                            <div class="d-flex justify-content-between align-items-end mb-3">
                                <div>
                                    <div class="text-xs text-muted text-uppercase">Monthly base</div>
                                    <div class="h5 font-weight-bold text-gray-900 mb-0">
                                        @UtilitiesService.ToCurrency(option.ProposedSalary, joAnalysis.Currency)
                                    </div>
                                </div>
                                <div class="text-right">
                                    <div class="text-xs text-muted">Annual + Packages</div>
                                    <strong>@UtilitiesService.ToCurrency(option.AnnualSalary, joAnalysis.Currency)</strong>
                                </div>
                            </div>

                            <div class="row text-center no-gutters border rounded mb-3">
                                <div class="col-6 py-2 border-right"><small class="text-muted d-block">Increase</small><strong class="text-success">@option.IncreasePercentage</strong></div>
                                <div class="col-6 py-2 border-right"><small class="text-muted d-block">Compa-ratio</small><strong>@option.CompaRatio</strong></div>
                            </div>

                            <div class="mb-3">
                                <div class="text-xs font-weight-bold text-uppercase text-gray-500 mb-1">TA justification</div>
                                <div class="text-gray-800">@option.Justification</div>
                            </div>

                            <div class="text-xs font-weight-bold text-uppercase text-gray-500 mb-2">Your decision</div>
                            <div class="btn-group btn-group-sm d-flex mb-3" role="group" aria-label="Decision for Option @option.OptionNumber">
                                <button type="button"
                                        class="@SetClassButton("Approve", option.DHProposalStatusId.GetValueOrDefault())"
                                        disabled>
                                    <i class="fas fa-check mr-1"></i>Approve
                                </button>

                                <button type="button"
                                        class="@SetClassButton("Return", option.DHProposalStatusId.GetValueOrDefault())"
                                        disabled>
                                    <i class="fas fa-rotate-left mr-1"></i>Return
                                </button>

                                <button type="button"
                                        class="@SetClassButton("Reject", option.DHProposalStatusId.GetValueOrDefault())"
                                        disabled>
                                    <i class="fas fa-times mr-1"></i>Reject
                                </button>
                            </div>

                            <label class="font-weight-bold text-gray-700 mb-1">Comments</label>
                            <textarea class="form-control form-control-sm" rows="3" readonly>@option.DHComments</textarea>

                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Summary -->
        <div class="border rounded bg-light p-3 mt-1">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <div class="font-weight-bold text-gray-900"><i class="fas fa-clipboard-check text-primary mr-2"></i>Decision summary</div>
                    <div class="mt-2">
                        <span class="badge badge-success mr-2">
                            <i class="fas fa-check mr-1"></i>
                            @joProposals.Count(jo => jo.DHProposalStatusId == JOStatus.Proposal.Approve) approved
                        </span>

                        <span class="badge badge-warning mr-2">
                            <i class="fas fa-rotate-left mr-1"></i>
                            @joProposals.Count(jo => jo.DHProposalStatusId == JOStatus.Proposal.Return) returned
                        </span>

                        <span class="badge badge-danger">
                            <i class="fas fa-times mr-1"></i>
                            @joProposals.Count(jo => jo.DHProposalStatusId == JOStatus.Proposal.Reject) rejected
                        </span>
                    </div>
                    <small class="text-muted d-block mt-2">All three options have a decision and required comments are complete.</small>
                </div>
                <div class="col-lg-4 text-lg-right mt-3 mt-lg-0">
                    <a href="@JORoutes.DH.Approvals"
                       class="btn btn-outline-secondary btn-sm mr-2">
                        <i class="fas fa-arrow-left fa-fw mr-1"></i>Back to Tracker
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    [Parameter] public int analysisId { get; set; }
    private VwJobOfferAnalysis joAnalysis = new();
    private List<VwJobOfferProposal> joProposals = new();
    private VwJobOfferProposal joProposal = new();
    private SalaryMatrixBand matrixBand = new();

    protected override async Task OnInitializedAsync()
    {
        joAnalysis = await JOAnalysisService.GetJobOfferAnalysis(analysisId);
        joProposals = await JOAnalysisService.GetJobOfferProposal(analysisId);
        joProposal = joProposals.FirstOrDefault(jo => jo.Id == joAnalysis.RecommendProposalId.GetValueOrDefault());
    }

    private bool IsRecommended(int id)
    {
        return joAnalysis.RecommendProposalId == id;
    }

    private string SetClassButton(string statusName, int statusId)
    {
        var status = statusName switch
        {
            "Approve" => (JOStatus.Proposal.Approve, "success"),
            "Return" => (JOStatus.Proposal.Return, "warning"),
            "Reject" => (JOStatus.Proposal.Reject, "danger"),
            _ => ((int?)null, "info")
        };

        return status.Item1 == statusId
            ? $"btn flex-fill btn-{status.Item2}"
            : $"btn flex-fill btn-outline-{status.Item2}";
    }
}
