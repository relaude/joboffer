@attribute [Authorize(Roles = JOUserRole.Admin)]
@attribute [Route(JORoutes.Admin.SalaryMatrix)]

@inject ISalaryMatrixService SalaryMatrixService

<div class="card shadow border-left-primary mb-4 small">
    <div class="card-header py-3">
        <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between">
            <h6 class="m-0 font-weight-bold text-primary d-flex align-items-center">
                <i class="fa-solid fa-table-cells fa-fw text-primary mr-2"></i>
                Salary Matrix
            </h6>

            <a href="@JORoutes.Admin.SalaryMatrixNew" class="btn btn-sm btn-primary mt-2 mt-md-0">
                <i class="fa-solid fa-plus fa-fw mr-1"></i>
                New Matrix
            </a>
        </div>
    </div>

    <div class="card-body">
        <div class="row">
            <div class="col-md-4 mb-3">
                <div class="card border-left-primary h-100 py-2">
                    <div class="card-body py-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Matrices</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@salaryMatrices.Count</div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card border-left-success h-100 py-2">
                    <div class="card-body py-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Active</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@salaryMatrices.Count(x => x.IsActive == true)</div>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card border-left-warning h-100 py-2">
                    <div class="card-body py-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Pending Approval</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@salaryMatrices.Count(x => x.ApprovalStatusId == 1)</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mb-3">
            <h6 class="font-weight-bold text-gray-800 mb-1">Matrix List</h6>
            <p class="text-muted mb-0">Manage salary structures, currencies, and effective periods.</p>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover table-sm text-nowrap mb-0">
                <thead class="thead-light text-center">
                    <tr>
                        <th>Matrix Name</th>
                        <th>Code</th>
                        <th>Currency</th>
                        <th>Effective From</th>
                        <th>Effective To</th>
                        <th>Approval Status</th>
                        <th>Active</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-3">
                                <i class="fas fa-spinner fa-spin fa-fw mr-1"></i>
                                Loading salary matrices...
                            </td>
                        </tr>
                    }
                    else if (salaryMatrices.Any())
                    {
                        @foreach (var item in salaryMatrices)
                        {
                            <tr @key="item.Id">
                                <td class="font-weight-bold text-gray-800">@DisplayText(item.MatrixName)</td>
                                <td>@DisplayText(item.MatrixCode)</td>
                                <td class="text-center">@DisplayText(item.Currency)</td>
                                <td class="text-center">@FormatDate(item.EffectiveFrom)</td>
                                <td class="text-center">@FormatDate(item.EffectiveTo)</td>
                                <td class="text-center">
                                    <span class="badge @GetApprovalBadgeClass(item.ApprovalStatusId)">
                                        @DisplayText(item.StatusName)
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(item.IsActive == true ? "badge-success" : "badge-secondary")">
                                        @(item.IsActive == true ? "Yes" : "No")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <a href="@($"{JORoutes.Admin.SalaryMatrix}/{item.Id}")"
                                       class="text-primary"
                                       style="text-decoration: none;">
                                        <i class="fa-solid fa-eye fa-fw mr-1"></i>
                                        View
                                    </a>
                                    <span class="text-muted mx-1">|</span>
                                    <a href="@($"{JORoutes.Admin.SalaryMatrix}?edit={item.Id}")"
                                       class="text-primary"
                                       style="text-decoration: none;">
                                        <i class="fa-solid fa-pen-to-square fa-fw mr-1"></i>
                                        Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-3">
                                <i class="fas fa-info-circle fa-fw mr-1"></i>
                                No salary matrices found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<VwSalaryMatrix> salaryMatrices = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        salaryMatrices = await SalaryMatrixService.GetMatrixList();
        isLoading = false;
    }

    private static string FormatDate(DateTime? date) => date?.ToString("dd MMM yyyy") ?? "-";

    private static string DisplayText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string GetApprovalBadgeClass(int? approvalStatusId) => approvalStatusId switch
    {
        1 => "badge-warning",
        2 => "badge-success",
        3 => "badge-secondary",
        _ => "badge-light"
    };
}
