@attribute [Authorize(Roles = JOUserRole.Admin)]
@attribute [Route(JORoutes.Admin.SalaryMatrix + "/{matrixId:int}")]

@inject ISalaryMatrixService SalaryMatrixService

<div class="card shadow border-left-primary mb-4 small">
    <div class="card-header py-3">
        <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between">
            <h6 class="m-0 font-weight-bold text-primary d-flex align-items-center">
                <i class="fas fa-table fa-fw text-primary mr-2"></i>
                Salary Matrix Details
            </h6>

            <a href="@JORoutes.Admin.SalaryMatrix"
               class="btn btn-sm btn-outline-secondary mt-2 mt-md-0">
                <i class="fas fa-arrow-left fa-fw mr-1"></i>
                Back to List
            </a>
        </div>
    </div>

    <div class="card-body">
        <div class="alert alert-light border-left-info mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="fas fa-info-circle fa-fw text-info mr-2"></i>
                <span>Review the matrix details and salary bands configured for this pay structure.</span>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-gray-800">
                    <i class="fas fa-file-alt fa-fw text-primary mr-2"></i>
                    Matrix Details
                </h6>
            </div>

            <div class="card-body">
                <div class="row">
                    <div class="col-lg-6">
                        <div class="pr-lg-3">
                            <div class="row mb-3">
                                <div class="col-sm-5 text-muted">Matrix Name</div>
                                <div class="col-sm-7 font-weight-bold text-gray-900">@DisplayText(matrix.MatrixName)</div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-5 text-muted">Matrix Code</div>
                                <div class="col-sm-7 font-weight-bold text-gray-900">@DisplayText(matrix.MatrixCode)</div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-5 text-muted">Company</div>
                                <div class="col-sm-7">@DisplayText(matrix.CompanyName)</div>
                            </div>

                            <div class="row mb-3 mb-lg-0">
                                <div class="col-sm-5 text-muted">Division</div>
                                <div class="col-sm-7">@DisplayText(matrix.DivisionName)</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6 mt-3 mt-lg-0">
                        <div class="pl-lg-3">
                            <div class="row mb-3">
                                <div class="col-sm-5 text-muted">Currency</div>
                                <div class="col-sm-7">@DisplayText(matrix.CurrencyName)</div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-5 text-muted">Status</div>
                                <div class="col-sm-7">
                                    <span class="badge badge-light border">@DisplayText(matrix.StatusName)</span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-5 text-muted">Effective From</div>
                                <div class="col-sm-7">@DisplayDate(matrix.EffectiveFrom)</div>
                            </div>

                            <div class="row mb-3 mb-lg-0">
                                <div class="col-sm-5 text-muted">Effective To</div>
                                <div class="col-sm-7">@DisplayDate(matrix.EffectiveTo)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="row">
                    <div class="col-lg-4 mt-3 mt-lg-0">
                        <div class="text-muted mb-1">Created By</div>
                        <div class="font-weight-bold text-gray-900">@DisplayText(matrix.CreatedByName)</div>
                    </div>

                    <div class="col-lg-4 mt-3 mt-lg-0">
                        <div class="text-muted mb-1">Modified By</div>
                        <div class="font-weight-bold text-gray-900">@DisplayText(matrix.ModifiedByName)</div>
                    </div>

                    <div class="col-lg-4">
                        <div class="text-muted mb-1">Approver</div>
                        <div class="font-weight-bold text-gray-900">@DisplayText(matrix.ApproverName)</div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-lg-4">
                        <div class="text-muted mb-1">Created At</div>
                        <div class="font-weight-bold text-gray-900">@DisplayDateTime(matrix.CreatedAt)</div>
                    </div>

                    <div class="col-lg-4 mt-3 mt-lg-0">
                        <div class="text-muted mb-1">Modified At</div>
                        <div class="font-weight-bold text-gray-900">@DisplayDateTime(matrix.ModifiedAt)</div>
                    </div>

                    <div class="col-lg-4 mt-3 mt-lg-0">
                        <div class="text-muted mb-1">Approved At</div>
                        <div class="font-weight-bold text-gray-900">@DisplayDateTime(matrix.ApprovedAt)</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header py-3">
                <div>
                    <h6 class="m-0 font-weight-bold text-gray-800">
                        <i class="fas fa-layer-group fa-fw text-primary mr-2"></i>
                        Salary Bands
                    </h6>
                    <small class="text-muted">Configured compensation ranges by job profile.</small>
                </div>
            </div>

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-sm text-nowrap mb-0">
                        <thead class="thead-light text-center">
                            <tr>
                                <th>Job Level</th>
                                <th>Job Family</th>
                                <th>Position Grade</th>
                                <th>Minimum</th>
                                <th>Midpoint</th>
                                <th>Maximum</th>
                                <th>Below Flag</th>
                                <th>Above Flag</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (salaryBands.Any())
                            {
                                @foreach (var band in salaryBands)
                                {
                                    <tr @key="band.Id">
                                        <td>@DisplayText(band.JobLevelName)</td>
                                        <td>@DisplayText(band.JobFamilyName)</td>
                                        <td>@DisplayText(band.PositionGrade)</td>
                                        <td class="text-right">@DisplayAmount(band.BandMinimum, matrix.Currency)</td>
                                        <td class="text-right">@DisplayAmount(band.BandMidpoint, matrix.Currency)</td>
                                        <td class="text-right">@DisplayAmount(band.BandMaximum, matrix.Currency)</td>
                                        <td class="text-center align-middle">
                                            <span class="badge @FlagBadgeClass(band.BelowBandFlagEnabled)">
                                                @FlagBadgeText(band.BelowBandFlagEnabled)
                                            </span>
                                        </td>
                                        <td class="text-center align-middle">
                                            <span class="badge @FlagBadgeClass(band.AboveBandFlagEnabled)">
                                                @FlagBadgeText(band.AboveBandFlagEnabled)
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center text-muted py-3">
                                        <i class="fas fa-info-circle fa-fw mr-1"></i>
                                        No salary bands configured.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int matrixId { get; set; }

    private VwSalaryMatrix matrix = new();
    private List<VwSalaryMatrixBand> salaryBands = new();

    protected override async Task OnInitializedAsync()
    {
        matrix = await SalaryMatrixService.GetMatrix(matrixId);
        salaryBands = await SalaryMatrixService.GetSalaryBands(matrixId);
    }

    private static string DisplayText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private static string DisplayDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("MMM dd, yyyy") : "-";
    }

    private static string DisplayAmount(decimal? value, string? currency)
    {
        if (!value.HasValue)
            return "-";

        var formattedAmount = value.Value.ToString("N2");
        return string.IsNullOrWhiteSpace(currency) ? formattedAmount : $"{currency} {formattedAmount}";
    }

    private static string DisplayDateTime(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("MMM dd, yyyy hh:mm tt") : "-";
    }

    private static string FlagBadgeClass(bool? isEnabled)
    {
        return isEnabled == true ? "badge-success" : "badge-secondary";
    }

    private static string FlagBadgeText(bool? isEnabled)
    {
        return isEnabled == true ? "Enabled" : "Disabled";
    }
}
