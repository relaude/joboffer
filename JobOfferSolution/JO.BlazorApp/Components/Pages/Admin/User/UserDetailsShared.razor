
@inject IManageUsersService ManageUsersService
@inject IAlertService AlertService
@inject NavigationManager Navigation

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header py-3 bg-white">
        <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between">
            <div class="d-flex align-items-center mb-2 mb-lg-0">
                <div class="icon-circle bg-primary text-white mr-2">
                    <i class="fas fa-user-shield"></i>
                </div>
                <div>
                    <h6 class="m-0 font-weight-bold text-primary">Job Offer User</h6>
                    <div class="text-xs text-gray-500">@joUser?.Name</div>
                </div>
            </div>

            <div class="d-flex flex-wrap align-items-center">
                <span class="badge badge-info badge-pill">
                    <i class="fas fa-project-diagram fa-fw mr-1"></i>RBAC + ABAC Details
                </span>
            </div>
        </div>
    </div>

    <div class="card-body">
        <div class="row">
            <div class="col-xl-8">
                <div class="card mb-3">
                    <div class="card-header py-2 bg-white d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                        <div>
                            <h6 class="m-0 font-weight-bold text-gray-800 text-uppercase text-xs">
                                <i class="fas fa-id-card fa-fw mr-1 text-primary"></i>General Information
                            </h6>
                        </div>
                        @if (joUser?.IsActive == true)
                        {
                            <span class="badge badge-success badge-pill mt-2 mt-md-0">
                                <i class="fas fa-user-check fa-fw mr-1"></i>Active
                            </span>
                        }
                        else
                        {
                            <span class="badge badge-secondary badge-pill mt-2 mt-md-0">
                                <i class="fas fa-user-slash fa-fw mr-1"></i>Inactive
                            </span>
                        }
                    </div>

                    <div class="card-body">
                        <div class="mb-3">
                            <label class="font-weight-bold text-gray-700 mb-1">Full Name</label>
                            <input type="text" class="form-control form-control-sm" value="@joUser?.Name" readonly />
                        </div>

                        <div class="mb-3">
                            <label class="font-weight-bold text-gray-700 mb-1">Email</label>
                            <input type="email" class="form-control form-control-sm" value="@joUser?.Email" readonly />
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header py-2 bg-white">
                        <h6 class="m-0 font-weight-bold text-gray-800 text-uppercase text-xs">
                            <i class="fas fa-user-shield fa-fw mr-1 text-primary"></i>RBAC
                        </h6>
                    </div>

                    <div class="card-body">
                        @foreach (var role in userRoles)
                        {
                            <div class="role-row @(role.Checked ? "is-selected" : "")">
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox"
                                           class="custom-control-input"
                                           id="@($"{IdPrefix}_role_{role.Id}")"
                                           checked="@role.Checked"
                                           disabled />
                                    <label class="custom-control-label font-weight-bold text-gray-800" for="@($"{IdPrefix}_role_{role.Id}")">
                                        @role.RoleName
                                    </label>
                                </div>

                                <span class="badge badge-info">@role.RoleCategory</span>
                            </div>
                        }
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header py-2 bg-white">
                        <h6 class="m-0 font-weight-bold text-gray-800 text-uppercase text-xs">
                            <i class="fas fa-building fa-fw mr-1 text-primary"></i>Division Access
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Company</th>
                                        <th>Division Code</th>
                                        <th>Division Name</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var division in divisionAccess)
                                    {
                                        <tr>
                                            <td>@division.CompanyName</td>
                                            <td>@division.DivisionCode</td>
                                            <td>@division.DivisionName</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4">
                <div class="card border-left-info mb-4">
                    <div class="card-header py-2 bg-white">
                        <h6 class="m-0 font-weight-bold text-gray-800 text-uppercase text-xs">
                            <i class="fas fa-key fa-fw mr-1 text-primary"></i>Effective Permissions
                        </h6>
                    </div>
                    <div class="card-body">
                        @foreach (var permission in userPermissions)
                        {
                            <div class="d-flex align-items-center justify-content-between border-bottom py-2">
                                <div>
                                    <div class="font-weight-bold text-gray-800">@permission.PermissionCode</div>
                                    <div class="text-xs text-gray-500">@permission.PermissionName</div>
                                </div>
                                <span class="badge @(permission.Allowed ? "badge-success" : "badge-light border")">
                                    <i class="fas @(permission.Allowed ? "fa-check" : "fa-times") fa-fw mr-1"></i>@(permission.Allowed ? "Allowed" : "Denied")
                                </span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-footer d-flex flex-column flex-lg-row justify-content-end">
        <a href="@BackUrl" class="btn btn-outline-secondary btn-sm mb-2 mb-lg-0 @(ShowToggleButton ? "mr-2" : "")">
            <i class="fas fa-arrow-left fa-fw mr-1"></i>@BackButtonText
        </a>

        @if (ShowToggleButton && joUser?.IsActive == true)
        {
            <button class="btn btn-danger btn-sm mb-2 mb-lg-0"
                    @onclick="ToggleUserIsActive">
                <i class="fas fa-user-slash fa-fw mr-1"></i> Disable User
            </button>
        }
        else if (ShowToggleButton)
        {
            <button class="btn btn-success btn-sm mb-2 mb-lg-0"
                    @onclick="ToggleUserIsActive">
                <i class="fas fa-user-check fa-fw"></i> Activate User
            </button>
        }
    </div>
</div>

<style>
    .role-row {
        align-items: center;
        border-bottom: 1px solid #e3e6f0;
        display: flex;
        gap: .75rem;
        justify-content: space-between;
        padding: .6rem 0;
    }

        .role-row:first-child {
            padding-top: 0;
        }

        .role-row:last-child {
            border-bottom: 0;
            padding-bottom: 0;
        }

        .role-row.is-selected {
            background: #f0f4ff;
            border-radius: .35rem;
            margin: 0 -.5rem .2rem;
            padding: .6rem .5rem;
        }
</style>

@code {
    [Parameter] public int JoUserId { get; set; }
    [Parameter] public bool ShowToggleButton { get; set; }
    [Parameter] public string BackUrl { get; set; } = JORoutes.Admin.Users;
    [Parameter] public string BackButtonText { get; set; } = "Back to Users";
    [Parameter] public string ToggleRedirectUrl { get; set; } = string.Empty;

    private readonly string IdPrefix = $"general_info_{Guid.NewGuid():N}";
    private JobOfferUsers? joUser = new();
    private List<VwJOUserRolesDto> userRoles = new();
    private List<VwUserDivisionAccess> divisionAccess = new();
    private List<UserPermissionsDto> userPermissions = new();

    protected override async Task OnParametersSetAsync()
    {
        joUser = await ManageUsersService.GetUserById(JoUserId);
        userRoles = await ManageUsersService.GetJOUserRolesById(JoUserId);
        divisionAccess = await ManageUsersService.GetDivisionAccessByUserId(JoUserId);
        userPermissions = await ManageUsersService.GetUserPermissions(JoUserId);
    }

    private async Task ToggleUserIsActive()
    {
        if (!await AlertService.Confirm()) return;

        await ManageUsersService.ToggleIsActive(JoUserId);

        var redirectUrl = string.IsNullOrWhiteSpace(ToggleRedirectUrl)
            ? $"{JORoutes.Admin.UserDetails}/{JoUserId}"
            : ToggleRedirectUrl;

        Navigation.NavigateTo(redirectUrl);
    }
}
