@attribute [Authorize(Roles = JOUserRole.Admin)]
@attribute [Route(JORoutes.Admin.NewUser)]

@inject IManageUsersService ManageUsersService

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header py-3 bg-white">
        <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between">
            <div class="d-flex align-items-center mb-2 mb-lg-0">
                <div class="icon-circle bg-primary text-white mr-2">
                    <i class="fas fa-user-plus"></i>
                </div>
                <div>
                    <h6 class="m-0 font-weight-bold text-primary">Create Job Offer User</h6>
                    <div class="text-xs text-gray-500">New User | Hybrid RBAC + ABAC</div>
                </div>
            </div>

            <div class="d-flex flex-wrap align-items-center">
                <span class="badge badge-info badge-pill">
                    <i class="fas fa-project-diagram fa-fw mr-1"></i>RBAC + ABAC Setup
                </span>
            </div>
        </div>
    </div>

    <div class="card-body">
        <div class="row">

            <!-- General Info -->
            <div class="col-xl-3">
                <div class="card mb-4">
                    <div class="card-header py-2 bg-white d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                        <div>
                            <h6 class="m-0 font-weight-bold text-gray-800 text-uppercase text-xs">
                                <i class="fas fa-id-card fa-fw mr-1 text-primary"></i>General Information
                            </h6>
                        </div>
                        <span class="badge badge-success badge-pill mt-2 mt-md-0">
                            <i class="fas fa-user-check fa-fw mr-1"></i>Active
                        </span>
                    </div>

                    <div class="card-body">
                        <div class="mb-3">
                            <label class="font-weight-bold text-gray-700 mb-1">Full Name</label>
                            <input type="text" class="form-control form-control-sm"  />
                        </div>

                        <div class="mb-3">
                            <label class="font-weight-bold text-gray-700 mb-1">Email</label>
                            <input type="email" class="form-control form-control-sm" />
                        </div>
                    </div>
                </div>
            </div>
            <!-- General Info -->

            <!-- Roles -->
            <div class="col-xl-3">
                <div class="card mb-4">
                    <div class="card-header py-2 bg-white">
                        <h6 class="m-0 font-weight-bold text-gray-800 text-uppercase text-xs">
                            <i class="fas fa-user-shield fa-fw mr-1 text-primary"></i>RBAC
                        </h6>
                    </div>

                    <div class="card-body">
                        @if (userRoles.Any())
                        {
                            foreach (var role in userRoles)
                            {
                                <div class="custom-control custom-checkbox mb-2">
                                    <input type="checkbox" class="custom-control-input" id="@("role_" + role.Id)" />
                                    <label class="custom-control-label" for="@("role_" + role.Id)">
                                        <span class="font-weight-bold text-gray-800">@role.RoleName</span>
                                    </label>
                                </div>
                            }
                        }
                        
                    </div>
                </div>
            </div>
            <!-- Roles -->

            <!-- Company Access -->
            <div class="col-xl-6">
                <div class="card mb-4">
                    <div class="card-header py-2 bg-white d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                        <h6 class="m-0 font-weight-bold text-gray-800 text-uppercase text-xs">
                            <i class="fas fa-building fa-fw mr-1 text-primary"></i>Division Access
                        </h6>
                        <button type="button" class="btn btn-outline-primary btn-sm mt-2 mt-md-0" disabled>
                            <i class="fas fa-plus fa-fw mr-1"></i>Add Division
                        </button>
                    </div>

                    <div class="card-body">

                    </div>
                </div>
            </div>
            <!-- Company Access -->

        </div>
    
        <div class="row">
            <!-- Permissions -->
            <div class="col-xl-6">
                <div class="card mb-4">
                    <div class="card-header py-2 bg-white">
                        <h6 class="m-0 font-weight-bold text-gray-800 text-uppercase text-xs">
                            <i class="fas fa-key fa-fw mr-1 text-primary"></i>Effective Permissions
                        </h6>
                    </div>
                    <div class="card-body">
                        @foreach (var permission in permissions)
                        {
                            <div class="d-flex align-items-center justify-content-between border-bottom py-2">
                                <div>
                                    <div class="font-weight-bold text-gray-800">@permission.Code</div>
                                    <div class="text-xs text-gray-500">@permission.Name</div>
                                </div>
                                <span class="badge @(permission.Allowed ? "badge-success" : "badge-light border")">
                                    <i class="fas @(permission.Allowed ? "fa-check" : "fa-times") fa-fw mr-1"></i>@(permission.Allowed ? "Allowed" : "Denied")
                                </span>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <!-- Company Access -->

            <!-- ABAC Attributes -->
            <div class="col-xl-6">
                <div class="card mb-4">
                    <div class="card-header py-2 bg-white d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                        <h6 class="m-0 font-weight-bold text-gray-800 text-uppercase text-xs">
                            <i class="fas fa-tags fa-fw text-primary mr-1"></i>ABAC Attributes
                        </h6>
                        <button type="button" class="btn btn-outline-primary btn-sm mt-2 mt-md-0" disabled>
                            <i class="fas fa-plus fa-fw mr-1"></i>Add Attribute
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Attribute Name</th>
                                        <th>Value</th>
                                        <th>Used For</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in attributes)
                                    {
                                        <tr>
                                            <td class="font-weight-bold text-gray-800">@item.Name</td>
                                            <td>@item.Value</td>
                                            <td>@item.Usage</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <!-- ABAC Attributes -->
        </div>
    </div>

    <div class="card-footer d-flex flex-column flex-lg-row justify-content-end">
        <a href="@JORoutes.Admin.Users" class="btn btn-outline-secondary btn-sm mr-2 mb-2 mb-lg-0">
            <i class="fas fa-arrow-left fa-fw mr-1"></i>Back to Users
        </a>
        <button type="button" class="btn btn-primary btn-sm mb-2 mb-lg-0" disabled>
            <i class="fas fa-save fa-fw mr-1"></i>Save User
        </button>
    </div>
</div>

@code {
