@attribute [Route(JORoutes.Public.Denied)]
<div class="container d-flex align-items-center justify-content-center">
    <div class="col-6">
        <div class="card shadow-lg my-5">
            <div class="card-body p-5">
                <h1 class="h3 text-dark">Whoops — you don't have access</h1>
                <p class="text-muted mb-3">
                    It looks like your account isn't authorized to perform this action.
                </p>

                <div class="alert alert-info mb-0" role="status">
                    <ul class="mb-0 pl-3">
                        <li>Confirm you're signed in with the correct account.</li>
                        <li>Request additional permissions from an administrator.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@code {

}
