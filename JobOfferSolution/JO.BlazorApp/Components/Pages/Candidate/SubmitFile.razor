@inject IUtilitiesService UtilitiesService
@inject IAlertService AlertService
@inject ICandidateService CandidateService
@inject IFileUploadService FileUploadService
@inject NavigationManager Navigation

@attribute [Route(JORoutes.Candidate.Index)]
<div class="card border-left-primary mb-4 shadow">
    <div class="card-header py-3 d-flex align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-user-plus mr-2"></i> Candidate Submission
        </h6>
    </div>

    <div class="card-body">
        <div class="row">
            <div class="col-lg-4 border-right">
                
                <div class="form-group">
                    <label class="font-weight-bold">Full Name</label>
                    <InputText class="form-control"
                               @bind-Value="candidateName"
                               placeholder="Enter full name" />
                </div>

                <div class="form-group">
                    <label class="font-weight-bold">Email</label>
                    <InputText type="email"
                               class="form-control"
                               @bind-Value="candidateEmail"
                               placeholder="Enter email address" />
                </div>
            </div>

            <div class="col-lg-8">
                <div class="form-group">
                    <label class="font-weight-bold">Compensation & Benefits Form</label>
                    <div class="custom-file">
                        <InputFile OnChange="e => HandleFileSelected(e, JOFileType.CompBen)"
                                   class="custom-file-input"
                                   id="compFile" />
                        <label class="custom-file-label">@compensationFileName</label>
                    </div>
                </div>

                <div class="form-group">
                    <label class="font-weight-bold">Resume</label>
                    <div class="custom-file">
                        <InputFile OnChange="e => HandleFileSelected(e, JOFileType.Resume)"
                                   class="custom-file-input"
                                   id="resumeFile" />
                        <label class="custom-file-label">@resumeFileName</label>
                    </div>
                </div>

                <div class="form-group">
                    <label class="font-weight-bold">Latest Payslip</label>
                    <div class="custom-file">
                        <InputFile OnChange="e => HandleFileSelected(e, JOFileType.Payslip)"
                                   class="custom-file-input"
                                   id="payslipFile" />
                        <label class="custom-file-label">@payslipFileName</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="card-footer text-right">
        <button class="btn btn-primary px-4" @onclick="()=> Submit()">
            <i class="fas fa-paper-plane mr-2"></i> Submit
        </button>
    </div>
</div>

@code {

    private string candidateName;
    private string candidateEmail;

    private string compensationFileName = "Choose file";
    private string resumeFileName = "Choose file";
    private string payslipFileName = "Choose file";

    private IBrowserFile compensationFile;
    private IBrowserFile resumeFile;
    private IBrowserFile payslipFile;

    private void HandleFileSelected(InputFileChangeEventArgs e, int fileType)
    {
        var file = e.File;

        if (file == null)
            return;

        switch (fileType)
        {
            case JOFileType.CompBen:
                compensationFile = file;
                compensationFileName = file.Name;
                break;

            case JOFileType.Resume:
                resumeFile = file;
                resumeFileName = file.Name;
                break;

            case JOFileType.Payslip:
                payslipFile = file;
                payslipFileName = file.Name;
                break;
        }
    }

    private List<string> CollectErrors(List<string> errors)
    {
        string chooseFile = "Choose file";

        bool isValidEmail = UtilitiesService.IsValidEmail(candidateEmail);
        if (!isValidEmail)
            errors.Add("Please enter a valid email address.");

        if (string.IsNullOrEmpty(candidateName))
            errors.Add("Name is required.");

        if (string.IsNullOrEmpty(compensationFileName) || compensationFileName == chooseFile)
            errors.Add("Compensation & Benefits Form file is required.");

        if (string.IsNullOrEmpty(resumeFileName) || resumeFileName == chooseFile)
            errors.Add("Resume file is required.");

        if (string.IsNullOrEmpty(payslipFileName) || payslipFileName == chooseFile)
            errors.Add("Payslip file is required.");

        return errors;
    }

    private async Task Submit()
    {
        var errors = CollectErrors(new List<string>());

        if (errors.Any())
        {
            await AlertService.Errors(errors);
            return;
        }

        if (!await AlertService.Confirm())
            return;
        
        var attachments = new List<AttachmentDto>();
        
        attachments.Add(new AttachmentDto { 
            FileType_Id = JOFileType.CompBen,
            FileName = compensationFileName,
            FileBytes = await FileUploadService.ReadFileAsync(compensationFile)
        });


        attachments.Add(new AttachmentDto { 
            FileType_Id = JOFileType.Resume,
            FileName = resumeFileName,
            FileBytes = await FileUploadService.ReadFileAsync(resumeFile)
        });

        attachments.Add(new AttachmentDto { 
            FileType_Id = JOFileType.Payslip,
            FileName = payslipFileName,
            FileBytes = await FileUploadService.ReadFileAsync(payslipFile)
        });

        var transactionId = await CandidateService.NewTransactionAsync(candidateName, candidateEmail, attachments);
        Navigation.NavigateTo($"{JORoutes.Candidate.Details}/{transactionId}");
    }
}

