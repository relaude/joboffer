@attribute [Route(JORoutes.MockUp.Analysis)]

<div class="card shadow mb-4 border-left-primary small jo-analysis-ta-page">
    <div class="card-header py-3 bg-white">
        <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between">
            <div>
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-chart-line fa-fw mr-2"></i>
                    Job Offer Analysis
                </h6>
                <small class="text-muted">
                    @application.ReferenceNumber &middot; @candidate.CandidateName &middot; @candidate.PositionAppliedFor
                </small>
            </div>

            <div class="mt-2 mt-lg-0">
                <span class="badge badge-light border mr-1">
                    <i class="fas fa-user-tie fa-fw text-primary mr-1"></i>
                    TA Partner View
                </span>
                <span class="badge badge-success">
                    <i class="fas fa-check-circle fa-fw mr-1"></i>
                    Matrix Matched
                </span>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <!-- KPI summary strip -->
        <div class="row mb-4">
            <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
                <div class="card border-left-primary shadow-sm h-100 py-2">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Recommended Offer</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@recommended.ProposedSalary</div>
                                <div class="text-xs text-muted">Option @recommended.OptionNumber &middot; @application.Currency</div>
                            </div>
                            <i class="fas fa-hand-holding-usd fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
                <div class="card border-left-success shadow-sm h-100 py-2">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Increase vs Current</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@($"{recommended.IncreasePercentage}%")</div>
                                <div class="text-xs text-muted">From @candidate.CurrentSalary</div>
                            </div>
                            <i class="fas fa-arrow-trend-up fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
                <div class="card border-left-info shadow-sm h-100 py-2">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Compa-Ratio</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@recommended.CompaRatio</div>
                                <div class="text-xs text-muted">Against band midpoint</div>
                            </div>
                            <i class="fas fa-balance-scale fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-3 col-md-6 mb-0">
                <div class="card border-left-warning shadow-sm h-100 py-2">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Negotiation Risk</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@assessment.RiskLevel</div>
                                <div class="text-xs text-muted">TA assessment</div>
                            </div>
                            <i class="fas fa-triangle-exclamation fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row align-items-start">
            <div class="col-lg-6 pr-lg-3 mb-4 mb-lg-0">
                <!-- Application -->
                <div class="card border shadow-sm w-100 mb-3">
                    <div class="card-header bg-white py-2">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            <i class="fas fa-building fa-fw text-primary mr-2"></i>
                            Application Details
                        </h6>
                    </div>
                    <div class="card-body p-3">
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Reference No.</div>
                            <div class="col-sm-8 font-weight-bold text-gray-900">@application.ReferenceNumber</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Company</div>
                            <div class="col-sm-8">@application.CompanyName</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Division</div>
                            <div class="col-sm-8 font-weight-bold text-gray-900">@application.DivisionName</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Salary Matrix</div>
                            <div class="col-sm-8 font-weight-bold text-gray-900">@application.MatrixName</div>
                        </div>
                        <hr class="my-3" />
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Candidate</div>
                            <div class="col-sm-8 font-weight-bold text-gray-900">@candidate.CandidateName</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Position</div>
                            <div class="col-sm-8">@candidate.PositionAppliedFor</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-sm-4 text-muted">Current Salary</div>
                            <div class="col-sm-8">@candidate.CurrentSalary</div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4 text-muted">Expected Salary</div>
                            <div class="col-sm-8 font-weight-bold text-gray-900">@candidate.ExpectedSalary</div>
                        </div>
                    </div>
                </div>

                <!-- Salary Matrix with band position bar -->
                <div class="card border shadow-sm w-100 mb-3">
                    <div class="card-header bg-white py-2">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            <i class="fas fa-table fa-fw text-primary mr-2"></i>
                            Salary Matrix &amp; Band Position
                        </h6>
                    </div>
                    <div class="card-body p-3">
                        <div class="row mb-2">
                            <div class="col-sm-5 text-muted">Matrix Code</div>
                            <div class="col-sm-7 font-weight-bold text-gray-900">@selectedBand.MatrixCode</div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-sm-5 text-muted">Salary Grade</div>
                            <div class="col-sm-7">@selectedBand.PositionGrade</div>
                        </div>

                        <div class="text-xs text-muted mb-1">Recommended offer position within band</div>
                        <div class="jo-band-track mb-1">
                            <div class="jo-band-mid"></div>
                            <div class="jo-band-marker" style="left:@($"{recommended.BandPositionPercent}%")">
                                <span class="jo-band-bubble">@recommended.ProposedSalary</span>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between text-xs text-gray-700 font-weight-bold">
                            <span>Min<br /><span class="text-muted font-weight-normal">@selectedBand.BandMinimum</span></span>
                            <span class="text-center">Mid<br /><span class="text-muted font-weight-normal">@selectedBand.BandMidpoint</span></span>
                            <span class="text-right">Max<br /><span class="text-muted font-weight-normal">@selectedBand.BandMaximum</span></span>
                        </div>
                    </div>
                </div>

                <!-- Negotiation Assessment -->
                <div class="card border shadow-sm w-100 mb-3">
                    <div class="card-header bg-white py-2">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            <i class="fas fa-handshake fa-fw text-primary mr-2"></i>
                            Negotiation Assessment
                        </h6>
                    </div>
                    <div class="card-body p-3">
                        <div class="row mb-2">
                            <div class="col-6 text-muted">Expected Salary</div>
                            <div class="col-6 text-right font-weight-bold text-gray-900">@candidate.ExpectedSalary</div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-6 text-muted">Recommended Offer</div>
                            <div class="col-6 text-right font-weight-bold text-gray-900">@recommended.ProposedSalary</div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-6 text-muted">Risk Level</div>
                            <div class="col-6 text-right"><span class="badge badge-warning">@assessment.RiskLevel</span></div>
                        </div>
                        <div class="border-left-info bg-light px-3 py-2 rounded">
                            <div class="font-weight-bold text-gray-900 mb-1">
                                <i class="fas fa-lightbulb fa-fw text-info mr-1"></i>Assessment
                            </div>
                            <div class="text-muted">@assessment.RiskReason</div>
                        </div>
                    </div>
                </div>

                <!-- Approval Preview -->
                <div class="card border shadow-sm w-100 mb-0">
                    <div class="card-header bg-white py-2">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            <i class="fas fa-route fa-fw text-primary mr-2"></i>
                            Approval Routing Preview
                        </h6>
                    </div>
                    <div class="card-body p-3">
                        @foreach (var approval in approvals)
                        {
                            <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                                <span>
                                    <i class="fas fa-user-shield fa-fw text-gray-400 mr-2"></i>@approval.Role
                                </span>
                                <span class="badge @approval.BadgeClass">@approval.Status</span>
                            </div>
                        }
                        <div class="border-left-info bg-light px-3 py-2 mt-3 rounded text-muted">
                            <i class="fas fa-clipboard-list fa-fw text-info mr-1"></i>
                            Approval view includes all salary options, band results, and TA notes.
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 pl-lg-3">
                <!-- Salary Bands -->
                <div class="card border shadow-sm w-100 mb-3">
                    <div class="card-header bg-white py-2">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            <i class="fas fa-layer-group fa-fw text-primary mr-2"></i>
                            Applicable Salary Bands
                        </h6>
                    </div>
                    <div class="card-body p-3">
                        <div class="list-group list-group-flush">
                            @foreach (var band in salaryBands)
                            {
                                var isSelected = selectedBandId == band.Id;
                                <label class="list-group-item d-flex align-items-center justify-content-between px-0 py-2 mb-0 @(isSelected ? "jo-band-selected" : "")">
                                    <span class="d-flex align-items-center">
                                        <input class="mr-3" type="radio" name="salaryBand" checked="@isSelected" disabled />
                                        <span class="font-weight-bold text-gray-900">@band.JobLevelName</span>
                                    </span>
                                    <span class="text-xs text-muted">@band.BandMinimum &ndash; @band.BandMaximum</span>
                                </label>
                            }
                        </div>
                    </div>
                </div>

                <!-- JO Proposals -->
                <div class="text-xs font-weight-bold text-uppercase text-gray-500 mb-2">
                    <i class="fas fa-list-ol fa-fw mr-1"></i>Proposal Options
                </div>
                @foreach (var option in joProposals)
                {
                    <div class="mb-3">
                        <div class="border rounded shadow-sm h-100 w-100 @(option.IsRecommended ? "jo-proposal-recommended" : "")">
                            <div class="px-3 py-2 border-bottom d-flex justify-content-between align-items-center @(option.IsRecommended ? "bg-success text-white" : "bg-light")">
                                <span class="font-weight-bold @(option.IsRecommended ? "text-white" : "text-gray-900")">
                                    @if (option.IsRecommended)
                                    {
                                        <i class="fas fa-star fa-fw mr-1"></i>
                                    }
                                    @($"Option {option.OptionNumber}")
                                    @if (option.IsRecommended)
                                    {
                                        <span class="ml-1">&middot; Recommended</span>
                                    }
                                </span>
                                <span class="badge @(option.IsRecommended ? "badge-light" : "badge-success")">@option.ValidationStatus</span>
                            </div>
                            <div class="p-3">
                                <div class="d-flex align-items-baseline justify-content-between mb-3">
                                    <div>
                                        <div class="text-xs text-muted">Base Salary (@application.Currency)</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800">@option.ProposedSalary</div>
                                    </div>
                                    <div class="text-right">
                                        <div class="text-xs text-muted">Annual + Packages</div>
                                        <div class="font-weight-bold text-gray-900">@option.AnnualSalary</div>
                                    </div>
                                </div>

                                <div class="row text-center mb-3">
                                    <div class="col-6">
                                        <div class="text-xs text-muted">Increase</div>
                                        <div class="font-weight-bold text-success">@($"{option.IncreasePercentage}%")</div>
                                    </div>
                                    <div class="col-6">
                                        <div class="text-xs text-muted">Compa-Ratio</div>
                                        <div class="font-weight-bold text-info">@option.CompaRatio</div>
                                    </div>
                                </div>

                                <div class="jo-band-track jo-band-track-sm mb-2">
                                    <div class="jo-band-mid"></div>
                                    <div class="jo-band-marker" style="left:@($"{option.BandPositionPercent}%")"></div>
                                </div>

                                <div class="text-xs text-muted mb-1">Justification</div>
                                <div class="text-gray-800">@option.Justification</div>
                            </div>
                        </div>
                    </div>
                }
                
                <!-- Compensation & Benefits Snapshot -->
                <div class="card border shadow-sm w-100 mb-3">
                    <div class="card-header bg-white py-2 d-flex align-items-center justify-content-between">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            <i class="fas fa-gift fa-fw text-primary mr-2"></i>
                            Compensation &amp; Benefits
                        </h6>
                        <select class="form-control form-control-sm w-auto" disabled>
                            @foreach (var package in ddPackages)
                            {
                                <option selected="@(package == selectedPackage)">@package</option>
                            }
                        </select>
                    </div>
                    <div class="card-body p-3">
                        <div class="table-responsive">
                            <table class="table table-sm mb-0 jo-benefits-table">
                                <tbody>
                                    @foreach (var item in compensationItems)
                                    {
                                        <tr>
                                            <td class="text-muted">@item.Label</td>
                                            <td class="text-right font-weight-bold text-gray-900">@item.Value</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Analysis Notes -->
                <div class="card border shadow-sm w-100 mb-0">
                    <div class="card-header bg-white py-2">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                            <i class="fas fa-pen-square fa-fw text-primary mr-2"></i>
                            TA Partner Notes
                        </h6>
                    </div>
                    <div class="card-body p-3">
                        <textarea class="form-control form-control-sm form-ctrl-sml" rows="4" readonly>@analysisNotes</textarea>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-footer bg-white d-flex flex-column flex-sm-row align-items-stretch align-items-sm-center justify-content-between">
        <a href="@JORoutes.TA.JobOfferTracker" class="btn btn-outline-secondary btn-sm mb-2 mb-sm-0">
            <i class="fas fa-arrow-left fa-fw mr-1"></i>Back to Tracker
        </a>
        <div>
            <button type="button" class="btn btn-outline-info btn-sm mr-2" disabled>
                <i class="fas fa-calculator fa-fw mr-1"></i>
                Recompute Analysis
            </button>
            <button type="button" class="btn btn-primary btn-sm" disabled>
                <i class="fas fa-paper-plane fa-fw mr-1"></i>
                Submit For Approval
            </button>
        </div>
    </div>
</div>

<style>
    .jo-analysis-ta-page .form-ctrl-sml {
        font-size: .8rem;
        min-height: calc(1.5em + .5rem + 2px);
    }

    .jo-analysis-ta-page textarea.form-ctrl-sml {
        min-height: auto;
    }

    /* Salary band position track */
    .jo-analysis-ta-page .jo-band-track {
        position: relative;
        height: 10px;
        border-radius: 6px;
        background: linear-gradient(90deg, #e74a3b 0%, #f6c23e 50%, #1cc88a 100%);
        opacity: .85;
        margin-top: .5rem;
    }

    .jo-analysis-ta-page .jo-band-track-sm {
        height: 6px;
        margin-top: .25rem;
    }

    .jo-analysis-ta-page .jo-band-mid {
        position: absolute;
        top: -3px;
        bottom: -3px;
        left: 50%;
        width: 2px;
        background: #5a5c69;
        transform: translateX(-50%);
    }

    .jo-analysis-ta-page .jo-band-marker {
        position: absolute;
        top: 50%;
        width: 14px;
        height: 14px;
        background: #fff;
        border: 3px solid #4e73df;
        border-radius: 50%;
        transform: translate(-50%, -50%);
        box-shadow: 0 1px 3px rgba(0, 0, 0, .3);
    }

    .jo-analysis-ta-page .jo-band-track-sm .jo-band-marker {
        width: 10px;
        height: 10px;
        border-width: 2px;
    }

    .jo-analysis-ta-page .jo-band-bubble {
        position: absolute;
        bottom: 16px;
        left: 50%;
        transform: translateX(-50%);
        white-space: nowrap;
        font-size: .65rem;
        font-weight: 700;
        color: #4e73df;
        background: #eaf0ff;
        border: 1px solid #cddafe;
        padding: 1px 6px;
        border-radius: 10px;
    }

    .jo-analysis-ta-page .jo-band-selected {
        background: #eaf7f1;
        border-radius: 6px;
    }

    .jo-analysis-ta-page .jo-proposal-recommended {
        border-color: #1cc88a !important;
        box-shadow: 0 0 0 1px #1cc88a, 0 .15rem .5rem rgba(28, 200, 138, .15) !important;
    }

    .jo-analysis-ta-page .jo-benefits-table td {
        padding: .4rem .5rem;
    }
</style>

@code {
    private readonly MockApplication application = new(
        "APP-2026-000123",
        "Unilab Inc.",
        "Sales Division",
        "PH Sales 2026 Salary Matrix",
        "Juan Dela Cruz",
        "PHP");

    private readonly MockCandidate candidate = new(
        "Juan Dela Cruz",
        "Territory Sales Representative",
        "PHP 35,000.00",
        "PHP 45,000.00");

    private readonly MockBand selectedBand = new(
        1,
        "Professional (P3)",
        "PH-SALES-SG12",
        "SG-12",
        "PHP 38,000.00",
        "PHP 45,000.00",
        "PHP 52,000.00");

    private readonly int selectedBandId = 1;

    private readonly List<MockBand> salaryBands =
    [
        new(1, "Professional (P3)", "PH-SALES-SG12", "SG-12", "PHP 38,000.00", "PHP 45,000.00", "PHP 52,000.00"),
        new(2, "Senior Professional (P4)", "PH-SALES-SG13", "SG-13", "PHP 48,000.00", "PHP 56,000.00", "PHP 64,000.00"),
        new(3, "Lead (M1)", "PH-SALES-SG14", "SG-14", "PHP 60,000.00", "PHP 70,000.00", "PHP 80,000.00")
    ];

    private readonly List<MockProposal> joProposals =
    [
        new(1, "PHP 42,000.00", "Conservative offer aligned with lower market range.", "20.00", "0.93", "PHP 504,000.00", "Within Band", false, 28.6),
        new(2, "PHP 45,000.00", "Recommended offer matching candidate expectation and salary midpoint.", "28.57", "1.00", "PHP 540,000.00", "Within Band", true, 50.0),
        new(3, "PHP 50,000.00", "Competitive offer for faster acceptance while remaining below maximum.", "42.86", "1.11", "PHP 600,000.00", "Within Band", false, 85.7)
    ];

    private MockProposal recommended => joProposals.FirstOrDefault(p => p.IsRecommended) ?? joProposals.First();

    private readonly MockAssessment assessment = new(
        "Medium",
        "Recommended proposal meets candidate expectation and aligns to matrix midpoint, keeping negotiation risk manageable.");

    private readonly List<MockApproval> approvals =
    [
        new("HROD Head", "Pending", "badge-warning"),
        new("Division Head", "Pending", "badge-warning"),
        new("President Approval", "Not Required", "badge-light border")
    ];

    private readonly List<string> ddPackages =
    [
        "Standard Sales Package",
        "Enhanced Sales Package"
    ];

    private readonly string selectedPackage = "Standard Sales Package";

    private readonly List<MockPair> compensationItems =
    [
        new("Rice Allowance", "PHP 2,000.00"),
        new("Transportation Allowance", "PHP 4,000.00"),
        new("Communication Allowance", "PHP 1,500.00"),
        new("Clothing Allowance", "PHP 750.00"),
        new("Signing Bonus", "PHP 20,000.00"),
        new("Benefit Package", "HMO + leave conversion")
    ];

    private readonly string analysisNotes =
        "Candidate is validated and salary matrix is active. Option 2 is recommended because it meets expected salary, aligns to midpoint, and remains within the approved salary band.";

    private sealed record MockApplication(
        string ReferenceNumber,
        string CompanyName,
        string DivisionName,
        string MatrixName,
        string CandidateName,
        string Currency);

    private sealed record MockCandidate(
        string CandidateName,
        string PositionAppliedFor,
        string CurrentSalary,
        string ExpectedSalary);

    private sealed record MockBand(
        int Id,
        string JobLevelName,
        string MatrixCode,
        string PositionGrade,
        string BandMinimum,
        string BandMidpoint,
        string BandMaximum);

    private sealed record MockProposal(
        int OptionNumber,
        string ProposedSalary,
        string Justification,
        string IncreasePercentage,
        string CompaRatio,
        string AnnualSalary,
        string ValidationStatus,
        bool IsRecommended,
        double BandPositionPercent);

    private sealed record MockAssessment(string RiskLevel, string RiskReason);

    private sealed record MockApproval(string Role, string Status, string BadgeClass);

    private sealed record MockPair(string Label, string Value);
}