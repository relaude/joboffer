    private readonly List<MockApproval> approvals =
    [
        new("HROD Head", "Pending", "badge-warning"),
        new("Division Head", "Pending", "badge-warning"),
        new("President Approval", "Not Required", "badge-light border")
    ];

    private readonly List<MockPair> compensationItems =
    [
        new("Rice Allowance", "PHP 2,000.00"),
        new("Transportation Allowance", "PHP 4,000.00"),
        new("Communication Allowance", "PHP 1,500.00"),
        new("Clothing Allowance", "PHP 750.00"),
        new("Signing Bonus", "PHP 20,000.00"),
        new("Benefit Package", "HMO + leave conversion")
    ];

    private readonly List<MockMapping> mockMappings =
    [
        new("Candidate summary", "Candidates", "FirstName, LastName, PositionAppliedFor, CurrentEmployer, ExpectedSalary"),
        new("Application context", "CandidateApplications", "CandidateId, RequisitionId, HiringCompanyId, LegalEntityId, CurrentWorkflowStatusId"),
        new("Validated compensation", "CandidateCompensationProfile", "CurrentBaseSalary, ExpectedSalary, IsValidated, ValidationDate, ValidatedBy"),
        new("Submission package", "CandidateDocuments", "CandidateApplicationId, FileName, VersionNo, UploadedDate, IsActive"),
        new("Salary matrix", "SalaryMatrix", "CompanyId, MatrixName, MatrixCode, EffectiveFrom, EffectiveTo, ApprovalStatusId, IsActive"),
        new("Salary band validation", "SalaryMatrixBand", "BandMinimum, BandMidpoint, BandMaximum, BelowBandFlagEnabled, AboveBandFlagEnabled"),
        new("Offer header", "JobOffers", "JobOfferNumber, Candidate_Id, CandidateApplicationId, BasicSalary, OfferDate, MainStatus_Id"),
        new("Offer compensation", "JobOfferCompensations", "MonthlySalary, AnnualSalary, Allowances, SigningBonus, Remarks"),
        new("Offer benefits", "JobOfferBenefits", "JobOfferId, BenefitId, BenefitValue")
    ];

    private sealed record MockOffer(
        string JobOfferNumber,
        string Status,
        string BestProposal,
        string RiskLevel,
        string RiskReason,
        string AnalysisNotes);

    private sealed record MockCandidate(
        string Name,
        string PositionAppliedFor,
        string CurrentEmployer,
        string CurrentSalary,
        string ExpectedSalary,
        string ApplicationDate,
        string ValidatedBy,
        string ValidatedDate);

    private sealed record MockOrganization(
        string RequisitionNo,
        string PositionTitle,
        string Company,
        string LegalEntity,
        string JobFamily,
        string RoleLevel,
        string JobLevel);

    private sealed record MockMatrix(
        string MatrixName,
        string SalaryGrade,
        string Minimum,
        string Midpoint,
        string Maximum,
        string Status,
        string EffectiveDate);

    private sealed record MockStep(string Name, string Icon, string Status, string BadgeClass);

    private sealed record MockPair(string Label, string Value);

    private sealed record MockProposal(
        string Name,
        string BaseSalary,
        string Justification,
        string BandPosition,
        string IncreasePercent,
        string CompaRatio,
        string AnnualSalary,
        string ValidationStatus,
        string BadgeClass);

