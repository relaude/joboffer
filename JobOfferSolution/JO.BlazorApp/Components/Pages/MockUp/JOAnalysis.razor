    ];

    private readonly List<MockProposal> proposals =
    [
        new("Option 1", "PHP 42,000.00", "Conservative offer aligned with lower market range.", "Within Band", "20.00%", "0.93", "PHP 504,000.00", "WITHIN BAND", "badge-success"),
        new("Option 2", "PHP 45,000.00", "Recommended offer matching candidate expectation and salary midpoint.", "Midpoint", "28.57%", "1.00", "PHP 540,000.00", "WITHIN BAND", "badge-success"),
