    private readonly List<MockPair> positionInfo =
    [
        new("Requisition No.", "REQ-2026-00125", true),
        new("Position Title", "Territory Sales Representative", true),
        new("Department", "Sales", false),
        new("Company", "Unilab Inc.", false),
        new("Legal Entity", "Unilab Philippines", true),
        new("Hiring Manager", "Maria Santos", false),
        new("TA Partner", "Andrea Reyes", false)
    ];

    private readonly List<MockOfferOption> approvedOffers =
    [
        new("Option A", "PHP 42,000.00", "PHP 3,000.00", "PHP 1,500.00", "PHP 46,500.00", "HROD / Division", "Conservative", false),
        new("Option B", "PHP 45,000.00", "PHP 3,000.00", "PHP 1,500.00", "PHP 49,500.00", "HROD / Division", "Recommended", true)
    ];

    private readonly MockDiscussion discussion = new(
        "June 16, 2026",
        "Phone Call",
        "Andrea Reyes",
        "Accepted",
        "Candidate asked for clarification on guaranteed allowances, transportation support, HMO coverage, and offer validity. TA Partner explained that Option B is the approved recommended package and that offer letter generation must match the approved option.",
        "Candidate verbally accepted Option B after benefits clarification and confirmed preferred start date remains July 15, 2026.");

    private readonly List<MockResponse> candidateResponses =
    [
        new("Accepted", true),
        new("Requested Negotiation", false),
        new("Declined", false)
    ];

    private readonly MockNegotiation negotiation = new(
        "PHP 48,000.00",
