    ];

    private readonly List<MockPair> acceptanceDetails =
    [
        new("Accepted Option", "Option B", true),
        new("Accepted Salary", "PHP 45,000.00", true),
        new("Total Monthly Package", "PHP 49,500.00", true),
        new("Acceptance Date", "June 16, 2026", false),
        new("Expected Start Date", "July 15, 2026", false)
    ];

    private readonly List<MockPair> acceptanceSummary =
    [
        new("Selected Option", "Option B", true, true),
        new("Salary", "PHP 45,000.00", true, true),
        new("Discussion Status", "Accepted", true, true),
        new("Acceptance Date", "June 16, 2026", false),
        new("Offer Status", "Ready For Offer Letter Generation", true, true)
    ];

    private readonly List<MockAudit> auditTrail =
    [
        new("Jun 14, 2026 04:10 PM", "HROD Head", "Approved", "Option A and Option B approved for candidate discussion.", "badge-success"),
        new("Jun 15, 2026 09:20 AM", "Andrea Reyes", "Discussed", "Initial candidate call completed.", "badge-info"),
        new("Jun 16, 2026 02:35 PM", "Andrea Reyes", "Accepted", "Candidate verbally accepted Option B.", "badge-success"),
        new("Jun 16, 2026 02:40 PM", "System", "Ready", "Offer letter generation can proceed using accepted approved option.", "badge-primary")
    ];

    private sealed record MockOffer(
        string JobOfferNo,
        string CandidateName,
        string PositionTitle,
        string Status);

    private sealed record MockStep(
        string Name,
        string Icon,
        string Status,
        string BadgeClass,
        string TextClass);

    private sealed record MockPair(
        string Label,
        string Value,
        bool IsStrong = false,
        bool Highlight = false);

    private sealed record MockOfferOption(
        string Name,
        string BaseSalary,
        string Allowance,
        string Transportation,
        string TotalPackage,
        string ApprovalRoute,
        string Remarks,
        bool IsSelected);

    private sealed record MockDiscussion(
        string Date,
        string Method,
        string TAPartner,
        string Status,
        string Notes,
        string Feedback);

    private sealed record MockResponse(string Label, bool IsSelected);

    private sealed record MockNegotiation(string PreferredSalary, string Reason);

    private sealed record MockHistory(
        string Date,
        string Method,
        string Notes,
        string Icon,
        string IconBg);

    private sealed record MockAudit(
        string Timestamp,
        string User,
        string Activity,
        string Remarks,
        string BadgeClass);
}
