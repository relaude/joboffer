@* @attribute [Route(JORoutes.MockUp.Accept)] *@

<div class="card shadow mb-4 border-left-primary small acceptance-page">
    <div class="card-header py-3 bg-white">
        <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between">
            <div>
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-handshake fa-fw mr-2"></i>
                    Candidate Discussion and Acceptance
                </h6>
                <small class="text-muted">@offer.JobOfferNo | @offer.CandidateName | @offer.PositionTitle | Mockup data only</small>
            </div>

            <div class="mt-2 mt-lg-0">
                <span class="badge badge-light border mr-1">
                    <i class="fas fa-user-tie fa-fw text-primary mr-1"></i>
                    TA Partner View
                </span>
                <span class="badge badge-info">
                    <i class="fas fa-hourglass-half fa-fw mr-1"></i>
                    @offer.Status
                </span>
            </div>
        </div>
    </div>

    <div class="card-body">
        <div class="alert alert-light border-left-info py-2 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="fas fa-info-circle fa-fw text-info mr-2"></i>
                <span>Only approved salary options are shown for candidate discussion. Rejected proposals are hidden from selectable offer options.</span>
            </div>
        </div>

        <div class="row text-center mb-4">
            @foreach (var step in workflowSteps)
            {
                <div class="col-xl-2 col-md-4 col-6 mb-2">
                    <div class="border rounded bg-light px-2 py-2 h-100">
                        <div class="@step.TextClass mb-1"><i class="@step.Icon"></i></div>
                        <div class="text-xs font-weight-bold text-gray-800">@step.Name</div>
                        <span class="badge @step.BadgeClass mt-1">@step.Status</span>
                    </div>
                </div>
            }
        </div>

        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-id-card fa-fw text-primary mr-2"></i>
                            Candidate Information
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var item in candidateInfo)
                        {
                            <div class="row mb-2">
                                <div class="col-sm-5 text-muted">@item.Label</div>
                                <div class="col-sm-7 font-weight-bold text-gray-900">@item.Value</div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-6 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-briefcase fa-fw text-primary mr-2"></i>
                            Position Information
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var item in positionInfo)
                        {
                            <div class="row mb-2">
                                <div class="col-sm-5 text-muted">@item.Label</div>
                                <div class="col-sm-7 @(item.IsStrong ? "font-weight-bold text-gray-900" : string.Empty)">@item.Value</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <ul class="nav nav-tabs small mb-3" role="tablist">
            <li class="nav-item">
                <a class="nav-link active" href="javascript:void(0)">
                    <i class="fas fa-layer-group fa-fw mr-1"></i>
                    Approved Offers
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link disabled" href="javascript:void(0)">
                    <i class="fas fa-pen-square fa-fw mr-1"></i>
                    Discussion Notes
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link disabled" href="javascript:void(0)">
                    <i class="fas fa-comment-dots fa-fw mr-1"></i>
                    Candidate Feedback
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link disabled" href="javascript:void(0)">
                    <i class="fas fa-history fa-fw mr-1"></i>
                    History
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link disabled" href="javascript:void(0)">
                    <i class="fas fa-clipboard-check fa-fw mr-1"></i>
                    Summary
                </a>
            </li>
        </ul>

        <div class="row">
            <div class="col-xl-8 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light d-flex flex-column flex-md-row justify-content-between">
                        <div>
                            <h6 class="m-0 font-weight-bold text-gray-800">
                                <i class="fas fa-check-double fa-fw text-primary mr-2"></i>
                                Approved Offer Options
                            </h6>
                            <small class="text-muted">Selectable options completed all required approval levels.</small>
                        </div>
                        <span class="badge badge-success mt-2 mt-md-0 align-self-start align-self-md-center">
                            @approvedOffers.Count Approved
                        </span>
                    </div>

                    <div class="p-3">
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm text-nowrap mb-3">
                                <thead class="thead-light text-center">
                                    <tr>
                                        <th>Metric</th>
                                        @foreach (var option in approvedOffers)
                                        {
                                            <th>@option.Name</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="font-weight-bold text-gray-800">Base Salary</td>
                                        @foreach (var option in approvedOffers)
                                        {
                                            <td class="text-right font-weight-bold text-gray-900">@option.BaseSalary</td>
                                        }
                                    </tr>
                                    <tr>
                                        <td>Allowance</td>
                                        @foreach (var option in approvedOffers)
                                        {
                                            <td class="text-right">@option.Allowance</td>
                                        }
                                    </tr>
                                    <tr>
                                        <td>Transportation</td>
                                        @foreach (var option in approvedOffers)
                                        {
                                            <td class="text-right">@option.Transportation</td>
                                        }
                                    </tr>
                                    <tr class="bg-light">
                                        <td class="font-weight-bold text-gray-800">Total Monthly Package</td>
                                        @foreach (var option in approvedOffers)
                                        {
                                            <td class="text-right font-weight-bold text-primary">@option.TotalPackage</td>
                                        }
                                    </tr>
                                    <tr>
                                        <td>Approval Route</td>
                                        @foreach (var option in approvedOffers)
                                        {
                                            <td><span class="badge badge-light border">@option.ApprovalRoute</span></td>
                                        }
                                    </tr>
                                    <tr>
                                        <td>Remarks</td>
                                        @foreach (var option in approvedOffers)
                                        {
                                            <td>@option.Remarks</td>
                                        }
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="border rounded bg-light px-3 py-2">
                            <div class="text-xs font-weight-bold text-uppercase text-gray-500 mb-2">Select Discussion Option</div>
                            <div class="row">
                                @foreach (var option in approvedOffers)
                                {
                                    <div class="col-md-6 mb-2 mb-md-0">
                                        <div class="custom-control custom-radio">
                                            <input type="radio" class="custom-control-input" checked="@option.IsSelected" disabled />
                                            <label class="custom-control-label font-weight-bold text-gray-800">@option.Name - @option.TotalPackage</label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="alert alert-light border-left-secondary py-2 mt-3 mb-0">
                            <i class="fas fa-eye-slash fa-fw text-secondary mr-1"></i>
                            Option C was rejected during approval routing and is not available for candidate discussion.
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-phone-alt fa-fw text-primary mr-2"></i>
                            Discussion Information
                        </h6>
                    </div>

                    <div class="p-3">
                        <div class="form-group mb-3">
                            <label class="font-weight-bold text-gray-700 mb-1">Discussion Date</label>
                            <input class="form-control form-control-sm form-ctrl-sml bg-light" value="@discussion.Date" readonly />
                        </div>
                        <div class="form-group mb-3">
                            <label class="font-weight-bold text-gray-700 mb-1">Discussion Method</label>
                            <select class="form-control form-control-sm form-ctrl-sml" disabled>
                                <option selected>@discussion.Method</option>
                                <option>MS Teams</option>
                                <option>Face-to-Face</option>
                                <option>Email</option>
                            </select>
                        </div>
                        <div class="form-group mb-3">
                            <label class="font-weight-bold text-gray-700 mb-1">TA Partner</label>
                            <input class="form-control form-control-sm form-ctrl-sml bg-light" value="@discussion.TAPartner" readonly />
                        </div>
                        <div class="form-group mb-0">
                            <label class="font-weight-bold text-gray-700 mb-1">Discussion Status</label>
                            <div class="form-control form-control-sm form-ctrl-sml bg-light">
                                <span class="badge badge-success">@discussion.Status</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-pen-square fa-fw text-primary mr-2"></i>
                            Discussion Notes
                        </h6>
                    </div>

                    <div class="p-3">
                        <textarea class="form-control form-control-sm form-ctrl-sml" rows="6" readonly>@discussion.Notes</textarea>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-comment-dots fa-fw text-primary mr-2"></i>
                            Candidate Feedback
                        </h6>
                    </div>

                    <div class="p-3">
                        <div class="text-xs font-weight-bold text-uppercase text-gray-500 mb-2">Candidate Response</div>
                        <div class="row mb-3">
                            @foreach (var response in candidateResponses)
                            {
                                <div class="col-md-4 mb-2 mb-md-0">
                                    <div class="custom-control custom-radio">
                                        <input type="radio" class="custom-control-input" checked="@response.IsSelected" disabled />
                                        <label class="custom-control-label">@response.Label</label>
                                    </div>
                                </div>
                            }
                        </div>
                        <label class="font-weight-bold text-gray-700 mb-1">Feedback</label>
                        <textarea class="form-control form-control-sm form-ctrl-sml" rows="4" readonly>@discussion.Feedback</textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-5 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light d-flex justify-content-between">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-sync-alt fa-fw text-primary mr-2"></i>
                            Negotiation Request
                        </h6>
                        <span class="badge badge-warning">Conditional</span>
                    </div>

                    <div class="p-3">
                        <div class="alert alert-warning py-2 mb-3">
                            <i class="fas fa-exclamation-triangle fa-fw mr-1"></i>
                            Candidate requested a revised offer package. Previous offer history is retained.
                        </div>
                        <div class="form-group mb-3">
                            <label class="font-weight-bold text-gray-700 mb-1">Candidate Preferred Salary</label>
                            <input class="form-control form-control-sm form-ctrl-sml bg-light" value="@negotiation.PreferredSalary" readonly />
                        </div>
                        <div class="form-group mb-0">
                            <label class="font-weight-bold text-gray-700 mb-1">Reason</label>
                            <textarea class="form-control form-control-sm form-ctrl-sml" rows="3" readonly>@negotiation.Reason</textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-history fa-fw text-primary mr-2"></i>
                            Discussion History
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var item in discussionHistory)
                        {
                            <div class="d-flex mb-3">
                                <span class="icon-circle @item.IconBg text-white mr-3 acceptance-icon-sm">
                                    <i class="@item.Icon fa-sm"></i>
                                </span>
                                <div class="border-bottom flex-fill pb-2">
                                    <div class="d-flex flex-column flex-md-row justify-content-between">
                                        <span class="font-weight-bold text-gray-900">@item.Date</span>
                                        <span class="badge badge-light border align-self-start align-self-md-center">@item.Method</span>
                                    </div>
                                    <div class="text-muted">@item.Notes</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-clipboard-check fa-fw text-primary mr-2"></i>
                            Acceptance Details
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var item in acceptanceDetails)
                        {
                            <div class="d-flex justify-content-between border-bottom py-1">
                                <span class="text-muted">@item.Label</span>
                                <span class="font-weight-bold text-gray-900">@item.Value</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-6 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-file-signature fa-fw text-primary mr-2"></i>
                            Offer Acceptance Summary
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var item in acceptanceSummary)
                        {
                            <div class="d-flex justify-content-between border-bottom py-1">
                                <span class="text-muted">@item.Label</span>
                                <span class="font-weight-bold @(item.Highlight ? "text-primary" : "text-gray-900")">@item.Value</span>
                            </div>
                        }
                        <div class="border-left-success bg-light px-3 py-2 mt-3">
                            <i class="fas fa-check-circle fa-fw text-success mr-1"></i>
                            Ready for Offer Letter Generation using the accepted approved salary option.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="border rounded bg-white mb-4">
            <div class="px-3 py-2 border-bottom bg-light">
                <h6 class="m-0 font-weight-bold text-gray-800">
                    <i class="fas fa-clipboard-list fa-fw text-primary mr-2"></i>
                    Audit Trail
                </h6>
            </div>

            <div class="p-3">
                <div class="table-responsive">
                    <table class="table table-bordered table-sm mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th>Date / Time</th>
                                <th>User</th>
                                <th>Activity</th>
                                <th>Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var audit in auditTrail)
                            {
                                <tr>
                                    <td class="text-nowrap">@audit.Timestamp</td>
                                    <td>@audit.User</td>
                                    <td><span class="badge @audit.BadgeClass">@audit.Activity</span></td>
                                    <td>@audit.Remarks</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="d-flex flex-column flex-md-row justify-content-end">
            <button type="button" class="btn btn-outline-secondary btn-sm btn-sml mb-2 mb-md-0 mr-md-2" disabled>
                <i class="fas fa-save fa-fw mr-1"></i>
                Save Discussion
            </button>
            <button type="button" class="btn btn-outline-success btn-sm btn-sml mb-2 mb-md-0 mr-md-2" disabled>
                <i class="fas fa-check fa-fw mr-1"></i>
                Record Acceptance
            </button>
            <button type="button" class="btn btn-outline-warning btn-sm btn-sml mb-2 mb-md-0 mr-md-2" disabled>
                <i class="fas fa-sync-alt fa-fw mr-1"></i>
                Initiate Re-Proposal
            </button>
            <button type="button" class="btn btn-outline-danger btn-sm btn-sml mb-2 mb-md-0 mr-md-2" disabled>
                <i class="fas fa-times fa-fw mr-1"></i>
                Record Decline
            </button>
            <button type="button" class="btn btn-primary btn-sm btn-sml" disabled>
                <i class="fas fa-file-signature fa-fw mr-1"></i>
                Generate Offer Letter
            </button>
        </div>
    </div>
</div>

<style>
    .acceptance-page .form-ctrl-sml {
        font-size: 0.78rem;
        min-height: 31px;
    }

    .acceptance-page .btn-sml {
        font-size: 0.76rem;
        padding: 0.25rem 0.65rem;
    }

    .acceptance-page textarea.form-ctrl-sml {
        min-height: auto;
        resize: none;
    }

    .acceptance-page .acceptance-icon-sm {
        height: 2rem;
        width: 2rem;
        min-width: 2rem;
    }

    .acceptance-page .nav-tabs .nav-link {
        padding: 0.45rem 0.75rem;
    }

    .acceptance-page .custom-control-label {
        line-height: 1.55;
    }
</style>

@code {
