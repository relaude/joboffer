        new("Salary Band Validation", "fas fa-balance-scale", "Done", "badge-success", "text-success"),
        new("Approval Routing", "fas fa-route", "Done", "badge-success", "text-success"),
        new("Candidate Discussion", "fas fa-comments", "Current", "badge-info", "text-info"),
