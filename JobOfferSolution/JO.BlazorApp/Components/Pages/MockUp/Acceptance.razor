        new("Completed", "fas fa-flag-checkered", "Open", "badge-light border", "text-gray-500")
    ];

    private readonly List<MockPair> candidateInfo =
    [
        new("Candidate Name", "Juan Dela Cruz", true),
        new("Email Address", "juan@email.com", false),
        new("Mobile Number", "0917-123-4567", false),
        new("Current Employer", "ABC Corporation", false),
        new("Current Salary", "PHP 35,000.00", false),
        new("Expected Salary", "PHP 45,000.00", true),
