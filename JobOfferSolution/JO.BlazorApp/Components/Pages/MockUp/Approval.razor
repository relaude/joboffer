@attribute [Route(JORoutes.MockUp.Approval)]

<div class="card shadow mb-4 border-left-primary small">
    <div class="card-header bg-white py-3">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between">
            <div>
                <div class="d-flex align-items-center mb-1">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-file-signature fa-fw mr-2"></i>Job Offer Approval
                    </h6>
                    <span class="badge badge-warning ml-2">3 options awaiting review</span>
                </div>
                <div class="text-muted">JO-2026-000145 &middot; Juan Dela Cruz &middot; Territory Sales Representative</div>
            </div>
            <div class="d-flex align-items-center mt-3 mt-lg-0">
                <span class="badge badge-light border mr-2"><i class="fas fa-user-shield text-primary mr-1"></i>HROD Head</span>
                <button type="button" class="btn btn-outline-secondary btn-sm" disabled>
                    <i class="fas fa-arrow-left mr-1"></i>Back to approvals
                </button>
            </div>
        </div>
    </div>

    <div class="card-body p-3 p-lg-4">
        <div class="row mb-4">
            <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
                <div class="card border-left-primary shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="text-xs font-weight-bold text-primary text-uppercase">Candidate</div>
                        <div class="font-weight-bold text-gray-900 mt-1">Juan Dela Cruz</div>
                        <div class="text-muted">ABC Corporation</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
                <div class="card border-left-info shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="text-xs font-weight-bold text-info text-uppercase">Salary Context</div>
                        <div class="d-flex justify-content-between mt-1"><span class="text-muted">Current</span><strong>PHP 35,000</strong></div>
                        <div class="d-flex justify-content-between"><span class="text-muted">Expected</span><strong>PHP 45,000</strong></div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6 mb-3 mb-md-0">
                <div class="card border-left-success shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="text-xs font-weight-bold text-success text-uppercase">Salary Band</div>
                        <div class="font-weight-bold text-gray-900 mt-1">PHP 38,000 - 52,000</div>
                        <div class="text-muted">Midpoint: PHP 45,000</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="card border-left-warning shadow-sm h-100">
                    <div class="card-body py-3 px-3">
                        <div class="text-xs font-weight-bold text-warning text-uppercase">Approval Progress</div>
                        <div class="font-weight-bold text-gray-900 mt-1">HROD review</div>
                        <div class="text-muted">Next: Division Head</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="alert alert-light border d-flex flex-column flex-md-row align-items-md-center justify-content-between py-2 mb-3">
            <div><i class="fas fa-circle-info text-info mr-2"></i>Decide on each option independently. Comments are required only for <strong>Return</strong> or <strong>Reject</strong>.</div>
            <span class="text-muted text-nowrap mt-2 mt-md-0"><i class="fas fa-clock mr-1"></i>Submitted Jul 13, 2026</span>
        </div>

        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-2">
            <div>
                <h6 class="font-weight-bold text-gray-900 mb-0">Proposal options</h6>
                <span class="text-muted">Review the key differences and record one decision per card.</span>
            </div>
            <div class="mt-2 mt-md-0">
                <button type="button" class="btn btn-outline-success btn-sm mr-1" disabled><i class="fas fa-check-double mr-1"></i>Approve all</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" disabled><i class="fas fa-columns mr-1"></i>Compare details</button>
            </div>
        </div>

        <div class="row">
            @foreach (var option in proposals)
            {
                <div class="col-xl-4 mb-3">
                    <div class="card shadow-sm h-100 @(option.IsRecommended ? "border-primary" : "border")">
                        <div class="card-header px-3 py-3 @(option.IsRecommended ? "bg-primary text-white" : "bg-light")">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="font-weight-bold">
                                        @if (option.IsRecommended) { <i class="fas fa-star mr-1"></i> }
                                        @option.Name
                                    </div>
                                    <small class="@(option.IsRecommended ? "text-white-50" : "text-muted")">@option.Caption</small>
                                </div>
                                <span class="badge @(option.IsRecommended ? "badge-light" : "badge-success")">@option.BandPosition</span>
                            </div>
                        </div>

                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-end mb-3">
                                <div>
                                    <div class="text-xs text-muted text-uppercase">Monthly base</div>
                                    <div class="h5 font-weight-bold text-gray-900 mb-0">@option.BaseSalary</div>
                                </div>
                                <div class="text-right">
                                    <div class="text-xs text-muted">Annual</div>
                                    <strong>@option.AnnualSalary</strong>
                                </div>
                            </div>

                            <div class="row text-center no-gutters border rounded mb-3">
                                <div class="col-4 py-2 border-right"><small class="text-muted d-block">Increase</small><strong class="text-success">@option.Increase</strong></div>
                                <div class="col-4 py-2 border-right"><small class="text-muted d-block">Compa-ratio</small><strong>@option.CompaRatio</strong></div>
                                <div class="col-4 py-2"><small class="text-muted d-block">Route</small><strong>@option.Route</strong></div>
                            </div>

                            <div class="mb-3">
                                <div class="text-xs font-weight-bold text-uppercase text-gray-500 mb-1">TA justification</div>
                                <div class="text-gray-800">@option.Justification</div>
                            </div>

                            <div class="text-xs font-weight-bold text-uppercase text-gray-500 mb-2">Your decision</div>
                            <div class="btn-group btn-group-sm d-flex mb-3" role="group" aria-label="Decision for @option.Name">
                                <button type="button" class="btn flex-fill @(option.Decision == "Approve" ? "btn-success" : "btn-outline-success")" disabled><i class="fas fa-check mr-1"></i>Approve</button>
                                <button type="button" class="btn flex-fill @(option.Decision == "Return" ? "btn-warning" : "btn-outline-warning")" disabled><i class="fas fa-rotate-left mr-1"></i>Return</button>
                                <button type="button" class="btn flex-fill @(option.Decision == "Reject" ? "btn-danger" : "btn-outline-danger")" disabled><i class="fas fa-times mr-1"></i>Reject</button>
                            </div>

                            <label class="font-weight-bold text-gray-700 mb-1" for="@($"comment-{option.Number}")">
                                Comment
                                @if (option.CommentRequired) { <span class="text-danger">*</span><span class="sr-only">required</span> }
                                else { <span class="text-muted font-weight-normal">(optional)</span> }
                            </label>
                            <textarea id="@($"comment-{option.Number}")" class="form-control form-control-sm" rows="3" placeholder="@(option.CommentRequired ? "Explain why this option is being returned or rejected..." : "Add an optional approval note...")" readonly>@option.Comment</textarea>
                            @if (option.CommentRequired)
                            {
                                <small class="text-danger"><i class="fas fa-asterisk fa-xs mr-1"></i>Required for @option.Decision.ToLowerInvariant()</small>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="border rounded bg-light p-3 mt-1">
            <div class="row align-items-center">
                <div class="col-lg-8">
                    <div class="font-weight-bold text-gray-900"><i class="fas fa-clipboard-check text-primary mr-2"></i>Decision summary</div>
                    <div class="mt-2">
                        <span class="badge badge-success mr-2"><i class="fas fa-check mr-1"></i>1 approved</span>
                        <span class="badge badge-warning mr-2"><i class="fas fa-rotate-left mr-1"></i>1 returned</span>
                        <span class="badge badge-danger"><i class="fas fa-times mr-1"></i>1 rejected</span>
                    </div>
                    <small class="text-muted d-block mt-2">All three options have a decision and required comments are complete.</small>
                </div>
                <div class="col-lg-4 text-lg-right mt-3 mt-lg-0">
                    <button type="button" class="btn btn-outline-secondary btn-sm mr-1" disabled>Save draft</button>
                    <button type="button" class="btn btn-primary btn-sm px-4" disabled><i class="fas fa-paper-plane mr-1"></i>Submit 3 decisions</button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly List<MockProposal> proposals =
    [
        new(1, "Option 1", "Balanced starting offer", "PHP 42,000", "PHP 504,000", "20.0%", "0.93", "Within band", "Division", "Conservative offer aligned with the lower market range and internal peers.", false, "Return", "Please provide a stronger market comparison before resubmitting.", true),
        new(2, "Option 2", "TA recommended", "PHP 45,000", "PHP 540,000", "28.6%", "1.00", "Midpoint", "Division", "Meets the candidate expectation and lands exactly at the approved salary band midpoint.", true, "Approve", "Aligned with the midpoint and internal equity.", false),
        new(3, "Option 3", "Competitive upper offer", "PHP 50,000", "PHP 600,000", "42.9%", "1.11", "Upper band", "President", "Improves acceptance likelihood but places the offer near the top of the approved band.", false, "Reject", "The premium is not sufficiently supported by experience or internal equity.", true)
    ];

    private sealed record MockProposal(int Number, string Name, string Caption, string BaseSalary, string AnnualSalary,
        string Increase, string CompaRatio, string BandPosition, string Route, string Justification,
        bool IsRecommended, string Decision, string Comment, bool CommentRequired);
}
