@attribute [Route(JORoutes.MockUp.ARBAC)]

<div class="create-jo-user-page small">
    <div class="card shadow mb-4 border-left-primary">
        <div class="card-header py-3 bg-white">
            <div class="d-flex flex-column flex-xl-row align-items-start align-items-xl-center justify-content-between">
                <div class="d-flex align-items-center mb-3 mb-xl-0">
                    <div class="page-icon bg-primary text-white mr-3">
                        <i class="fas fa-user-shield"></i>
                    </div>
                    <div>
                        <h6 class="m-0 font-weight-bold text-primary">Create Job Offer User</h6>
                        <div class="text-xs text-gray-500">Administration > Security > Job Offer Users > Hybrid RBAC + ABAC</div>
                    </div>
                </div>

                <div class="d-flex flex-wrap">
                    @foreach (var pill in headerPills)
                    {
                        <span class="badge @pill.BadgeClass mr-2 mb-2 mb-xl-0">
                            <i class="@pill.Icon fa-fw mr-1"></i>@pill.Label
                        </span>
                    }
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="row mb-4">
                @foreach (var stat in summaryStats)
                {
                    <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
                        <div class="metric-tile border-left-@stat.Color">
                            <div>
                                <div class="text-xs font-weight-bold text-@stat.Color text-uppercase mb-1">@stat.Label</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-900">@stat.Value</div>
                            </div>
                            <i class="@stat.Icon fa-2x text-gray-300"></i>
                        </div>
                    </div>
                }
            </div>

            <div class="row">
                <div class="col-xl-8">
                    <div class="card shadow-sm border-left-primary mb-4">
                        <div class="card-header py-2 bg-white d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between">
                            <div>
                                <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                                    <i class="fas fa-id-card fa-fw mr-1"></i>General Information
                                </h6>
                            </div>
                            <span class="badge badge-success badge-pill mt-2 mt-md-0">
                                <i class="fas fa-check-circle fa-fw mr-1"></i>Active
                            </span>
                        </div>

                        <div class="card-body">
                            <div class="row">
                                <div class="col-lg-3 col-md-6 mb-3">
                                    <label class="font-weight-bold text-gray-700 mb-1">Employee No</label>
                                    <input class="form-control form-control-sm" value="100011" readonly />
                                </div>
                                <div class="col-lg-5 col-md-6 mb-3">
                                    <label class="font-weight-bold text-gray-700 mb-1">Full Name</label>
                                    <input class="form-control form-control-sm" value="Maria Dela Cruz" readonly />
                                </div>
                                <div class="col-lg-4 col-md-12 mb-3">
                                    <label class="font-weight-bold text-gray-700 mb-1">Email</label>
                                    <input class="form-control form-control-sm" value="maria.delacruz@unilab.com.ph" readonly />
                                </div>
                                <div class="col-lg-6 mb-3">
                                    <label class="font-weight-bold text-gray-700 mb-1">Azure AD Object ID</label>
                                    <input class="form-control form-control-sm" value="4f1c2d88-9a40-47b8-8a77-44f76f64a203" readonly />
                                </div>
                                <div class="col-lg-6 mb-3">
                                    <label class="font-weight-bold text-gray-700 mb-1">ASP.NET Identity User ID</label>
                                    <input class="form-control form-control-sm" value="10000000-0000-0000-0000-000000000203" readonly />
                                </div>
                                <div class="col-md-4 mb-3 mb-md-0">
                                    <label class="font-weight-bold text-gray-700 mb-1">Department</label>
                                    <select class="form-control form-control-sm" disabled>
                                        <option selected>Talent Acquisition</option>
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3 mb-md-0">
                                    <label class="font-weight-bold text-gray-700 mb-1">Business Unit</label>
                                    <select class="form-control form-control-sm" disabled>
                                        <option selected>Human Resources</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="font-weight-bold text-gray-700 mb-1">Location</label>
                                    <input class="form-control form-control-sm" value="Mandaluyong" readonly />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-6 mb-4">
                            <div class="card shadow-sm h-100 border-left-info">
                                <div class="card-header py-2 bg-white d-flex align-items-center justify-content-between">
                                    <h6 class="m-0 font-weight-bold text-info text-uppercase text-xs">
                                        <i class="fas fa-user-tag fa-fw mr-1"></i>RBAC Roles
                                    </h6>
                                    <span class="badge badge-light border">AspNetRoles</span>
                                </div>
                                <div class="card-body">
                                    @foreach (var role in roles)
                                    {
                                        <div class="role-row @(role.Assigned ? "is-selected" : "")">
                                            <div class="custom-control custom-checkbox">
                                                <input type="checkbox" class="custom-control-input" id="@role.Id" checked="@role.Assigned" disabled />
                                                <label class="custom-control-label font-weight-bold text-gray-800" for="@role.Id">@role.Name</label>
                                            </div>
                                            <span class="badge @role.BadgeClass">@role.Category</span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-6 mb-4">
                            <div class="card shadow-sm h-100 border-left-success">
                                <div class="card-header py-2 bg-white d-flex align-items-center justify-content-between">
                                    <h6 class="m-0 font-weight-bold text-success text-uppercase text-xs">
                                        <i class="fas fa-building fa-fw mr-1"></i>ABAC Scope
                                    </h6>
                                    <span class="badge badge-light border">Resource Match</span>
                                </div>
                                <div class="card-body">
                                    @foreach (var scope in accessScopes)
                                    {
                                        <div class="scope-row">
                                            <div>
                                                <div class="font-weight-bold text-gray-800">@scope.Name</div>
                                                <div class="text-xs text-gray-500">@scope.Type</div>
                                            </div>
                                            <span class="badge @(scope.Allowed ? "badge-success" : "badge-light border")">
                                                <i class="fas @(scope.Allowed ? "fa-check" : "fa-minus") fa-fw mr-1"></i>@scope.Status
                                            </span>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-left-warning mb-4">
                        <div class="card-header py-2 bg-white d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between">
                            <h6 class="m-0 font-weight-bold text-warning text-uppercase text-xs">
                                <i class="fas fa-coins fa-fw mr-1"></i>Approval Limits and Routing
                            </h6>
                            <span class="badge badge-warning mt-2 mt-md-0">Sequence 1 Approver</span>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-lg-4 mb-3 mb-lg-0">
                                    <div class="limit-box">
                                        <div class="text-xs text-uppercase font-weight-bold text-warning mb-1">Approval Range</div>
                                        <div class="h5 font-weight-bold text-gray-900 mb-1">PHP 0 - 100,000</div>
                                        <div class="text-xs text-gray-500">UserApprovalLimits</div>
                                    </div>
                                </div>
                                <div class="col-lg-8">
                                    <div class="row">
                                        @foreach (var route in routingRules)
                                        {
                                            <div class="col-md-6 mb-3">
                                                <div class="routing-chip">
                                                    <i class="@route.Icon @route.Color fa-fw mr-2"></i>
                                                    <div>
                                                        <div class="font-weight-bold text-gray-800">@route.Title</div>
                                                        <div class="text-gray-600">@route.Detail</div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card shadow-sm border-left-secondary mb-4">
                        <div class="card-header py-2 bg-white d-flex align-items-center justify-content-between">
                            <h6 class="m-0 font-weight-bold text-gray-800 text-uppercase text-xs">
                                <i class="fas fa-fingerprint fa-fw text-primary mr-1"></i>User Attributes
                            </h6>
                            <button type="button" class="btn btn-outline-primary btn-sm"
                                @onclick="()=> modalAddAttribute.Show()">
                                <i class="fas fa-plus fa-fw mr-1"></i>Add Attribute
                            </button>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-bordered table-sm mb-0">
                                    <thead class="thead-light">
                                        <tr>
                                            <th>Attribute</th>
                                            <th>Value</th>
                                            <th>Authorization Use</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in attributes)
                                        {
                                            <tr>
                                                <td class="font-weight-bold text-gray-800">@item.Name</td>
                                                <td>@item.Value</td>
                                                <td>@item.Usage</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-4">
                    <div class="card shadow-sm border-left-primary mb-4">
                        <div class="card-header py-2 bg-white">
                            <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                                <i class="fas fa-clipboard-check fa-fw mr-1"></i>Creation Summary
                            </h6>
                        </div>
                        <div class="card-body">
                            @foreach (var item in creationSummary)
                            {
                                <div class="summary-row">
                                    <span class="summary-icon @item.Background"><i class="@item.Icon"></i></span>
                                    <div>
                                        <div class="font-weight-bold text-gray-800">@item.Title</div>
                                        <div class="text-gray-600">@item.Detail</div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="card shadow-sm border-left-success mb-4">
                        <div class="card-header py-2 bg-white">
                            <h6 class="m-0 font-weight-bold text-success text-uppercase text-xs">
                                <i class="fas fa-key fa-fw mr-1"></i>Effective Permissions
                            </h6>
                        </div>
                        <div class="card-body">
                            @foreach (var permission in permissions)
                            {
                                <div class="permission-row">
                                    <div>
                                        <div class="font-weight-bold text-gray-800">@permission.Code</div>
                                        <div class="text-xs text-gray-500">@permission.Source</div>
                                    </div>
                                    <span class="badge @(permission.Allowed ? "badge-success" : "badge-light border")">
                                        <i class="fas @(permission.Allowed ? "fa-check" : "fa-times") fa-fw mr-1"></i>@(permission.Allowed ? "Allowed" : "Denied")
                                    </span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="card shadow-sm border-left-info mb-4">
                        <div class="card-header py-2 bg-white">
                            <h6 class="m-0 font-weight-bold text-info text-uppercase text-xs">
                                <i class="fas fa-id-card-alt fa-fw mr-1"></i>Claims Preview
                            </h6>
                        </div>
                        <div class="card-body">
                            @foreach (var claim in claims)
                            {
                                <div class="claim-row">
                                    <span class="text-gray-500">@claim.Type</span>
                                    <span class="font-weight-bold text-gray-900 text-right">@claim.Value</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="card shadow-sm border-left-danger mb-4">
                        <div class="card-header py-2 bg-white">
                            <h6 class="m-0 font-weight-bold text-danger text-uppercase text-xs">
                                <i class="fas fa-vial fa-fw mr-1"></i>Authorization Simulation
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="form-group">
                                <label class="font-weight-bold text-gray-700 mb-1">Company</label>
                                <select class="form-control form-control-sm" disabled>
                                    <option selected>Amherst Laboratories</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="font-weight-bold text-gray-700 mb-1">Division</label>
                                <select class="form-control form-control-sm" disabled>
                                    <option selected>Manufacturing Division</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="font-weight-bold text-gray-700 mb-1">Proposed Salary</label>
                                <input class="form-control form-control-sm text-right" value="125,000.00" readonly />
                            </div>
                            <div class="simulation-result bg-light">
                                <div class="font-weight-bold text-danger mb-1">
                                    <i class="fas fa-times-circle fa-fw mr-1"></i>Access Denied
                                </div>
                                <div class="text-gray-600">Company outside user scope and salary exceeds HROD approval limit.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="border rounded bg-white p-3 d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between">
                <div class="text-gray-600 mb-3 mb-lg-0">
                    <i class="fas fa-clipboard-check fa-fw text-secondary mr-1"></i>
                    Draft access profile ready for security review.
                </div>
                <div class="d-flex flex-wrap">
                    <button type="button" class="btn btn-outline-secondary btn-sm mr-2 mb-2 mb-lg-0" disabled>
                        <i class="fas fa-arrow-left fa-fw mr-1"></i>Cancel
                    </button>
                    <button type="button" class="btn btn-outline-info btn-sm mr-2 mb-2 mb-lg-0" disabled>
                        <i class="fas fa-sync-alt fa-fw mr-1"></i>Sync Azure AD
                    </button>
                    <button type="button" class="btn btn-outline-warning btn-sm mr-2 mb-2 mb-lg-0" disabled>
                        <i class="fas fa-shield-alt fa-fw mr-1"></i>Test Authorization
                    </button>
                    <button type="button" class="btn btn-primary btn-sm mb-2 mb-lg-0" disabled>
                        <i class="fas fa-save fa-fw mr-1"></i>Create User
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<Modal @ref="modalAddAttribute" Title="New Attribute">
    <ChildContent>
        <div class="attribute-modal small">
            <div class="alert alert-light border-left-info py-2 mb-3" role="alert">
                <div class="d-flex align-items-start">
                    <i class="fas fa-fingerprint fa-fw text-info mr-2 mt-1"></i>
                    <div>
                        <div class="font-weight-bold text-gray-800">ABAC attribute preview</div>
                        <div class="text-gray-600">Attribute values become claim candidates and policy inputs for resource, action, and approval checks.</div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-7 mb-3 mb-lg-0">
                    <div class="card shadow-sm border-left-primary h-100">
                        <div class="card-header py-2 bg-white d-flex align-items-center justify-content-between">
                            <h6 class="m-0 font-weight-bold text-primary text-uppercase text-xs">
                                <i class="fas fa-plus-circle fa-fw mr-1"></i>Attribute Details
                            </h6>
                            <span class="badge badge-light border">UserAttributes</span>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="font-weight-bold text-gray-700 mb-1">Attribute Name</label>
                                    <select class="form-control form-control-sm" disabled>
                                        <option selected>ApprovalLimit</option>
                                        <option>BusinessUnit</option>
                                        <option>CanApproveAboveBand</option>
                                        <option>Region</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="font-weight-bold text-gray-700 mb-1">Attribute Value</label>
                                    <input class="form-control form-control-sm" value="100000" readonly />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="font-weight-bold text-gray-700 mb-1">Value Type</label>
                                    <select class="form-control form-control-sm" disabled>
                                        <option selected>Number</option>
                                        <option>Text</option>
                                        <option>Boolean</option>
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="font-weight-bold text-gray-700 mb-1">Applies To</label>
                                    <select class="form-control form-control-sm" disabled>
                                        <option selected>Job Offer Approval</option>
                                        <option>Reporting Visibility</option>
                                        <option>Salary Matrix Maintenance</option>
                                    </select>
                                </div>
                                <div class="col-12 mb-3">
                                    <label class="font-weight-bold text-gray-700 mb-1">Description</label>
                                    <textarea class="form-control form-control-sm" rows="2" readonly>Maximum proposed salary the user can approve when RBAC role and resource scope match.</textarea>
                                </div>
                            </div>

                            <div class="d-flex flex-wrap">
                                @foreach (var tag in modalAttributeTags)
                                {
                                    <span class="badge @tag.BadgeClass mr-2 mb-2">
                                        <i class="@tag.Icon fa-fw mr-1"></i>@tag.Label
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="card shadow-sm border-left-success h-100">
                        <div class="card-header py-2 bg-white">
                            <h6 class="m-0 font-weight-bold text-success text-uppercase text-xs">
                                <i class="fas fa-shield-alt fa-fw mr-1"></i>Policy Impact
                            </h6>
                        </div>
                        <div class="card-body">
                            @foreach (var item in modalPolicyImpacts)
                            {
                                <div class="modal-impact-row">
                                    <div>
                                        <div class="font-weight-bold text-gray-800">@item.Title</div>
                                        <div class="text-gray-600">@item.Detail</div>
                                    </div>
                                    <span class="badge @item.BadgeClass">@item.Status</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-left-info mt-3">
                <div class="card-header py-2 bg-white d-flex align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-info text-uppercase text-xs">
                        <i class="fas fa-list-ul fa-fw mr-1"></i>Suggested Attributes
                    </h6>
                    <span class="badge badge-info">Mock Data</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm mb-0">
                            <thead class="thead-light">
                                <tr>
                                    <th>Attribute</th>
                                    <th>Sample Value</th>
                                    <th>Usage</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in modalSuggestedAttributes)
                                {
                                    <tr>
                                        <td class="font-weight-bold text-gray-800">@item.Name</td>
                                        <td>@item.Value</td>
                                        <td>@item.Usage</td>
                                        <td><span class="badge @item.BadgeClass">@item.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="modal-preview-box">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-2">
                            <i class="fas fa-code fa-fw mr-1"></i>Claim Preview
                        </div>
                        <div class="d-flex justify-content-between border-bottom py-1">
                            <span class="text-gray-500">Type</span>
                            <span class="font-weight-bold text-gray-900">ApprovalLimit</span>
                        </div>
                        <div class="d-flex justify-content-between py-1">
                            <span class="text-gray-500">Value</span>
                            <span class="font-weight-bold text-gray-900">100000</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="modal-preview-box">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-2">
                            <i class="fas fa-balance-scale fa-fw mr-1"></i>Evaluation Example
                        </div>
                        <div class="font-weight-bold text-gray-800 mb-1">JO.APPROVE</div>
                        <div class="text-gray-600">@("Allowed when Role = HROD Head, Company is in scope, and ProposedSalary <= 100000.")"</div>
                    </div>
                </div>
            </div>
        </div>
    </ChildContent>
    <FooterTemplate>
        <button type="button" class="btn btn-outline-secondary btn-sm" disabled>
            <i class="fas fa-times fa-fw mr-1"></i>Cancel
        </button>
        <button type="button" class="btn btn-primary btn-sm" disabled>
            <i class="fas fa-plus fa-fw mr-1"></i>Add Attribute
        </button>
    </FooterTemplate>
</Modal>

<style>
    .create-jo-user-page .page-icon,
    .create-jo-user-page .summary-icon {
        align-items: center;
        border-radius: 50%;
        color: #fff;
        display: inline-flex;
        flex: 0 0 auto;
        justify-content: center;
    }

    .create-jo-user-page .page-icon {
        height: 2.5rem;
        width: 2.5rem;
    }

    .create-jo-user-page .summary-icon {
        height: 2rem;
        width: 2rem;
    }

    .create-jo-user-page .metric-tile {
        align-items: center;
        background: #f8f9fc;
        display: flex;
        justify-content: space-between;
        min-height: 5rem;
        padding: 1rem;
    }

    .create-jo-user-page .role-row,
    .create-jo-user-page .scope-row,
    .create-jo-user-page .permission-row,
    .create-jo-user-page .claim-row,
    .create-jo-user-page .summary-row {
        border-bottom: 1px solid #e3e6f0;
        display: flex;
        gap: .75rem;
        justify-content: space-between;
        padding: .6rem 0;
    }

    .create-jo-user-page .role-row:first-child,
    .create-jo-user-page .scope-row:first-child,
    .create-jo-user-page .permission-row:first-child,
    .create-jo-user-page .claim-row:first-child,
    .create-jo-user-page .summary-row:first-child {
        padding-top: 0;
    }

    .create-jo-user-page .role-row:last-child,
    .create-jo-user-page .scope-row:last-child,
    .create-jo-user-page .permission-row:last-child,
    .create-jo-user-page .claim-row:last-child,
    .create-jo-user-page .summary-row:last-child {
        border-bottom: 0;
        padding-bottom: 0;
    }

    .create-jo-user-page .role-row,
    .create-jo-user-page .scope-row,
    .create-jo-user-page .permission-row,
    .create-jo-user-page .summary-row {
        align-items: center;
    }

    .create-jo-user-page .role-row.is-selected {
        background: #f0f4ff;
        border-radius: .35rem;
        margin: 0 -.5rem .2rem;
        padding: .6rem .5rem;
    }

    .create-jo-user-page .limit-box,
    .create-jo-user-page .routing-chip,
    .create-jo-user-page .simulation-result {
