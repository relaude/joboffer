    ];

    private readonly List<MockRoute> approvalRoute =
    [
        new("TA Partner", "Required", "badge-primary"),
        new("HROD Head", "Required", "badge-primary"),
        new("Division Head", "Required", "badge-primary"),
        new("President", "Conditional", "badge-warning")
    ];

    private readonly List<MockComparison> versionComparison =
    [
        new("Highest Salary", "PHP 45,000", "PHP 50,000", true),
        new("Difference", "-", "PHP 5,000", true),
        new("Highest Increase %", "28.57%", "42.86%", true),
        new("Negotiation Reason", "Candidate Declined", "Requested Negotiation", false)
