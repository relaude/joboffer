        new("Option 2", "PHP 48,000.00", "PHP 3,000.00", "PHP 1,500.00", "PHP 52,500.00", "37.1%", "1.07", "Upper Band", "badge-info", "fas fa-check-circle"),
        new("Option 3", "PHP 50,000.00", "PHP 3,000.00", "PHP 1,500.00", "PHP 54,500.00", "42.9%", "1.11", "Upper Band", "badge-warning", "fas fa-exclamation-triangle")
    ];

    private readonly MockJustification justification = new(
