    private readonly List<MockTimeline> negotiationTimeline =
    [
        new("June 15, 2026", "Candidate Feedback", "Candidate declined Option B and requested PHP 48,000.00 salary.", "fas fa-comment-dots", "bg-warning"),
        new("June 16, 2026", "Version Created", "TA Partner initiated Version 2 proposal set under the same job offer transaction.", "fas fa-code-branch", "bg-info"),
        new("June 16, 2026", "Validation", "System recalculated increase percentage, compa-ratio, band position, and approval route preview.", "fas fa-calculator", "bg-primary")
    ];

    private readonly List<string> preservedRecords =
    [
        "Rejected proposals",
        "Declined approved offers",
        "Candidate feedback",
        "Approver comments",
        "Prior versions",
        "Salary band flags and candidate responses"
    ];

    private sealed record MockHeader(
        string JobOfferNo,
        string CurrentVersion,
        string NewVersion,
        string CandidateName,
        string PositionTitle,
        string Status);

    private sealed record MockStep(
        string Name,
        string Icon,
        string Status,
        string BadgeClass,
        string TextClass);

    private sealed record MockPair(
        string Label,
        string Value,
        bool Highlight = false);

    private sealed record MockPreviousOffer(
        string Name,
        string BaseSalary,
        string Allowance,
        string Transportation,
        string Status);

    private sealed record MockApproval(
        string Actor,
        string Decision,
        string Remarks,
        string BadgeClass);

    private sealed record MockProposal(
        string Name,
        string BaseSalary,
        string Allowance,
        string Transportation,
        string TotalPackage,
        string IncreasePercent,
        string CompaRatio,
        string BandPosition,
        string ValidationBadge,
        string ValidationIcon);

    private sealed record MockJustification(
        string ReProposalReason,
        string BusinessJustification);

    private sealed record MockRoute(
        string Actor,
        string Requirement,
        string BadgeClass);

    private sealed record MockComparison(
        string Metric,
        string VersionOne,
        string VersionTwo,
        bool Highlight);

    private sealed record MockTimeline(
        string Date,
        string Tag,
        string Notes,
        string Icon,
        string IconBg);
}
