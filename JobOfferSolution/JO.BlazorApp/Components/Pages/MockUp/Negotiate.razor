    private readonly List<MockPair> candidateFeedback =
    [
        new("Discussion Date", "June 15, 2026", false),
        new("Candidate Response", "Requested Negotiation", true),
        new("Requested Salary", "PHP 48,000.00", true),
        new("Current Version", "V1", false),
        new("New Version", "V2", true)
    ];

    private readonly string feedbackReason = "Current offer is below market expectation. Candidate received competing offers and requested a revised salary package closer to PHP 48,000.00.";

    private readonly List<MockPreviousOffer> previousOffers =
    [
        new("Option A", "PHP 42,000.00", "PHP 3,000.00", "PHP 1,500.00", "Declined"),
        new("Option B", "PHP 45,000.00", "PHP 3,000.00", "PHP 1,500.00", "Declined")
