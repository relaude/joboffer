        new("Job Offer Analysis", "fas fa-chart-line", "Done", "badge-success", "text-success"),
        new("Approval Routing", "fas fa-route", "Done", "badge-success", "text-success"),
        new("Candidate Discussion", "fas fa-comments", "Done", "badge-success", "text-success"),
        new("Negotiation & Re-Proposal", "fas fa-sync-alt", "Current", "badge-warning", "text-warning"),
        new("Approval Routing V2", "fas fa-user-check", "Next", "badge-light border", "text-gray-500"),
        new("Candidate Acceptance", "fas fa-handshake", "Open", "badge-light border", "text-gray-500"),
        new("Offer Letter", "fas fa-file-signature", "Open", "badge-light border", "text-gray-500")
