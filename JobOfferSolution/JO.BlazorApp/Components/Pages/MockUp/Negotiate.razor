    private readonly List<MockApproval> previousApprovals =
    [
        new("TA Partner", "Approved Analysis", "Salary package reviewed and routed.", "badge-success"),
        new("HROD Head", "Approved", "Approved Option A and B.", "badge-success"),
        new("Division Head", "Approved", "Approved Option A and B.", "badge-success"),
        new("President", "Not Required", "No above-band escalation in V1.", "badge-light border")
    ];

    private readonly List<MockProposal> newProposals =
    [
