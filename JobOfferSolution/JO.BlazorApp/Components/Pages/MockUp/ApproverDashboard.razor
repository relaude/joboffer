@attribute [Route(JORoutes.MockUp.ApproverDashboard)]

<div class="card shadow mb-4 border-left-primary small approver-dashboard-page">
    <div class="card-header py-3 bg-white">
        <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between">
            <div>
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-user-check fa-fw mr-2"></i>
                    Approver Dashboard
                </h6>
                <small class="text-muted">Welcome, @approver.Name | Role: @approver.Role | Today: @approver.Today | Mockup data only</small>
            </div>

            <div class="mt-2 mt-lg-0">
                <span class="badge badge-light border mr-1">
                    <i class="fas fa-clipboard-check fa-fw text-primary mr-1"></i>
                    Approval View
                </span>
                <span class="badge badge-warning">
                    <i class="fas fa-clock fa-fw mr-1"></i>
                    SLA Watch
                </span>
            </div>
        </div>
    </div>

    <div class="card-body">
        <ul class="nav nav-tabs small mb-4" role="tablist">
            @foreach (var menu in menus)
            {
                <li class="nav-item">
                    <a class="nav-link @(menu.IsActive ? "active" : "disabled")" href="javascript:void(0)">
                        <i class="@menu.Icon fa-fw mr-1"></i>
                        @menu.Label
                    </a>
                </li>
            }
        </ul>

        <div class="row">
            @foreach (var kpi in kpiCards)
            {
                <div class="col-xl-2 col-md-4 col-6 mb-4">
                    <div class="card border-left-@kpi.Color shadow h-100 py-2">
                        <div class="card-body py-2">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-@kpi.Color text-uppercase mb-1">@kpi.Label</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">@kpi.Value</div>
                                </div>
                                <div class="col-auto">
                                    <i class="@kpi.Icon fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="row">
            <div class="col-xl-7 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light d-flex flex-column flex-md-row justify-content-between">
                        <div>
                            <h6 class="m-0 font-weight-bold text-gray-800">
                                <i class="fas fa-inbox fa-fw text-primary mr-2"></i>
                                Pending Approvals
                            </h6>
                            <small class="text-muted">Review salary proposals, validation results, justifications, and prior comments.</small>
                        </div>
                        <span class="badge badge-danger mt-2 mt-md-0 align-self-start align-self-md-center">2 High Priority</span>
                    </div>

                    <div class="p-3">
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Priority</th>
                                        <th>Candidate</th>
                                        <th>Position</th>
                                        <th>Aging</th>
                                        <th class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var approval in approvalQueue)
                                    {
                                        <tr>
                                            <td><span class="badge @approval.PriorityBadge">@approval.Priority</span></td>
                                            <td class="font-weight-bold text-gray-900">@approval.Candidate</td>
                                            <td>@approval.Position</td>
                                            <td>@approval.Aging</td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-outline-primary btn-sm btn-sml" disabled>
                                                    <i class="fas fa-eye fa-fw mr-1"></i>
                                                    Review
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-5 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-stream fa-fw text-primary mr-2"></i>
                            Current Approval Workload
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var item in workload)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="font-weight-bold text-gray-800">@item.Label</span>
                                    <span class="badge @item.BadgeClass">@item.Count</span>
                                </div>
                                <div class="progress progress-sm">
                                    <div class="progress-bar @item.BarClass" role="progressbar" style="@item.WidthStyle"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-stopwatch fa-fw text-primary mr-2"></i>
                            Approval SLA Monitoring
                        </h6>
                    </div>

                    <div class="p-3">
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Candidate</th>
                                        <th>Stage</th>
                                        <th>Target</th>
                                        <th>Actual</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in slaItems)
                                    {
                                        <tr>
                                            <td class="font-weight-bold text-gray-900">@item.Candidate</td>
                                            <td>@item.Stage</td>
                                            <td>@item.Target</td>
                                            <td>@item.Actual</td>
                                            <td><span class="badge @item.BadgeClass">@item.Status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light d-flex flex-column flex-md-row justify-content-between">
                        <div>
                            <h6 class="m-0 font-weight-bold text-gray-800">
                                <i class="fas fa-exclamation-triangle fa-fw text-danger mr-2"></i>
                                Above Band Cases
                            </h6>
                            <small class="text-muted">Above-band proposals are escalated to President review when required.</small>
                        </div>
                        <span class="badge badge-danger mt-2 mt-md-0 align-self-start align-self-md-center">Escalation</span>
                    </div>

                    <div class="p-3">
                        <div class="table-responsive">
                            <table class="table table-bordered table-sm mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Candidate</th>
                                        <th>Position</th>
                                        <th>Salary</th>
                                        <th>Band Max</th>
                                        <th class="text-center">Open</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in aboveBandCases)
                                    {
                                        <tr>
                                            <td class="font-weight-bold text-gray-900">@item.Candidate</td>
                                            <td>@item.Position</td>
                                            <td class="font-weight-bold text-danger">@item.Salary</td>
                                            <td>@item.BandMax</td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-outline-danger btn-sm btn-sml" disabled>
                                                    <i class="fas fa-external-link-alt fa-fw mr-1"></i>
                                                    Review
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="border rounded bg-white mb-4">
            <div class="px-3 py-2 border-bottom bg-light">
                <h6 class="m-0 font-weight-bold text-gray-800">
                    <i class="fas fa-clipboard-list fa-fw text-primary mr-2"></i>
                    Pending Review Cards
                </h6>
            </div>

            <div class="p-3">
                <div class="row">
                    @foreach (var card in reviewCards)
                    {
                        <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
                            <div class="border rounded bg-light h-100">
                                <div class="px-3 py-2 border-bottom bg-white d-flex justify-content-between">
                                    <span class="font-weight-bold text-gray-900">@card.Candidate</span>
                                    <span class="badge @card.BadgeClass">@card.Status</span>
                                </div>
                                <div class="p-3">
                                    <div class="d-flex justify-content-between border-bottom py-1">
                                        <span class="text-muted">Position</span>
                                        <span class="font-weight-bold text-gray-900">@card.Position</span>
                                    </div>
                                    <div class="d-flex justify-content-between border-bottom py-1">
                                        <span class="text-muted">Company</span>
                                        <span>@card.Company</span>
                                    </div>
                                    <div class="d-flex justify-content-between border-bottom py-1">
                                        <span class="text-muted">Highest Proposal</span>
                                        <span class="font-weight-bold text-primary">@card.HighestProposal</span>
                                    </div>
                                    <div class="d-flex justify-content-between py-1">
                                        <span class="text-muted">Aging</span>
                                        <span>@card.Aging</span>
                                    </div>
                                    <button type="button" class="btn btn-outline-primary btn-sm btn-sml btn-block mt-3" disabled>
                                        <i class="fas fa-eye fa-fw mr-1"></i>
                                        Review
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-5 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-building fa-fw text-primary mr-2"></i>
                            Company Approval Queue
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var item in companyQueue)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="font-weight-bold text-gray-800">@item.Label</span>
                                    <span class="badge badge-light border">@item.Count</span>
                                </div>
                                <div class="progress progress-sm">
                                    <div class="progress-bar bg-primary" role="progressbar" style="@item.WidthStyle"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-7 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-bolt fa-fw text-primary mr-2"></i>
                            Immediate Attention
                        </h6>
                    </div>

                    <div class="p-3">
                        <div class="row">
                            <div class="col-md-7 mb-3 mb-md-0">
                                @foreach (var item in quickReview)
                                {
                                    <div class="d-flex justify-content-between border-bottom py-1">
                                        <span class="text-muted">@item.Label</span>
                                        <span class="font-weight-bold @(item.Highlight ? "text-danger" : "text-gray-900")">@item.Value</span>
                                    </div>
                                }
                            </div>
                            <div class="col-md-5">
                                <div class="border-left-danger bg-light px-3 py-2 mb-3">
                                    <i class="fas fa-exclamation-circle fa-fw text-danger mr-1"></i>
                                    Above-band proposal requires focused review of business justification and prior approver comments.
                                </div>
                                <button type="button" class="btn btn-danger btn-sm btn-sml btn-block" disabled>
                                    <i class="fas fa-eye fa-fw mr-1"></i>
                                    Review Now
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-xl-4 col-lg-6 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-chart-pie fa-fw text-primary mr-2"></i>
                            Approval Status
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var item in approvalStatus)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span>@item.Label</span>
                                    <span class="font-weight-bold text-gray-900">@item.Value</span>
                                </div>
                                <div class="progress progress-sm">
                                    <div class="progress-bar @item.BarClass" role="progressbar" style="@item.WidthStyle"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-xl-4 col-lg-6 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-chart-line fa-fw text-primary mr-2"></i>
                            Approval Volume Trend
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var item in volumeTrend)
                        {
                            <div class="d-flex align-items-center mb-2">
                                <span class="trend-month">@item.Month</span>
                                <div class="progress progress-sm flex-fill mx-2">
                                    <div class="progress-bar bg-success" role="progressbar" style="@item.WidthStyle"></div>
                                </div>
                                <span class="font-weight-bold text-gray-900 trend-value">@item.Value</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-xl-4 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-balance-scale fa-fw text-primary mr-2"></i>
                            Salary Band Distribution
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var item in salaryBandDistribution)
                        {
                            <div class="d-flex align-items-center mb-3">
                                <span class="icon-circle @item.IconBg text-white mr-3 dashboard-icon-sm">
                                    <i class="@item.Icon fa-sm"></i>
                                </span>
                                <div class="flex-fill">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="font-weight-bold text-gray-800">@item.Label</span>
                                        <span>@item.Value</span>
                                    </div>
                                    <div class="progress progress-sm">
                                        <div class="progress-bar @item.BarClass" role="progressbar" style="@item.WidthStyle"></div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-4 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-bell fa-fw text-primary mr-2"></i>
                            Notifications
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var notification in notifications)
                        {
                            <div class="d-flex mb-3">
                                <span class="icon-circle @notification.IconBg text-white mr-3 dashboard-icon-sm">
                                    <i class="@notification.Icon fa-sm"></i>
                                </span>
                                <div class="border-bottom flex-fill pb-2">
                                    <div class="font-weight-bold text-gray-900">@notification.Message</div>
                                    <div class="text-muted">@notification.Age</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-check-circle fa-fw text-primary mr-2"></i>
                            Recent Approvals
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var approval in recentApprovals)
                        {
                            <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                                <div>
                                    <div class="font-weight-bold text-gray-900">@approval.Candidate</div>
                                    <div class="text-muted">@approval.Date</div>
                                </div>
                                <span class="badge @approval.BadgeClass">@approval.Decision</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-undo fa-fw text-primary mr-2"></i>
                            Returned To TA Partner
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var item in returnedCases)
                        {
                            <div class="border-bottom py-2">
                                <div class="font-weight-bold text-gray-900">@item.Candidate</div>
                                <div class="text-muted">@item.Reason</div>
                            </div>
                        }

                        <div class="border-left-info bg-light px-3 py-2 mt-3">
                            <i class="fas fa-info-circle fa-fw text-info mr-1"></i>
                            Return comments are retained with approver identity and timestamp.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-5 mb-4 mb-lg-0">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-clipboard-check fa-fw text-primary mr-2"></i>
                            My Decisions Today
                        </h6>
                    </div>

                    <div class="p-3">
                        @foreach (var decision in decisionsToday)
                        {
                            <div class="d-flex justify-content-between align-items-center border-bottom py-2">
                                <span class="font-weight-bold text-gray-800">@decision.Label</span>
                                <span class="badge @decision.BadgeClass">@decision.Count</span>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="border rounded bg-white h-100">
                    <div class="px-3 py-2 border-bottom bg-light">
                        <h6 class="m-0 font-weight-bold text-gray-800">
                            <i class="fas fa-bolt fa-fw text-primary mr-2"></i>
                            Quick Actions
                        </h6>
                    </div>

                    <div class="p-3 d-flex flex-column flex-md-row">
                        <button type="button" class="btn btn-primary btn-sm btn-sml mb-2 mb-md-0 mr-md-2" disabled>
                            <i class="fas fa-inbox fa-fw mr-1"></i>
                            My Approvals
                        </button>
                        <button type="button" class="btn btn-warning btn-sm btn-sml mb-2 mb-md-0 mr-md-2" disabled>
                            <i class="fas fa-exclamation-triangle fa-fw mr-1"></i>
                            Above Band Cases
                        </button>
                        <button type="button" class="btn btn-info btn-sm btn-sml mb-2 mb-md-0 mr-md-2" disabled>
                            <i class="fas fa-chart-pie fa-fw mr-1"></i>
                            Approval Analytics
                        </button>
                        <button type="button" class="btn btn-success btn-sm btn-sml" disabled>
                            <i class="fas fa-check-double fa-fw mr-1"></i>
                            Completed Approvals
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .approver-dashboard-page .form-ctrl-sml {
        font-size: 0.78rem;
        min-height: 31px;
    }

    .approver-dashboard-page .btn-sml {
        font-size: 0.76rem;
        padding: 0.25rem 0.65rem;
    }

    .approver-dashboard-page .dashboard-icon-sm {
        height: 2rem;
        width: 2rem;
        min-width: 2rem;
    }

    .approver-dashboard-page .nav-tabs .nav-link {
        padding: 0.45rem 0.75rem;
    }

    .approver-dashboard-page .trend-month {
        width: 2.5rem;
    }

    .approver-dashboard-page .trend-value {
        width: 2rem;
        text-align: right;
    }
</style>

